.App {
    text-align: center;
    font-family: 'Arial', sans-serif;
  }
  
  .App-header {
    background-color: #282c34;
    min-height: 10vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: calc(10px + 1.5vmin);
    color: white;
    padding: 1rem;
  }
  
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem;
  }
  
  .simulation-section {
    width: 100%;
    max-width: 1024px;
    margin-bottom: 1rem;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
  }
  
  .controls-section {
    width: 100%;
    max-width: 1024px;
    padding: 1rem;
    background-color: #f5f5f5;
    border-radius: 5px;
  }
  
  button {
    background-color: #4CAF50;
    border: none;
    color: white;
    padding: 10px 20px;
    text-align: center;
    text-decoration: none;
    display: inline-block;
    font-size: 16px;
    margin: 4px 2px;
    cursor: pointer;
    border-radius: 4px;
    transition: background-color 0.3s;
  }
  
  button:hover {
    background-color: #45a049;
  }
  
  /* Stile per il container del gioco Phaser */
  #phaser-game {
    border: 2px solid #ccc;
    border-radius: 5px;
    overflow: hidden;
  }