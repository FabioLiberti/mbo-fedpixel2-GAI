.splash-screen {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  background-color: #000000;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  transition: opacity 0.8s ease;
}

.splash-screen.fade-out {
  opacity: 0;
  pointer-events: none;
}

.fallback-content {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.splash-video-fallback {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.click-text-fallback {
  position: absolute;
  bottom: 40px;
  font-family: Arial, sans-serif;
  font-size: 16px;
  color: white;
  opacity: 0.7;
  animation: pulse 2s ease-in-out infinite;
  text-shadow: 0 0 5px rgba(0, 0, 0, 0.8);
}

@keyframes pulse {
  0% { opacity: 0.5; }
  50% { opacity: 1; }
  100% { opacity: 0.5; }
}