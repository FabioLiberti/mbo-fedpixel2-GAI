.splash-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 999;
    background-color: #000000;
    transition: opacity 0.8s ease;
  }
  
  .splash-screen.fade-out {
    opacity: 0;
    pointer-events: none;
  }
  
  .video-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }
  
  .splash-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .unmute-prompt {
    position: absolute;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%);
    background-color: rgba(0, 0, 0, 0.7);
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    cursor: pointer;
    animation: pulse 2s infinite;
    z-index: 1000;
  }
  
  .click-to-continue {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: rgba(0, 0, 0, 0.7);
    color: white;
    padding: 15px 30px;
    border-radius: 10px;
    font-size: 24px;
    font-weight: bold;
    cursor: pointer;
    animation: pulse 1.5s infinite;
    z-index: 1000;
  }
  
  @keyframes pulse {
    0% { opacity: 0.6; }
    50% { opacity: 1; }
    100% { opacity: 0.6; }
  }
  
  @media (max-width: 768px) {
    .splash-video {
      object-fit: contain;
    }
    
    .unmute-prompt {
      bottom: 40px;
      font-size: 12px;
    }
    
    .click-to-continue {
      font-size: 18px;
      padding: 10px 20px;
    }
  }