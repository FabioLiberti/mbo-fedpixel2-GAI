.splash-screen-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background-color: #222222;
    z-index: 1000;
    cursor: pointer;
  }
  
  .phaser-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  
  /* Stile per il layer di fallback */
  .fallback-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: -1; /* Dietro il contenitore Phaser */
  }
  
  .logo-container {
    display: flex;
    margin-bottom: 30px;
  }
  
  .lab-box {
    width: 50px;
    height: 50px;
    margin: 0 10px;
    border-radius: 4px;
    animation: pulse 2s infinite ease-in-out;
  }
  
  .mercatorum {
    background-color: #c27c54; /* terracotta */
    animation-delay: 0s;
  }
  
  .blekinge {
    background-color: #add8e6; /* ice blue */
    animation-delay: 0.3s;
  }
  
  .opbg {
    background-color: #98d8c8; /* aqua green */
    animation-delay: 0.6s;
  }
  
  .loading-text {
    color: white;
    font-size: 18px;
    margin: 20px 0;
  }
  
  .skip-text {
    color: rgba(255, 255, 255, 0.5);
    font-size: 14px;
    position: absolute;
    bottom: 20px;
    right: 20px;
  }
  
  @keyframes pulse {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
    100% {
      transform: scale(1);
    }
  }