import * as Phaser from 'phaser';
import { BaseScene } from './BaseScene';
import LabMiniature from '../entities/LabMiniature';
import { GlobalAgentController } from '../controllers/GlobalAgentController';
import { SCENE_KEYS } from '../game';
import { LabType } from '../types/LabType';
import { AgentsLegend } from '../ui/AgentsLegend';
import { FLController } from '../fl/FLController';
import { LAB_TYPES, LabTypeId } from '../types/LabTypeConstants';
import { FLState } from '../fl/FLState';
import { emitFLPanelToggle, getFLPanelState, updateFLPanelState } from '../../utils/customEvents';

interface PhaserTimer {
  callback: Function;
  remove: () => void;
  paused: boolean;
}

export class WorldMapScene extends BaseScene {
  private labMiniatures: Map<string, LabMiniature> = new Map();
  
  // FL Controller
  private flController: FLController;
  
  // Inizializzazione delle proprietà per risolvere gli errori TS2564
  private globalAgentController!: GlobalAgentController;
  private navigationButtons!: Phaser.GameObjects.Container;
  private infoPanel!: Phaser.GameObjects.Container;
  private connectionGraphics!: Phaser.GameObjects.Graphics;
  private mercatorumMiniature!: LabMiniature;
  private blekingeMiniature!: LabMiniature;
  private opbgMiniature!: LabMiniature;
  private agentsLegend!: AgentsLegend;
  
  // Debug properties
  private debugGraphics!: Phaser.GameObjects.Graphics;
  private debugText!: Phaser.GameObjects.Text;
  private debugMode: boolean = false; // Inizia con il debug disattivato

  constructor() {
    super('WorldMapScene');
    this.flController = FLController.getInstance();
  }

  init(): void {
    super.init();
    this.cameras.main.setBackgroundColor('#1a1a2e');
  }

  preload(): void {
    super.preload();
    console.log("WorldMapScene: Preloading assets...");
    
    // Debug: log all available textures
    console.log("Available textures:", Object.keys(this.textures.list));
    
    // Precaricare assets specifici della mappa mondiale
    this.load.image('world-map-background', 'assets/ui/world-map-background.png');
    this.load.image('lab-connection', 'assets/ui/lab-connection-line.png');
    this.load.image('data-exchange-icon', 'assets/ui/data-exchange-icon.ico');
    this.load.image('agent-dot', 'assets/ui/agent-dot.png');
    
    // Pulsanti UI
    this.load.image('info-button', 'assets/ui/info-button.png');
    this.load.image('settings-button', 'assets/ui/settings-button.png');
    this.load.image('close-button', 'assets/ui/close-button.png');
    
    // Miniature dei laboratori - carica immagini più grandi e dettagliate
    this.load.image('mercatorum_preview', 'assets/images/labs/mercatorum_preview.png');
    this.load.image('blekinge_preview', 'assets/images/labs/blekinge_preview.png');
    this.load.image('opbg_preview', 'assets/images/labs/opbg_preview.png');
    
    // Carica anche le versioni alternative per compatibilità
    this.load.image('mercatorum', 'assets/images/labs/mercatorum_preview.png');
    this.load.image('blekinge', 'assets/images/labs/blekinge_preview.png');
    this.load.image('opbg', 'assets/images/labs/opbg_preview.png');
    
    // Immagine di fallback
    this.load.image('default_lab', 'assets/images/labs/default_preview.png');
    
    // Precarica il file di configurazione degli agenti per la legenda
    this.load.json('agentTypesConfig', 'assets/config/agentTypes.json');
  }

  async create(): Promise<void> {
    console.log("WorldMapScene: Creating scene...");
    
    // Initialize debug mode
    this.setupDebugMode();
    
    // Log all textures available after loading
    console.log("Create: Available textures:", Object.keys(this.textures.list));
    
    // Creazione dello sfondo della mappa mondiale
    const background = this.add.image(this.cameras.main.centerX, this.cameras.main.centerY, 'world-map-background')
      .setOrigin(0.5)
      .setDisplaySize(this.cameras.main.width, this.cameras.main.height);
    
    // Debug: Log the background dimensions
    console.log(`Background dimensions: ${background.width}x${background.height}`);
    console.log(`Display dimensions: ${background.displayWidth}x${background.displayHeight}`);
    
    // Creazione delle grafiche per le connessioni
    this.connectionGraphics = this.add.graphics();
    
    // Posizionamento delle miniature dei laboratori
    this.createLabMiniatures();
    
    // Creazione delle connessioni tra laboratori
    this.createLabConnections();
    
    // Inizializzazione del controller degli agenti globali
    this.globalAgentController = new GlobalAgentController(this);
    this.globalAgentController.initialize();
    
    // Creazione dei pulsanti di navigazione
    this.createNavigationUI();
    
    // Creazione del pannello informativo
    this.createInfoPanel();
    
    // Creazione della legenda degli agenti
    await this.createAgentsLegend();
    
    // Registrazione degli eventi
    this.registerEvents();
    
    // Aggiungi effetti alle connessioni
    this.addConnectionGlow();
    
    // Inizializza gli effetti FL per la mappa mondiale
    this.flController.initWorldMapEffects(this);
    
    // Emetti un evento per aggiornare lo stato FL iniziale
    this.triggerInitialFLState();
    
    // Update debug info
    this.updateDebugInfo();
    
    // Emetti un evento quando la scena viene chiusa
    this.events.on('shutdown', () => {
      this.game.events.emit('sceneShutdown', 'WorldMapScene');
    });

    // Aggiungi listener per eventi dai controlli di simulazione React
    this.setupSimulationControls();
  }

  update(time: number, delta: number): void {
    // Aggiorna le connessioni per mantenerle fluide
    this.updateConnections();
    
    // Correzione dell'errore TS2802 usando Array.from
    Array.from(this.labMiniatures.values()).forEach(miniature => {
      if (typeof miniature.update === 'function') {
        miniature.update(time, delta);
      }
    });
    
    // Aggiornamento degli agenti sulla mappa
    if (this.globalAgentController) {
      this.globalAgentController.update(time, delta);
    }
  }

  /**
   * Configura i listener per i controlli di simulazione dalla UI React
   */
  private setupSimulationControls(): void {
    // Ascolta eventi dai pulsanti di simulazione
    this.game.events.on('simulation:start', () => {
      console.log('Simulation start event received');
      this.startFLSimulation();
    });

    this.game.events.on('simulation:pause', () => {
      console.log('Simulation pause event received');
      this.pauseFLSimulation();
    });

    this.game.events.on('simulation:stop', () => {
      console.log('Simulation stop event received');
      this.stopFLSimulation();
    });

    this.game.events.on('simulation:reset', () => {
      console.log('Simulation reset event received');
      this.resetFLSimulation();
    });

    // Ascolta eventi di toggle FL dalla legenda
    this.game.events.on('toggleFL', (data: { enabled: boolean }) => {
      console.log('Toggle FL event received:', data);
      if (data.enabled) {
        this.startFLSimulation();
      } else {
        this.stopFLSimulation();
      }
    });
    
    // Aggiungi questo event listener per il toggle del pannello FL
    this.game.events.on('toggleFLPanel', (data: { visible: boolean }) => {
      // Invia un evento al componente React che gestisce l'interfaccia FL
      console.log('FL Panel visibility changed:', data.visible);
      
      // Se il pannello dovrebbe essere visibile ma la simulazione non è attiva,
      // avviamo anche la simulazione
      if (data.visible && !this.flController.isEnabled()) {
        this.startFLSimulation();
      }
    });
  }

  /**
   * Avvia la simulazione FL
   */
  private startFLSimulation(): void {
    try {
      // Correzione per l'errore getTimers
      let timerRemoved = false;
      
      try {
        // Prima cerca di usare getTimers() se esiste
        if (typeof this.time.getTimers === 'function') {
          const timers = this.time.getTimers();
          if (Array.isArray(timers)) {
            timers.forEach((timer: PhaserTimer) => {
              if (timer.callback === this.updateFLState) {
                timer.remove();
                timerRemoved = true;
              }
            });
          }
        } else if (this.time._timerEvents) {
          // Altrimenti usa _timerEvents
          const timers = this.time._timerEvents;
          if (Array.isArray(timers)) {
            timers.forEach((timer: PhaserTimer) => {
              if (timer.callback === this.updateFLState) {
                timer.remove();
                timerRemoved = true;
              }
            });
          }
        }
      } catch (e) {
        console.warn("Could not access timer array:", e);
      }
      
      if (!timerRemoved) {
        console.warn("Could not access timer array, creating new timer anyway");
      }

      // Crea un nuovo stato FL attivo
      const flStatus = {
        enabled: true,
        currentState: FLState.TRAINING,
        activeAgents: [
          {
            id: 'agent1',
            state: FLState.TRAINING,
            labType: LAB_TYPES.MERCATORUM,
            agentType: 'researcher'
          },
          {
            id: 'agent2',
            state: FLState.SENDING,
            labType: LAB_TYPES.BLEKINGE,
            agentType: 'ml_engineer'
          },
          {
            id: 'agent3',
            state: FLState.RECEIVING,
            labType: LAB_TYPES.OPBG,
            agentType: 'doctor'
          }
        ],
        metrics: {
          accuracy: 0.7,
          loss: 0.3,
          round: 1,
          clientFraction: 0.67
        },
        connections: [
          {
            source: LAB_TYPES.MERCATORUM,
            target: LAB_TYPES.BLEKINGE,
            active: true
          },
          {
            source: LAB_TYPES.BLEKINGE,
            target: LAB_TYPES.OPBG,
            active: true
          },
          {
            source: LAB_TYPES.OPBG,
            target: LAB_TYPES.MERCATORUM,
            active: true
          }
        ]
      };

      // Invia l'evento
      this.game.events.emit('updateFLStatus', flStatus);

      // Avvia gli aggiornamenti periodici con il contesto corretto
      this.time.addEvent({
        delay: 5000, // Ogni 5 secondi
        callback: this.updateFLState,
        callbackScope: this,
        loop: true
      });

      console.log("FL Simulation started");
    } catch (error) {
      console.error("Error starting FL simulation:", error);
    }
  }

  /**
   * Mette in pausa la simulazione FL
   */
  private pauseFLSimulation(): void {
    try {
      // Trova e metti in pausa tutti i timer che aggiornano lo stato FL
      let timerPaused = false;
      
      try {
        if (typeof this.time.getTimers === 'function') {
          const timers = this.time.getTimers();
          if (Array.isArray(timers)) {
            timers.forEach((timer: PhaserTimer) => {
              if (timer.callback === this.updateFLState) {
                timer.paused = true;
                timerPaused = true;
              }
            });
          }
        } else if (this.time._timerEvents) {
          const timers = this.time._timerEvents;
          if (Array.isArray(timers)) {
            timers.forEach((timer: PhaserTimer) => {
              if (timer.callback === this.updateFLState) {
                timer.paused = true;
                timerPaused = true;
              }
            });
          }
        }
      } catch (e) {
        console.warn("Could not access timer array:", e);
      }
      
      if (!timerPaused) {
        console.warn("Could not pause timer");
      }

      console.log("FL Simulation paused");
    } catch (error) {
      console.error("Error pausing FL simulation:", error);
    }
  }

  /**
   * Ferma la simulazione FL
   */
  private stopFLSimulation(): void {
    try {
      // Trova e rimuovi tutti i timer che aggiornano lo stato FL
      let timerRemoved = false;
      
      try {
        if (typeof this.time.getTimers === 'function') {
          const timers = this.time.getTimers();
          if (Array.isArray(timers)) {
            timers.forEach((timer: PhaserTimer) => {
              if (timer.callback === this.updateFLState) {
                timer.remove();
                timerRemoved = true;
              }
            });
          }
        } else if (this.time._timerEvents) {
          const timers = this.time._timerEvents;
          if (Array.isArray(timers)) {
            timers.forEach((timer: PhaserTimer) => {
              if (timer.callback === this.updateFLState) {
                timer.remove();
                timerRemoved = true;
              }
            });
          }
        }
      } catch (e) {
        console.warn("Could not access timer array:", e);
      }
      
      if (!timerRemoved) {
        console.warn("Could not remove timer");
      }

      // Crea un evento di stato FL disabilitato
      const flStatus = {
        enabled: false,
        currentState: FLState.IDLE,
        activeAgents: [],
        metrics: {
          accuracy: 0,
          loss: 0,
          round: 0,
          clientFraction: 0
        },
        connections: [
          {
            source: LAB_TYPES.MERCATORUM,
            target: LAB_TYPES.BLEKINGE,
            active: false
          },
          {
            source: LAB_TYPES.BLEKINGE,
            target: LAB_TYPES.OPBG,
            active: false
          },
          {
            source: LAB_TYPES.OPBG,
            target: LAB_TYPES.MERCATORUM,
            active: false
          }
        ]
      };

      // Invia l'evento
      this.game.events.emit('updateFLStatus', flStatus);

      console.log("FL Simulation stopped");
    } catch (error) {
      console.error("Error stopping FL simulation:", error);
    }
  }

  /**
   * Resetta la simulazione FL
   */
  private resetFLSimulation(): void {
    try {
      // Prima ferma
      this.stopFLSimulation();
      
      // Poi riavvia con valori iniziali
      const flStatus = {
        enabled: true,
        currentState: FLState.IDLE,
        activeAgents: [
          {
            id: 'agent1',
            state: FLState.IDLE,
            labType: LAB_TYPES.MERCATORUM,
            agentType: 'researcher'
          },
          {
            id: 'agent2',
            state: FLState.IDLE,
            labType: LAB_TYPES.BLEKINGE,
            agentType: 'ml_engineer'
          },
          {
            id: 'agent3',
            state: FLState.IDLE,
            labType: LAB_TYPES.OPBG,
            agentType: 'doctor'
          }
        ],
        metrics: {
          accuracy: 0,
          loss: 1.0,
          round: 0,
          clientFraction: 0.67
        },
        connections: [
          {
            source: LAB_TYPES.MERCATORUM,
            target: LAB_TYPES.BLEKINGE,
            active: false
          },
          {
            source: LAB_TYPES.BLEKINGE,
            target: LAB_TYPES.OPBG,
            active: false
          },
          {
            source: LAB_TYPES.OPBG,
            target: LAB_TYPES.MERCATORUM,
            active: false
          }
        ]
      };

      // Invia l'evento
      this.game.events.emit('updateFLStatus', flStatus);

      console.log("FL Simulation reset");
    } catch (error) {
      console.error("Error resetting FL simulation:", error);
    }
  }

  /**
   * Invia un evento di stato FL iniziale per attivare la visualizzazione del pannello
   */
  private triggerInitialFLState(): void {
    try {
      // Crea un evento FL di esempio per attivare la visualizzazione
      const initialFLStatus = {
        enabled: true,
        currentState: FLState.IDLE,
        activeAgents: [
          {
            id: 'agent1',
            state: FLState.TRAINING,
            labType: LAB_TYPES.MERCATORUM,
            agentType: 'researcher'
          },
          {
            id: 'agent2',
            state: FLState.SENDING,
            labType: LAB_TYPES.BLEKINGE,
            agentType: 'ml_engineer'
          },
          {
            id: 'agent3',
            state: FLState.RECEIVING,
            labType: LAB_TYPES.OPBG,
            agentType: 'doctor'
          }
        ],
        metrics: {
          accuracy: 0.85,
          loss: 0.12,
          round: 3,
          clientFraction: 0.67
        },
        connections: [
          {
            source: LAB_TYPES.MERCATORUM,
            target: LAB_TYPES.BLEKINGE,
            active: true
          },
          {
            source: LAB_TYPES.BLEKINGE,
            target: LAB_TYPES.OPBG,
            active: true
          },
          {
            source: LAB_TYPES.OPBG,
            target: LAB_TYPES.MERCATORUM,
            active: false
          }
        ]
      };
      
      // Invia l'evento allo FLController tramite il game event emitter
      console.log("Triggering initial FL state:", initialFLStatus);
      this.game.events.emit('updateFLStatus', initialFLStatus);
    } catch (error) {
      console.error("Error triggering initial FL state:", error);
    }
  }

  /**
   * Aggiorna lo stato FL con nuovi dati simulati
   */
  private updateFLState = (): void => {
    try {
      // Rimuoviamo la variabile currentState non utilizzata
      // const currentState = this.flController.getCurrentState();
      
      // Crea un nuovo stato casuale
      const states = Object.values(FLState);
      const randomState = states[Math.floor(Math.random() * states.length)];
      
      // Genera connessioni casuali
      const connections = [
        {
          source: LAB_TYPES.MERCATORUM,
          target: LAB_TYPES.BLEKINGE,
          active: Math.random() > 0.5
        },
        {
          source: LAB_TYPES.BLEKINGE,
          target: LAB_TYPES.OPBG,
          active: Math.random() > 0.5
        },
        {
          source: LAB_TYPES.OPBG,
          target: LAB_TYPES.MERCATORUM,
          active: Math.random() > 0.5
        }
      ];
      
      // Agenti attivi casuali
      const activeAgents = [];
      const agentTypes = ['researcher', 'professor', 'ml_engineer', 'doctor'];
      const labTypes = [LAB_TYPES.MERCATORUM, LAB_TYPES.BLEKINGE, LAB_TYPES.OPBG];
      
      // Genera da 2 a 5 agenti casuali
      const agentCount = 2 + Math.floor(Math.random() * 4);
      for (let i = 0; i < agentCount; i++) {
        activeAgents.push({
          id: `agent${i+1}`,
          state: states[Math.floor(Math.random() * states.length)],
          labType: labTypes[Math.floor(Math.random() * labTypes.length)],
          agentType: agentTypes[Math.floor(Math.random() * agentTypes.length)]
        });
      }
      
      // Aggiorna le metriche
      const metrics = {
        accuracy: 0.7 + Math.random() * 0.25, // Tra 0.7 e 0.95
        loss: 0.05 + Math.random() * 0.15,   // Tra 0.05 e 0.2
        round: Math.floor(Math.random() * 10) + 1,
        clientFraction: 0.3 + Math.random() * 0.6 // Tra 0.3 e 0.9
      };
      
      // Crea l'oggetto di stato FL aggiornato
      const updatedFLStatus = {
        enabled: true,
        currentState: randomState,
        activeAgents,
        metrics,
        connections
      };
      
      // Invia l'evento aggiornato
      console.log("Updating FL state:", updatedFLStatus);
      this.game.events.emit('updateFLStatus', updatedFLStatus);
    } catch (error) {
      console.error("Error updating FL state:", error);
    }
  }

  private setupDebugMode(): void {
    // Create debug graphics
    this.debugGraphics = this.add.graphics();
    
    // Add debug text
    this.debugText = this.add.text(10, 10, 'Debug Info', {
      fontSize: '14px',
      color: '#FFFFFF',
      backgroundColor: '#000000',
      padding: { x: 10, y: 5 }
    });
    this.debugText.setDepth(1000);
    
    // Inizialmente nascondi gli elementi di debug
    this.debugGraphics.setVisible(false);
    this.debugText.setVisible(false);
  }

  private updateDebugInfo(): void {
    // Count textures
    const textureCount = Object.keys(this.textures.list).length;
    
    // Update debug text
    this.debugText.setText(
      `Debug Info:\n` +
      `Resolution: ${this.cameras.main.width}x${this.cameras.main.height}\n` +
      `Textures loaded: ${textureCount}\n` +
      `Labs: ${this.labMiniatures.size}\n` +
      `FL Controller: ${this.flController ? 'Initialized' : 'Not Initialized'}`
    );
  }
  
  private toggleDebug(): void {
    this.debugMode = !this.debugMode;
    
    // Toggle debug visuals
    this.debugGraphics.setVisible(this.debugMode);
    this.debugText.setVisible(this.debugMode);
    
    // Toggle debug on lab miniatures if they have a toggleDebug method
    this.labMiniatures.forEach(miniature => {
      if (miniature.toggleDebug && typeof miniature.toggleDebug === 'function') {
        miniature.toggleDebug(this.debugMode);
      }
    });
    
    console.log(`Debug mode: ${this.debugMode ? 'ON' : 'OFF'}`);
  }

  private createLabMiniatures(): void {
    // Nuovo posizionamento dei laboratori in base al layout richiesto
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    // Parametri di posizionamento - migliorati per avere più spazio
    const topMargin = height * 0.2;
    const sideMargin = width * 0.2;
    const bottomMargin = height * 0.15; // Ridotto per abbassare ulteriormente OPBG
    
    // Debug: Draw grid points for positioning
    if (this.debugMode) {
      this.debugLabPositions(width, height, topMargin, sideMargin, bottomMargin);
    }
    
    // Nuove posizioni per rendere i laboratori più visibili
    const mercatorumX = sideMargin + 100;
    const mercatorumY = topMargin + 80;
    const blekingeX = width - sideMargin - 100;
    const blekingeY = topMargin + 80;
    const opbgX = width / 2;
    const opbgY = height - bottomMargin - 50; // Abbassato ulteriormente
    
    // Definizione dei tre oggetti LabType (oggetti completi invece di stringhe)
    const mercatorumLab: LabType = {
      id: LAB_TYPES.MERCATORUM,
      name: 'Università Mercatorum',
      location: { x: mercatorumX, y: mercatorumY }
    };
    
    const blekingeLab: LabType = {
      id: LAB_TYPES.BLEKINGE,
      name: 'Blekinge University',
      location: { x: blekingeX, y: blekingeY }
    };
    
    const opbgLab: LabType = {
      id: LAB_TYPES.OPBG,
      name: 'OPBG IRCCS',
      location: { x: opbgX, y: opbgY }
    };
    
    try {
      // Mercatorum Lab (in alto a sinistra)
      this.mercatorumMiniature = new LabMiniature(
        this, 
        mercatorumX,
        mercatorumY,
        mercatorumLab
      );
      
      // Impostiamo dimensioni più grandi per i laboratori
      this.mercatorumMiniature.setScale(1.8);
      
      // Impostiamo la proprietà targetScene
      this.mercatorumMiniature.targetScene = SCENE_KEYS.MERCATORUM;
      
      // Inizialmente nascondi le scritte di debug
      this.mercatorumMiniature.toggleDebug(this.debugMode);
      
      // Importante: aggiungi sia con l'ID che con il tipo enum per compatibilità con GlobalAgentController
      this.labMiniatures.set(LAB_TYPES.MERCATORUM, this.mercatorumMiniature);
      this.labMiniatures.set('mercatorum', this.mercatorumMiniature); // Versione lowercase per compatibilità
      
      // Blekinge Lab (in alto a destra)
      this.blekingeMiniature = new LabMiniature(
        this,
        blekingeX,
        blekingeY,
        blekingeLab
      );
      
      // Impostiamo dimensioni più grandi per i laboratori
      this.blekingeMiniature.setScale(1.8);
      
      // Impostiamo la proprietà targetScene
      this.blekingeMiniature.targetScene = SCENE_KEYS.BLEKINGE;
      
      // Inizialmente nascondi le scritte di debug
      this.blekingeMiniature.toggleDebug(this.debugMode);
      
      // Importante: aggiungi sia con l'ID che con il tipo enum per compatibilità con GlobalAgentController
      this.labMiniatures.set(LAB_TYPES.BLEKINGE, this.blekingeMiniature);
      this.labMiniatures.set('blekinge', this.blekingeMiniature); // Versione lowercase per compatibilità
      
      // OPBG Lab (in basso centro)
      this.opbgMiniature = new LabMiniature(
        this,
        opbgX,
        opbgY,
        opbgLab
      );
      
      // Impostiamo dimensioni più grandi per i laboratori
      this.opbgMiniature.setScale(1.8);
      
      // Impostiamo la proprietà targetScene
      this.opbgMiniature.targetScene = SCENE_KEYS.OPBG;
      
      // Inizialmente nascondi le scritte di debug
      this.opbgMiniature.toggleDebug(this.debugMode);
      
      // Importante: aggiungi sia con l'ID che con il tipo enum per compatibilità con GlobalAgentController
      this.labMiniatures.set(LAB_TYPES.OPBG, this.opbgMiniature);
      this.labMiniatures.set('opbg', this.opbgMiniature); // Versione lowercase per compatibilità
      
      console.log("Miniature create successfully");
      
      // Aggiungiamo un titolo per ogni lab
      this.addLabTitle(mercatorumX, mercatorumY + 100, 'Università Mercatorum', 0xE63946);
      this.addLabTitle(blekingeX, blekingeY + 100, 'Blekinge University', 0x457B9D);
      this.addLabTitle(opbgX, opbgY + 100, 'OPBG IRCCS', 0x2A9D8F);
      
      // Log delle miniature aggiunte alla mappa
      console.log("Lab miniatures map keys:", Array.from(this.labMiniatures.keys()));
      
    } catch (e) {
      console.error("Error creating miniatures:", e);
    }
    
    // Imposta l'interattività su ciascuna miniatura usando setOnClick
    this.mercatorumMiniature.setOnClick(() => {
      console.log(`Starting scene: ${this.mercatorumMiniature.targetScene}`);
      this.scene.start(this.mercatorumMiniature.targetScene);
    });
    
    this.blekingeMiniature.setOnClick(() => {
      console.log(`Starting scene: ${this.blekingeMiniature.targetScene}`);
      this.scene.start(this.blekingeMiniature.targetScene);
    });
    
    this.opbgMiniature.setOnClick(() => {
      console.log(`Starting scene: ${this.opbgMiniature.targetScene}`);
      this.scene.start(this.opbgMiniature.targetScene);
    });
    
    // Debug: Log miniature dimensions
    console.log("Lab miniature dimensions:");
    console.log(`Mercatorum: ${this.mercatorumMiniature.width}x${this.mercatorumMiniature.height}`);
    console.log(`Blekinge: ${this.blekingeMiniature.width}x${this.blekingeMiniature.height}`);
    console.log(`OPBG: ${this.opbgMiniature.width}x${this.opbgMiniature.height}`);
  }
  
  private addLabTitle(x: number, y: number, title: string, color: number): void {
    // Crea un testo con stile più visibile per i titoli dei laboratori
    const titleText = this.add.text(x, y, title, {
      fontSize: '18px',
      fontStyle: 'bold',
      color: '#FFFFFF',
      backgroundColor: Phaser.Display.Color.IntegerToColor(color).rgba,
      padding: { x: 10, y: 5 },
      shadow: { offsetX: 2, offsetY: 2, color: '#000000', blur: 2, fill: true }
    });
    titleText.setOrigin(0.5);
    
    // Rimosso l'effetto di pulsazione sui titoli come richiesto
  }
  
  private debugLabPositions(
    width: number, 
    height: number, 
    topMargin: number, 
    sideMargin: number, 
    bottomMargin: number
  ): void {
    // Draw reference points for lab positions
    this.debugGraphics.fillStyle(0xFF0000, 1);
    
    // Mercatorum position
    const mercatorumX = sideMargin + 100;
    const mercatorumY = topMargin + 80;
    this.debugGraphics.fillCircle(mercatorumX, mercatorumY, 5);
    
    // Blekinge position
    const blekingeX = width - sideMargin - 100;
    const blekingeY = topMargin + 80;
    this.debugGraphics.fillCircle(blekingeX, blekingeY, 5);
    
    // OPBG position
    const opbgX = width / 2;
    const opbgY = height - bottomMargin - 50;
    this.debugGraphics.fillCircle(opbgX, opbgY, 5);
  }

  private createLabConnections(): void {
    // Pulisci le grafiche precedenti
    this.connectionGraphics.clear();
    
    if (!this.mercatorumMiniature || !this.blekingeMiniature || !this.opbgMiniature) {
      console.warn("One or more lab miniatures are not initialized!");
      return;
    }
    
    // Ottieni le posizioni dalle miniature
    const mercatorumPos = new Phaser.Math.Vector2(
      this.mercatorumMiniature.x,
      this.mercatorumMiniature.y
    );
    
    const blekingePos = new Phaser.Math.Vector2(
      this.blekingeMiniature.x,
      this.blekingeMiniature.y
    );
    
    const opbgPos = new Phaser.Math.Vector2(
      this.opbgMiniature.x,
      this.opbgMiniature.y
    );
    
    // Debug: Log positions
    console.log("Lab positions for connections:");
    console.log(`Mercatorum: (${mercatorumPos.x}, ${mercatorumPos.y})`);
    console.log(`Blekinge: (${blekingePos.x}, ${blekingePos.y})`);
    console.log(`OPBG: (${opbgPos.x}, ${opbgPos.y})`);
    
    // Disegna le connessioni aggiornate con linee tratteggiate più visibili
    this.drawDashedLine(this.connectionGraphics, mercatorumPos.x, mercatorumPos.y, blekingePos.x, blekingePos.y, 0x2080ff, 15, 8, 3);
    this.drawDashedLine(this.connectionGraphics, blekingePos.x, blekingePos.y, opbgPos.x, opbgPos.y, 0x2080ff, 15, 8, 3);
    this.drawDashedLine(this.connectionGraphics, opbgPos.x, opbgPos.y, mercatorumPos.x, mercatorumPos.y, 0x2080ff, 15, 8, 3);
    
    // Aggiunta di icone di "data exchange" lungo le connessioni
    this.createDataExchangeVisuals(mercatorumPos, blekingePos);
    this.createDataExchangeVisuals(blekingePos, opbgPos);
    this.createDataExchangeVisuals(opbgPos, mercatorumPos);
  }

  /**
   * Disegna una linea tratteggiata tra due punti
   */
  private drawDashedLine(
    graphics: Phaser.GameObjects.Graphics,
    startX: number,
    startY: number,
    endX: number,
    endY: number,
    lineColor: number = 0x2080ff,  // Blu più chiaro
    dashSize: number = 10,
    gapSize: number = 5,
    lineWidth: number = 2          // Linea più sottile
  ): void {
    // Imposta lo stile della linea
    graphics.lineStyle(lineWidth, lineColor, 0.7);  // Ridotta l'opacità a 0.7
    
    // Calcola la lunghezza totale della linea
    const dx = endX - startX;
    const dy = endY - startY;
    const distance = Math.sqrt(dx * dx + dy * dy);
    
    // Calcola la direzione normalizzata
    const dirX = dx / distance;
    const dirY = dy / distance;
    
    // Disegna segmenti di linea tratteggiati
    let currentDist = 0;
    let drawing = true;
    
    while (currentDist < distance) {
      const segmentLength = drawing ? dashSize : gapSize;
      const nextDist = Math.min(currentDist + segmentLength, distance);
      
      const startSegX = startX + dirX * currentDist;
      const startSegY = startY + dirY * currentDist;
      const endSegX = startX + dirX * nextDist;
      const endSegY = startY + dirY * nextDist;
      
      if (drawing) {
        graphics.beginPath();
        graphics.moveTo(startSegX, startSegY);
        graphics.lineTo(endSegX, endSegY);
        graphics.strokePath();
      }
      
      currentDist = nextDist;
      drawing = !drawing;
    }
  }

  /**
   * Crea gli elementi visuali semplificati per rappresentare lo scambio di dati tra i laboratori
   */
  private createDataExchangeVisuals(start: Phaser.Math.Vector2, end: Phaser.Math.Vector2): void {
    // Calcola il punto centrale tra i due punti
    const midX = (start.x + end.x) / 2;
    const midY = (start.y + end.y) / 2;
    
    // Debug: Mark data exchange position
    if (this.debugMode) {
      this.debugGraphics.fillStyle(0xFFAA00, 1);
      this.debugGraphics.fillCircle(midX, midY, 8);
    }
    
    // Crea un simbolo semplice per rappresentare lo scambio dati
    const dataCircle = this.add.circle(midX, midY, 8, 0x3498db, 0.9);
    dataCircle.setStrokeStyle(2, 0xFFFFFF, 0.7);
    
    // Non aggiungiamo effetti particellari o animazioni complesse
    // per evitare l'effetto "fuochi d'artificio"
  }

  /**
   * Aggiunge un effetto di brillantezza alle connessioni attive
   */
  private addConnectionGlow(): void {
    if (this.connectionGraphics && this.mercatorumMiniature && this.blekingeMiniature && this.opbgMiniature) {
      // Manteniamo le connessioni statiche invece di animarle
      this.connectionGraphics.setAlpha(0.8);
    }
  }

  /**
   * Aggiorna le connessioni tra i laboratori
   */
  private updateConnections(): void {
    if (this.connectionGraphics && this.mercatorumMiniature && this.blekingeMiniature && this.opbgMiniature) {
      // Pulisci le grafiche precedenti
      this.connectionGraphics.clear();
      
      // Ottieni le posizioni aggiornate usando x e y direttamente
      const mercatorumPos = new Phaser.Math.Vector2(
        this.mercatorumMiniature.x,
        this.mercatorumMiniature.y
      );
      
      const blekingePos = new Phaser.Math.Vector2(
        this.blekingeMiniature.x,
        this.blekingeMiniature.y
      );
      
      const opbgPos = new Phaser.Math.Vector2(
        this.opbgMiniature.x,
        this.opbgMiniature.y
      );
      
      // Disegna le connessioni aggiornate
      this.drawDashedLine(this.connectionGraphics, mercatorumPos.x, mercatorumPos.y, blekingePos.x, blekingePos.y, 0x2080ff, 15, 8, 3);
      this.drawDashedLine(this.connectionGraphics, blekingePos.x, blekingePos.y, opbgPos.x, opbgPos.y, 0x2080ff, 15, 8, 3);
      this.drawDashedLine(this.connectionGraphics, opbgPos.x, opbgPos.y, mercatorumPos.x, mercatorumPos.y, 0x2080ff, 15, 8, 3);
    }
  }

  private createNavigationUI(): void {
    // Creazione dei pulsanti di navigazione in posizione più visibile
    this.navigationButtons = this.add.container(
      this.cameras.main.width - 80,
      this.cameras.main.height - 100
    );
    
    // Crea un riquadro per il menu di navigazione
    const menuBg = this.add.graphics();
    menuBg.fillStyle(0x333333, 0.8);
    // Aumentiamo l'altezza del menu per ospitare tutti i pulsanti con spazio adeguato
    menuBg.fillRoundedRect(-60, -70, 120, 180, 10); // Aumentata l'altezza da 140 a 180
    menuBg.lineStyle(2, 0x666666, 1);
    menuBg.strokeRoundedRect(-60, -70, 120, 180, 10); // Aumentata l'altezza da 140 a 180
    this.navigationButtons.add(menuBg);
    
    // Check if button textures exist
    const infoButtonExists = this.textures.exists('info-button');
    
    // Pulsante Info - ora posizionato più in alto
    if (infoButtonExists) {
      const infoButton = this.add.image(0, -50, 'info-button')
        .setInteractive()
        .on('pointerdown', () => this.toggleInfoPanel());
      infoButton.setScale(0.7);
      this.navigationButtons.add(infoButton);
    } else {
      // Crea un pulsante info testuale
      const infoButton = this.add.text(0, -50, 'info', { 
        fontSize: '16px', 
        color: '#FFFFFF',
        backgroundColor: '#3366FF',
        padding: { x: 12, y: 6 }
      }).setOrigin(0.5);
      infoButton.setInteractive();
      infoButton.on('pointerdown', () => this.toggleInfoPanel());
      this.navigationButtons.add(infoButton);
    }
    
    // Pulsante Legenda "L" - al centro
    const legendButton = this.add.text(0, -10, 'Agents', { 
      fontSize: '16px', 
      color: '#FFFFFF',
      backgroundColor: '#33AA66',
      padding: { x: 10, y: 6 }
    }).setOrigin(0.5);
    legendButton.setInteractive();
    legendButton.on('pointerdown', () => {
      if (this.agentsLegend) {
        this.agentsLegend.toggleVisibility();
      }
    });
    this.navigationButtons.add(legendButton);
    
    // Pulsante Debug - in basso
    const debugButton = this.add.text(0, 30, 'Debug', { 
      fontSize: '16px', 
      color: '#FFFFFF',
      backgroundColor: '#AA0000',
      padding: { x: 10, y: 6 }
    }).setOrigin(0.5);
    debugButton.setInteractive();
    debugButton.on('pointerdown', () => this.toggleDebug());
    this.navigationButtons.add(debugButton);
    
    // NUOVO: Pulsante FL - più in basso
    const flButton = this.add.text(0, 70, 'FL Process', { 
      fontSize: '16px', 
      color: '#FFFFFF',
      backgroundColor: '#3366CC',
      padding: { x: 10, y: 6 }
    }).setOrigin(0.5);
    flButton.setInteractive();
    flButton.on('pointerdown', () => {
      try {
        // Utilizziamo l'approccio alternativo con eventi DOM personalizzati
        // invece di affidarci solo al game registry
        const isCurrentlyVisible = getFLPanelState();
        const newVisibility = !isCurrentlyVisible;
        
        // Aggiorna lo stato nel localStorage
        updateFLPanelState(newVisibility);
        
        // Emetti l'evento personalizzato
        emitFLPanelToggle(newVisibility);
        
        // Per retrocompatibilità, aggiorniamo anche il registry e emettiamo l'evento Phaser
        try {
          this.game.registry.set('flPanelVisible', newVisibility);
          this.game.events.emit('toggleFLPanel', { visible: newVisibility });
          console.log(`FL Panel visibility changed using Phaser events: ${newVisibility}`);
        } catch (error) {
          console.warn('Error using Phaser registry or events:', error);
          // Non preoccuparti se fallisce, il meccanismo alternativo funzionerà
        }
        
        console.log(`Toggle FL Panel: ${newVisibility ? 'visible' : 'hidden'}`);
      } catch (error) {
        // Fallback assoluto: se tutto fallisce, prova ad emettere solo l'evento toggleFLPanel
        console.error("Error in FL button click handler:", error);
        try {
          this.game.events.emit('toggleFLPanel', { visible: true });
        } catch (e) {
          console.error("Even the fallback failed:", e);
        }
      }
    });
    this.navigationButtons.add(flButton);
    
    // Etichetta del menu
    const menuLabel = this.add.text(0, -85, 'Menu', {
      fontSize: '14px',
      color: '#FFFFFF',
      backgroundColor: '#000000',
      padding: { x: 8, y: 4 }
    }).setOrigin(0.5);
    this.navigationButtons.add(menuLabel);
    
    // Aggiungi un effetto di pulsazione al menu
    this.tweens.add({
      targets: menuBg,
      alpha: { from: 0.8, to: 0.6 },
      duration: 1500,
      yoyo: true,
      repeat: -1,
      ease: 'Sine.easeInOut'
    });
  }

  private createInfoPanel(): void {
    // Creazione del pannello informativo (nascosto all'inizio)
    this.infoPanel = this.add.container(
      this.cameras.main.centerX,
      this.cameras.main.centerY
    ).setVisible(false);
    
    // -------- FONDAMENTALE: UN CONTAINER INTERATTIVO PER BLOCCARE I CLICK SOTTOSTANTI --------
    // Creiamo un rettangolo abbastanza grande da coprire tutto il pannello e intercettare tutti i click
    const hitArea = this.add.rectangle(0, 0, 700, 600, 0x000000, 0);
    hitArea.setInteractive();
    hitArea.on('pointerdown', function(pointer: Phaser.Input.Pointer) {
      // Ferma la propagazione dell'evento per evitare click sui laboratori sottostanti
      pointer.event.stopPropagation();
    });
    this.infoPanel.add(hitArea);
    
    // Sfondo del pannello con bordo
    const panelBg = this.add.rectangle(0, 0, 600, 500, 0x000000, 0.9)
      .setOrigin(0.5);
    panelBg.setStrokeStyle(2, 0x444444);
    this.infoPanel.add(panelBg);
    
    // Titolo del pannello
    const title = this.add.text(0, -220, 'Federated Learning Network', {
      fontFamily: 'Arial',
      fontSize: '24px',
      fontStyle: 'bold',
      color: '#ffffff'
    }).setOrigin(0.5);
    this.infoPanel.add(title);
    
    // Descrizione generale (fuori dall'area scrollabile)
    const description = this.add.text(0, -180, 
      'This map shows the three research laboratories participating in the\n' +
      'federated learning network. Each lab specializes in different aspects\n' +
      'of privacy-preserving collaborative machine learning.', {
      fontFamily: 'Arial',
      fontSize: '14px',
      color: '#ffffff',
      align: 'center'
    }).setOrigin(0.5);
    this.infoPanel.add(description);
    
    // Area di visualizzazione scrollabile - un rettangolo con una maschera
    const scrollViewport = this.add.rectangle(0, 0, 560, 300, 0x111111, 0.5)
      .setOrigin(0.5);
    this.infoPanel.add(scrollViewport);
    
    // IMPORTANTE: Container principale per tutto il contenuto scrollabile
    const contentContainer = this.add.container(0, -120);
    
    // Creazione della maschera per l'area di scroll
    const mask = this.make.graphics({});
    mask.fillStyle(0xffffff);
    mask.fillRect(
      this.cameras.main.centerX - scrollViewport.width / 2,
      this.cameras.main.centerY - scrollViewport.height / 2,
      scrollViewport.width,
      scrollViewport.height
    );
    
    // Applica la maschera al container scrollabile
    const maskGeom = mask.createGeometryMask();
    contentContainer.setMask(maskGeom);
    
    // ----- BLOCCHI DI TESTO UNIFICATI PER OGNI LABORATORIO -----
    
    // ----- MERCATORUM (TITOLO + CONTENUTO UNIFICATI) -----
    // Creiamo un container per tenere insieme il titolo e il contenuto
    const mercatorumSection = this.add.container(0, 0);
    contentContainer.add(mercatorumSection);
    
    // Titolo Mercatorum
    const mercatorumTitle = this.add.text(0, 0, 'Università Mercatorum', {
      fontFamily: 'Arial',
      fontSize: '18px',
      fontStyle: 'bold',
      color: '#E63946', // Rosso Mercatorum
      backgroundColor: '#000000AA',
      padding: { x: 10, y: 3 }
    }).setOrigin(0.5);
    mercatorumSection.add(mercatorumTitle);
    
    // Contenuto Mercatorum
    const mercatorumContent = this.add.text(0, 20,
      'Laboratorio di ricerca specializzato in business intelligence ' +
        'e analisi finanziaria federata con tecnologie ' +
        'all\'avanguardia per la privacy dei dati finanziari.\n\n' +
      'Specializzazione FL:\n' +
      '• Business intelligence e analisi finanziaria federata\n' +
      '• Privacy-preserving analytics per dati aziendali sensibili\n' +
      '• Framework regolatori e compliance GDPR\n' +
      '• Ottimizzazione di modelli federati per previsioni di mercato\n\n', {
      //'Caratteristiche Funzionali:\n' +
      //'• Grande area centrale con tavolo per meeting collaborativi\n' +
      //'• Workstation individuali disposte lungo il perimetro\n' +
      //'• Area dedicata alla visualizzazione di dati finanziari\n' +
      //'• Piccola biblioteca con testi di economia e business intelligence', {
      fontFamily: 'Arial',
      fontSize: '14px',
      color: '#ffffff',
      align: 'left',
      lineSpacing: 5,
      wordWrap: { width: 500 }
    }).setOrigin(0.5, 0);
    mercatorumSection.add(mercatorumContent);
    
    // ----- BLEKINGE (TITOLO + CONTENUTO UNIFICATI) -----
    // Creiamo un container per Blekinge
    const blekingeSection = this.add.container(0, 220);
    contentContainer.add(blekingeSection);
    
    // Titolo Blekinge
    const blekingeTitle = this.add.text(0, 0, 'Blekinge University', {
      fontFamily: 'Arial',
      fontSize: '18px',
      fontStyle: 'bold',
      color: '#457B9D', // Blu Blekinge
      backgroundColor: '#000000AA',
      padding: { x: 10, y: 3 }
    }).setOrigin(0.5);
    blekingeSection.add(blekingeTitle);
    
    // Contenuto Blekinge
    const blekingeContent = this.add.text(0, 20,
      'Laboratorio di ricerca specializzato in tecnologie all\'avanguardia per ' + 
        'l\'ottimizzazione di algoritmi distribuiti su larga scala e ' +
        'l\'aggregazione efficiente di modelli eterogenei.\n\n' + 
      'Specializzazione FL:\n' +    
      '• Algoritmi di aggregazione avanzati (oltre FedAvg)\n' +
      '• Ottimizzazione per dispositivi IoT e edge computing\n' +
      '• Quantizzazione e compressione per ridurre comunicazione\n' +
      '• Client selection e sampling strategico\n\n', {
      //'Caratteristiche Funzionali:\n' +
      //'• Layout open space con isole di lavoro collaborative\n' +
      //'• Parete di schermi per visualizzazione algoritmi e dati\n' +
      //'• "Innovation corner" con lavagne digitali\n' +
      //'• Area relax con vista stilizzata sul Mar Baltico', {
      fontFamily: 'Arial',
      fontSize: '14px',
      color: '#ffffff',
      align: 'left',
      lineSpacing: 5,
      wordWrap: { width: 500 }
    }).setOrigin(0.5, 0);
    blekingeSection.add(blekingeContent);
    
    // ----- OPBG (TITOLO + CONTENUTO UNIFICATI) -----
    // Creiamo un container per OPBG
    const opbgSection = this.add.container(0, 440);
    contentContainer.add(opbgSection);
    
    // Titolo OPBG
    const opbgTitle = this.add.text(0, 0, 'OPBG IRCCS', {
      fontFamily: 'Arial',
      fontSize: '18px',
      fontStyle: 'bold',
      color: '#2A9D8F', // Verde OPBG
      backgroundColor: '#000000AA',
      padding: { x: 10, y: 3 }
    }).setOrigin(0.5);
    opbgSection.add(opbgTitle);
    
    // Contenuto OPBG
    const opbgContent = this.add.text(0, 20,
      'Laboratorio di ricerca specializzato in federated learning per dati ' +
        'medici pediatrici altamente sensibili. Questo ambiente ' +
        'privilegia la sicurezza dei dati facilitando la ricerca medica collaborativa.\n\n' +      
      'Specializzazione FL:\n' +
      '• Federated learning per dati medici altamente sensibili\n' +
      '• Diagnosi collaborativa preservando privacy dei pazienti\n' +
      '• Modelli personalizzati per casi pediatrici rari\n' +
      '• Integrazione di dati eterogenei (immagini, test, genetica)\n\n', {
      //'Caratteristiche Funzionali:\n' +
      //'• Area centrale sicura per dati sensibili (server room stilizzata)\n' +
      //'• Postazioni con doppi monitor per analisi medicali\n' +
      //'• Piccola area con letti ospedalieri pixelati per simulazione clinica\n' +
      //'• Bacheca con immagini stilizzate di pazienti pediatrici', {
      fontFamily: 'Arial',
      fontSize: '14px',
      color: '#ffffff',
      align: 'left',
      lineSpacing: 5,
      wordWrap: { width: 500 }
    }).setOrigin(0.5, 0);
    opbgSection.add(opbgContent);
    
    // Aggiungiamo anche una sezione finale per dare spazio sotto l'ultimo contenuto
    const bottomSpacerText = this.add.text(0, 630, ' ', {
      fontFamily: 'Arial',
      fontSize: '12px',
      color: '#555555',
      align: 'center'
    }).setOrigin(0.5);
    contentContainer.add(bottomSpacerText);
    
    // Aggiungi il contenitore principale al pannello informativo
    this.infoPanel.add(contentContainer);
    
    // ----- IMPLEMENTAZIONE AVANZATA DELLO SCROLLING -----
    // Variabili per gestire lo scrolling
    let isDragging = false;
    let lastY = 0;
    const contentHeight = 650; // Altezza totale del contenuto
    const viewportHeight = 300; // Altezza dell'area visibile
    let scrollSpeed = 0;
    
    // Aggiungi interattività all'area scrollabile
    scrollViewport.setInteractive({ useHandCursor: true });
    
    // Event listener per il pointerdown
    scrollViewport.on('pointerdown', (pointer: Phaser.Input.Pointer) => {
      isDragging = true;
      lastY = pointer.y;
      scrollSpeed = 0;
      
      // Ferma qualsiasi tween attivo
      this.tweens.killTweensOf(contentContainer);
      
      // Ferma la propagazione
      pointer.event.stopPropagation();
    });
    
    // Event listener per il pointermove
    this.input.on('pointermove', (pointer: Phaser.Input.Pointer) => {
      if (isDragging && this.infoPanel.visible) {
        // Calcola spostamento
        const deltaY = pointer.y - lastY;
        lastY = pointer.y;
        
        // Aggiorna velocità di scrolling
        scrollSpeed = deltaY * 2;
        
        // Calcola la nuova posizione
        const newY = contentContainer.y + deltaY;
        
        // Limiti di scrolling con effetto elastico
        const minY = viewportHeight / 2 - contentHeight; // Limite inferiore
        const maxY = -120; // Limite superiore
        
        if (newY > maxY) {
          // Effetto elastico quando si trascina oltre il limite superiore
          contentContainer.y = maxY + (newY - maxY) * 0.3;
        } else if (newY < minY) {
          // Effetto elastico quando si trascina oltre il limite inferiore
          contentContainer.y = minY + (newY - minY) * 0.3;
        } else {
          // Movimento normale entro i limiti
          contentContainer.y = newY;
        }
      }
    });
    
    // Event listener per il pointerup/pointerout
    const endDrag = () => {
      if (isDragging && this.infoPanel.visible) {
        isDragging = false;
        
        // Limiti di scrolling rigidi
        const minY = viewportHeight / 2 - contentHeight; // Limite inferiore
        const maxY = -120; // Limite superiore
        
        // Correzione elastica, ritorna nei limiti con una animazione se necessario
        if (contentContainer.y > maxY || contentContainer.y < minY) {
          // Determina destinazione finale
          const targetY = contentContainer.y > maxY ? maxY : minY;
          
          // Ripristina con un'animazione
          this.tweens.add({
            targets: contentContainer,
            y: targetY,
            duration: 300,
            ease: 'Back.out',
          });
        } else if (Math.abs(scrollSpeed) > 3) {
          // Inerzia dello scrolling
          const momentum = scrollSpeed * 10;
          let targetY = contentContainer.y + momentum;
          
          // Limita il target entro i confini
          targetY = Math.max(minY, Math.min(maxY, targetY));
          
          // Anima lo scrolling con inerzia
          this.tweens.add({
            targets: contentContainer,
            y: targetY,
            duration: 700,
            ease: 'Cubic.out'
          });
        }
      }
    };
    
    // Aggiungi tutti gli event listeners
    this.input.on('pointerup', endDrag);
    this.input.on('pointerout', endDrag);
    
    // Click handler che ferma la propagazione
    scrollViewport.on('pointerdown', function(pointer: Phaser.Input.Pointer) {
      pointer.event.stopPropagation();
    });
    
    // Funzione per gestire lo scrolling con la rotella del mouse
    this.input.on('wheel', (pointer: Phaser.Input.Pointer, gameObjects: any, deltaX: number, deltaY: number) => {
      if (this.infoPanel.visible) {
        // Calcola nuova posizione (moltiplica per un fattore per regolare la velocità)
        const newY = contentContainer.y - deltaY * 0.5;
        
        // Limiti di scrolling
        const minY = viewportHeight / 2 - contentHeight; // Limite inferiore 
        const maxY = -120; // Limite superiore
        
        // Applica la nuova posizione con limiti
        contentContainer.y = Phaser.Math.Clamp(newY, minY, maxY);
      }
    });
    
    // Istruzioni per lo scrolling
    const scrollInstructions = this.add.text(0, 170, 'Trascina o usa la rotellina per scorrere', {
      fontFamily: 'Arial',
      fontSize: '12px',
      fontStyle: 'italic',
      color: '#cccccc',
      backgroundColor: '#00000080',
      padding: { x: 8, y: 3 }
    }).setOrigin(0.5);
    this.infoPanel.add(scrollInstructions);
    
    // Pulsante per chiudere il pannello
    const closeButton = this.add.text(270, -220, 'X', {
      fontSize: '24px',
      color: '#FF0000',
      backgroundColor: '#000000',
      padding: { x: 10, y: 5 }
    })
    .setInteractive()
    .on('pointerdown', (pointer: Phaser.Input.Pointer) => {
      // Ferma la propagazione dell'evento
      pointer.event.stopPropagation();
      this.toggleInfoPanel();
    });
    this.infoPanel.add(closeButton);
    
    // Frecce di scroll
    const upArrow = this.add.text(270, -70, '↑', {
      fontSize: '24px',
      color: '#FFFFFF',
      backgroundColor: '#333333',
      padding: { x: 10, y: 5 }
    })
    .setInteractive({ useHandCursor: true })
    .on('pointerdown', (pointer: Phaser.Input.Pointer) => {
      // Ferma la propagazione dell'evento
      pointer.event.stopPropagation();
      
      // Scroll verso l'alto
      const currentY = contentContainer.y;
      const targetY = Math.min(currentY + 100, -120);
      
      this.tweens.add({
        targets: contentContainer,
        y: targetY,
        duration: 300,
        ease: 'Cubic.out'
      });
    });
    this.infoPanel.add(upArrow);
    
    const downArrow = this.add.text(270, 70, '↓', {
      fontSize: '24px',
      color: '#FFFFFF',
      backgroundColor: '#333333',
      padding: { x: 10, y: 5 }
    })
    .setInteractive({ useHandCursor: true })
    .on('pointerdown', (pointer: Phaser.Input.Pointer) => {
      // Ferma la propagazione dell'evento
      pointer.event.stopPropagation();
      
      // Scroll verso il basso
      const lowerLimit = viewportHeight / 2 - contentHeight; // Calcoliamo il limite inferiore
      const currentY = contentContainer.y;
      const targetY = Math.max(currentY - 100, lowerLimit);
      
      this.tweens.add({
        targets: contentContainer,
        y: targetY,
        duration: 300,
        ease: 'Cubic.out'
      });
    });
    this.infoPanel.add(downArrow);
  }


  private toggleInfoPanel(): void {
    this.infoPanel.setVisible(!this.infoPanel.visible);
  }
  
  /**
   * Crea la legenda degli agenti
   */
  private async createAgentsLegend(): Promise<void> {
    try {
      // Carica la configurazione dei tipi di agenti
      const agentTypes = await AgentsLegend.loadAgentTypesConfig(this);
      
      // Crea la legenda in alto a destra
      this.agentsLegend = new AgentsLegend(this, 20, 50, agentTypes);
      
      // Inizialmente collassa la legenda
      this.agentsLegend.collapse();
      
      // Nascondi completamente la legenda all'avvio
      // Utilizziamo il metodo hide() fornito dalla classe AgentsLegend
      this.agentsLegend.hide();
      
      // Aggiungi un pulsante per attivare/disattivare la modalità debug
      this.agentsLegend.addDebugToggleButton(() => this.toggleDebug());
      
      console.log("Agents legend created successfully and hidden");
    } catch (error) {
      console.error("Failed to create agents legend:", error);
    }
  }

  private registerEvents(): void {
    // Registrazione degli eventi per gestire la navigazione tra le scene
    this.events.on('shutdown', () => {
      try {
        // Pulizia quando la scena viene chiusa
        this.events.off('shutdown');
        
        // Rimuovi il controller degli agenti
        if (this.globalAgentController) {
          this.globalAgentController.destroy();
        }
        
        // Salva lo stato corrente del pannello FL prima di chiudere la scena
        // Usa entrambi i metodi per sicurezza
        const flPanelVisible = this.game.registry.get('flPanelVisible') || false;
        this.game.registry.set('flPanelState', {
          visible: flPanelVisible
        });
        
        // Salva anche in localStorage
        updateFLPanelState(flPanelVisible);
      } catch (error) {
        console.error("Error in shutdown event handler:", error);
      }
    });
    
    // Metodo alternativo per la navigazione
    Array.from(this.labMiniatures.values()).forEach(miniature => {
      if (miniature.on && typeof miniature.on === 'function') {
        miniature.on('pointerdown', () => {
          if (miniature.targetScene) {
            console.log(`Navigating to scene: ${miniature.targetScene}`);
            this.scene.start(miniature.targetScene);
          }
        });
      }
    });
    
    // Aggiungi listener per i controlli di simulazione dalla UI React
    this.game.events.on('controlsReady', () => {
      // Registra i link dalla UI React ai metodi della simulazione
      this.setupSimulationControls();
    });
    
    // Quando si torna alla scena, ripristina lo stato del pannello FL
    this.events.once('create', () => {
      try {
        // Prova prima a recuperare lo stato dal registry
        const flState = this.game.registry.get('flPanelState');
        if (flState) {
          this.game.registry.set('flPanelVisible', flState.visible);
          // Emetti sia l'evento Phaser che quello personalizzato
          this.game.events.emit('toggleFLPanel', { visible: flState.visible });
          emitFLPanelToggle(flState.visible);
        } else {
          // Se non c'è stato nel registry, usa localStorage
          const isVisible = getFLPanelState();
          this.game.registry.set('flPanelVisible', isVisible);
          this.game.events.emit('toggleFLPanel', { visible: isVisible });
          emitFLPanelToggle(isVisible);
        }
      } catch (error) {
        console.warn('Error restoring FL panel state from registry:', error);
        // Fallback al localStorage
        const isVisible = getFLPanelState();
        emitFLPanelToggle(isVisible);
      }
    });
  }
  
  /**
   * Metodo pubblico per ottenere le posizioni dei laboratori per gli effetti FL
   * @param labTypeId ID del tipo di laboratorio
   * @returns Vettore con la posizione del laboratorio o null se non trovato
   */
  public getLabPosition(labTypeId: LabTypeId): Phaser.Math.Vector2 | null {
    // Cerca la miniatura sia con la chiave originale che con versioni alternative
    const miniature = this.getMiniatureByLabType(labTypeId);
    
    if (miniature) {
      return new Phaser.Math.Vector2(miniature.x, miniature.y);
    }
    
    console.warn(`Lab position not found for ${labTypeId}`);
    return null;
  }
  
  /**
   * Cerca una miniatura di laboratorio con varie varianti della chiave
   */
  private getMiniatureByLabType(labTypeId: LabTypeId | string): LabMiniature | null {
    // Prova diverse varianti della chiave
    const keyVariations = [
      labTypeId,
      String(labTypeId).toLowerCase(),
      String(labTypeId).toUpperCase()
    ];
    
    for (const key of keyVariations) {
      const miniature = this.labMiniatures.get(key);
      if (miniature) {
        return miniature;
      }
    }
    
    return null;
  }
}