import Phaser from 'phaser';
import { AudioManager } from '../utils/audioManager';

interface SplashSceneInitData {
  eventEmitter: Phaser.Events.EventEmitter;
}

export class SplashScene extends Phaser.Scene {
  private eventEmitter?: Phaser.Events.EventEmitter;
  private isSkipping = false;
  private isComplete = false;
  private backgroundRect?: Phaser.GameObjects.Rectangle;
  private skipText?: Phaser.GameObjects.Text;
  private logo?: Phaser.GameObjects.Container;
  
  // Color palettes for each lab
  private readonly mercatorumColor = 0xc27c54; // terracotta
  private readonly blekingeColor = 0xadd8e6;   // ice blue
  private readonly opbgColor = 0x98d8c8;       // aqua green
  
  constructor() {
    super({ key: 'SplashScene' });
  }

  init(data: SplashSceneInitData): void {
    console.log('[SplashScene] init() iniziato');
    this.eventEmitter = data.eventEmitter;
    this.isSkipping = false;
    this.isComplete = false;
    
    // Listen for skip event
    if (this.eventEmitter) {
      this.eventEmitter.on('skipSplash', this.skipAnimation, this);
    }
  }

  preload(): void {
    console.log('[SplashScene] preload() iniziato');
    try {
      // Disabilita globalmente l'audio durante lo splash screen per evitare errori
      if (this.game.sound) {
        console.log('[SplashScene] Disabilito temporaneamente l\'audio durante lo splash');
        AudioManager.muteAudio(this);
      }
    } catch (error) {
      console.error('[SplashScene] Errore in preload:', error);
    }
  }

  create(): void {
    console.log('[SplashScene] create() iniziato');
    const { width, height } = this.game.canvas;
    const centerX = width / 2;
    const centerY = height / 2;
    
    // Add background - dark gray instead of black for better visibility
    this.backgroundRect = this.add.rectangle(centerX, centerY, width, height, 0x222222);
    
    // Add skip text
    this.skipText = this.add.text(width - 20, height - 20, 'Click anywhere to skip', {
      fontSize: '16px',
      color: '#FFFFFF'
    })
    .setOrigin(1, 1)
    .setAlpha(0.7);
    
    // Make entire scene clickable to skip
    this.input.on('pointerdown', () => {
      this.skipAnimation();
    });
    
    // Create simple logo
    this.createSimpleLogo(centerX, centerY);
    
    // Start simple animation
    this.animateLogo();
  }
  
  private createSimpleLogo(centerX: number, centerY: number): void {
    console.log('[SplashScene] Creazione logo semplificato');
    
    // Crea un container per il logo
    this.logo = this.add.container(centerX, centerY);
    
    // Dimensioni delle forme
    const size = 40;
    const margin = 10;
    
    // Crea tre rettangoli colorati per rappresentare i tre laboratori
    const mercatorumRect = this.add.rectangle(-size - margin, 0, size, size, this.mercatorumColor);
    const blekingeRect = this.add.rectangle(0, 0, size, size, this.blekingeColor);
    const opbgRect = this.add.rectangle(size + margin, 0, size, size, this.opbgColor);
    
    // Aggiungi i rettangoli al container
    if (this.logo) {
      this.logo.add([mercatorumRect, blekingeRect, opbgRect]);
      
      // Nascondi inizialmente il logo
      this.logo.setAlpha(0);
    }
  }
  
  private animateLogo(): void {
    console.log('[SplashScene] Avvio animazione logo');
    
    if (!this.logo) {
      console.error('[SplashScene] Logo non creato');
      this.completeAnimation();
      return;
    }
    
    // Fade in del logo
    this.tweens.add({
      targets: this.logo,
      alpha: 1,
      duration: 800,
      ease: 'Sine.easeOut'
    });
    
    // Pulsazione del logo
    this.tweens.add({
      targets: this.logo,
      scaleX: 1.1,
      scaleY: 1.1,
      duration: 1000,
      yoyo: true,
      repeat: 1,
      ease: 'Sine.easeInOut',
      onComplete: () => {
        // Dopo la pulsazione, aspetta un attimo e completa l'animazione
        this.time.delayedCall(500, () => {
          if (!this.isComplete) {
            this.completeAnimation();
          }
        });
      }
    });
  }
  
  private skipAnimation(): void {
    console.log('[SplashScene] skipAnimation chiamato');
    if (this.isSkipping || this.isComplete) return;
    this.isSkipping = true;
    
    this.completeAnimation();
  }
  
  private completeAnimation(): void {
    console.log('[SplashScene] completeAnimation chiamato');
    if (this.isComplete) return;
    this.isComplete = true;
    
    // Crea un array di oggetti per il fade out
    const targets: any[] = [];
    
    // Aggiungi gli elementi se esistono
    if (this.backgroundRect) targets.push(this.backgroundRect);
    if (this.logo) targets.push(this.logo);
    if (this.skipText) targets.push(this.skipText);
    
    this.tweens.add({
      targets: targets,
      alpha: 0,
      duration: 300,
      onComplete: () => {
        console.log('[SplashScene] Animazione completata, emetto evento splashComplete');
        if (this.eventEmitter) {
          this.eventEmitter.emit('splashComplete');
        }
      }
    });
  }
  
  shutdown(): void {
    console.log('[SplashScene] shutdown chiamato');
    // Cleanup quando la scena viene fermata
    
    // Pulisci gli eventi e le risorse
    if (this.eventEmitter) {
      this.eventEmitter.off('skipSplash', this.skipAnimation, this);
    }
  }
}