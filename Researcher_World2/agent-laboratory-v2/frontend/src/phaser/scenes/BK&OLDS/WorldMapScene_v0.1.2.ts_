import Phaser from 'phaser';
import { BaseScene } from './BaseScene';
import { LabMiniature } from '../entities/LabMiniature';
import { GlobalAgentController } from '../controllers/GlobalAgentController';
import { SCENE_KEYS } from '../game';

export class WorldMapScene extends BaseScene {
  private labMiniatures: Map<string, LabMiniature> = new Map();
  // Inizializzazione delle proprietà per risolvere gli errori TS2564
  private globalAgentController!: GlobalAgentController;
  private navigationButtons!: Phaser.GameObjects.Container;
  private infoPanel!: Phaser.GameObjects.Container;
  private connectionGraphics!: Phaser.GameObjects.Graphics;
  private mercatorumMiniature!: LabMiniature;
  private blekingeMiniature!: LabMiniature;
  private opbgMiniature!: LabMiniature;

  constructor() {
    super('WorldMapScene');
  }

  init(): void {
    this.cameras.main.setBackgroundColor('#1a1a2e');
  }

  preload(): void {
    // Precaricare assets specifici della mappa mondiale
    this.load.image('world-map-background', 'assets/ui/world-map-background.png');
    this.load.image('lab-connection', 'assets/ui/lab-connection-line.png');
    this.load.image('data-exchange-icon', 'assets/ui/data-exchange-icon.png');
    this.load.image('agent-dot', 'assets/ui/agent-dot.png');
    
    // Pulsanti UI
    this.load.image('info-button', 'assets/ui/info-button.png');
    this.load.image('settings-button', 'assets/ui/settings-button.png');
    this.load.image('close-button', 'assets/ui/close-button.png');
  }

  create(): void {
    // Creazione dello sfondo della mappa mondiale
    this.add.image(this.cameras.main.centerX, this.cameras.main.centerY, 'world-map-background')
      .setOrigin(0.5)
      .setDisplaySize(this.cameras.main.width, this.cameras.main.height);
    
    // Creazione delle grafiche per le connessioni
    this.connectionGraphics = this.add.graphics();
    
    // Posizionamento delle miniature dei laboratori
    this.createLabMiniatures();
    
    // Creazione delle connessioni tra laboratori
    this.createLabConnections();
    
    // Inizializzazione del controller degli agenti globali
    this.globalAgentController = new GlobalAgentController(this);
    this.globalAgentController.initialize();
    
    // Creazione dei pulsanti di navigazione
    this.createNavigationUI();
    
    // Creazione del pannello informativo
    this.createInfoPanel();
    
    // Registrazione degli eventi
    this.registerEvents();
    
    // Aggiungi effetti alle connessioni
    this.addConnectionGlow();
  }

  update(time: number, delta: number): void {
    // Aggiorna le connessioni per mantenerle fluide
    this.updateConnections();
    
    // Correzione dell'errore TS2802 usando Array.from
    Array.from(this.labMiniatures.values()).forEach(miniature => {
      if (typeof miniature.update === 'function') {
        miniature.update(time, delta);
      }
    });
    
    // Aggiornamento degli agenti sulla mappa
    if (this.globalAgentController) {
      this.globalAgentController.update(time, delta);
    }
  }

  private createLabMiniatures(): void {
    // Nuovo posizionamento dei laboratori in base al layout richiesto
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    // Parametri di posizionamento
    const topMargin = height * 0.15;
    const sideMargin = width * 0.15;
    const bottomMargin = height * 0.2;
    
    // Mercatorum Lab (in alto a sinistra)
    this.mercatorumMiniature = new LabMiniature(
      this,
      sideMargin + 50,       // Spostata più a sinistra per far spazio alla dimensione maggiore
      topMargin + 50,        // Spostata più in alto
      'mercatorum-miniature',
      'Università Mercatorum',
      SCENE_KEYS.MERCATORUM
    );
    this.labMiniatures.set('mercatorum', this.mercatorumMiniature);
    
    // Blekinge Lab (in alto a destra)
    this.blekingeMiniature = new LabMiniature(
      this,
      width - sideMargin - 350,  // Spostata più a sinistra per far spazio alla dimensione maggiore
      topMargin + 50,            // Spostata più in alto
      'blekinge-miniature',
      'Blekinge University',
      SCENE_KEYS.BLEKINGE
    );
    this.labMiniatures.set('blekinge', this.blekingeMiniature);
    
    // OPBG Lab (in basso centro)
    this.opbgMiniature = new LabMiniature(
      this,
      width / 2 - 150,            // Centrata orizzontalmente
      height - bottomMargin - 250, // Spostata più in alto dal fondo
      'opbg-miniature',
      'OPBG IRCCS',
      SCENE_KEYS.OPBG
    );
    this.labMiniatures.set('opbg', this.opbgMiniature);
    
    // Imposta l'interattività su ciascuna miniatura
    this.mercatorumMiniature.setInteractive(() => {
      this.scene.start(SCENE_KEYS.MERCATORUM);
    });
    
    this.blekingeMiniature.setInteractive(() => {
      this.scene.start(SCENE_KEYS.BLEKINGE);
    });
    
    this.opbgMiniature.setInteractive(() => {
      this.scene.start(SCENE_KEYS.OPBG);
    });
  }

  private createLabConnections(): void {
    // Pulisci le grafiche precedenti
    this.connectionGraphics.clear();
    
    // Ottieni le posizioni aggiornate
    const mercatorumPos = this.mercatorumMiniature.getPosition();
    const blekingePos = this.blekingeMiniature.getPosition();
    const opbgPos = this.opbgMiniature.getPosition();
    
    // Disegna le connessioni aggiornate con linee tratteggiate
    this.drawDashedLine(this.connectionGraphics, mercatorumPos.x, mercatorumPos.y, blekingePos.x, blekingePos.y);
    this.drawDashedLine(this.connectionGraphics, blekingePos.x, blekingePos.y, opbgPos.x, opbgPos.y);
    this.drawDashedLine(this.connectionGraphics, opbgPos.x, opbgPos.y, mercatorumPos.x, mercatorumPos.y);
    
    // Aggiunta di icone di "data exchange" lungo le connessioni
    this.createDataExchangeVisuals(mercatorumPos, blekingePos);
    this.createDataExchangeVisuals(blekingePos, opbgPos);
    this.createDataExchangeVisuals(opbgPos, mercatorumPos);
  }

  /**
   * Disegna una linea tratteggiata tra due punti
   */
  private drawDashedLine(
    graphics: Phaser.GameObjects.Graphics,
    startX: number,
    startY: number,
    endX: number,
    endY: number,
    lineColor: number = 0x2080ff,  // Blu più chiaro
    dashSize: number = 10,
    gapSize: number = 5,
    lineWidth: number = 2          // Linea più sottile
  ): void {
    // Imposta lo stile della linea
    graphics.lineStyle(lineWidth, lineColor, 0.7);  // Ridotta l'opacità a 0.7
    
    // Calcola la lunghezza totale della linea
    const dx = endX - startX;
    const dy = endY - startY;
    const distance = Math.sqrt(dx * dx + dy * dy);
    
    // Calcola la direzione normalizzata
    const dirX = dx / distance;
    const dirY = dy / distance;
    
    // Disegna segmenti di linea tratteggiati
    let currentDist = 0;
    let drawing = true;
    
    while (currentDist < distance) {
      const segmentLength = drawing ? dashSize : gapSize;
      const nextDist = Math.min(currentDist + segmentLength, distance);
      
      const startSegX = startX + dirX * currentDist;
      const startSegY = startY + dirY * currentDist;
      const endSegX = startX + dirX * nextDist;
      const endSegY = startY + dirY * nextDist;
      
      if (drawing) {
        graphics.beginPath();
        graphics.moveTo(startSegX, startSegY);
        graphics.lineTo(endSegX, endSegY);
        graphics.strokePath();
      }
      
      currentDist = nextDist;
      drawing = !drawing;
    }
  }

  /**
   * Crea gli elementi visuali per rappresentare lo scambio di dati tra i laboratori
   */
  private createDataExchangeVisuals(start: Phaser.Math.Vector2, end: Phaser.Math.Vector2): void {
    // Calcola il punto centrale tra i due punti
    const midX = (start.x + end.x) / 2;
    const midY = (start.y + end.y) / 2;
    
    // Crea un elemento visivo di scambio dati nel punto centrale
    // Usa uno sprite invece di un rettangolo colorato
    const dataExchange = this.add.sprite(midX, midY, 'data-exchange-icon');
    
    // Imposta scala e opacità per renderlo meno invasivo
    dataExchange.setScale(0.5);
    dataExchange.setAlpha(0.7);
    
    // Aggiungi un effetto di pulsazione per dare l'idea di scambio dati attivo
    this.tweens.add({
      targets: dataExchange,
      alpha: { from: 0.7, to: 0.4 },
      duration: 1000,
      ease: 'Sine.easeInOut',
      yoyo: true,
      repeat: -1
    });
  }

  /**
   * Aggiunge un effetto di brillantezza alle connessioni attive
   */
  private addConnectionGlow(): void {
    if (this.connectionGraphics && this.mercatorumMiniature && this.blekingeMiniature && this.opbgMiniature) {
      // Aggiungi un leggero effetto pulsante alle connessioni
      this.tweens.add({
        targets: this.connectionGraphics,
        alpha: { from: 0.7, to: 0.4 },
        duration: 3000,
        ease: 'Sine.easeInOut',
        yoyo: true,
        repeat: -1
      });
    }
  }

  /**
   * Aggiorna le connessioni tra i laboratori
   */
  private updateConnections(): void {
    if (this.connectionGraphics && this.mercatorumMiniature && this.blekingeMiniature && this.opbgMiniature) {
      // Pulisci le grafiche precedenti
      this.connectionGraphics.clear();
      
      // Ottieni le posizioni aggiornate
      const mercatorumPos = this.mercatorumMiniature.getPosition();
      const blekingePos = this.blekingeMiniature.getPosition();
      const opbgPos = this.opbgMiniature.getPosition();
      
      // Disegna le connessioni aggiornate
      this.drawDashedLine(this.connectionGraphics, mercatorumPos.x, mercatorumPos.y, blekingePos.x, blekingePos.y);
      this.drawDashedLine(this.connectionGraphics, blekingePos.x, blekingePos.y, opbgPos.x, opbgPos.y);
      this.drawDashedLine(this.connectionGraphics, opbgPos.x, opbgPos.y, mercatorumPos.x, mercatorumPos.y);
    }
  }

  private createNavigationUI(): void {
    // Creazione dei pulsanti di navigazione (zoom in/out, settings, etc.)
    this.navigationButtons = this.add.container(
      this.cameras.main.width - 50,
      this.cameras.main.height - 150
    );
    
    // Pulsante Info
    const infoButton = this.add.image(0, 0, 'info-button')
      .setInteractive()
      .on('pointerdown', () => this.toggleInfoPanel());
    
    // Pulsante Settings
    const settingsButton = this.add.image(0, 50, 'settings-button')
      .setInteractive()
      .on('pointerdown', () => console.log('Settings clicked'));
    
    this.navigationButtons.add([infoButton, settingsButton]);
  }

  private createInfoPanel(): void {
    // Creazione del pannello informativo (nascosto all'inizio)
    this.infoPanel = this.add.container(
      this.cameras.main.centerX,
      this.cameras.main.centerY
    ).setVisible(false);
    
    // Sfondo del pannello
    const panelBg = this.add.rectangle(0, 0, 500, 400, 0x000000, 0.8)
      .setOrigin(0.5);
    
    // Titolo del pannello
    const title = this.add.text(0, -150, 'Federated Learning Network', {
      fontFamily: 'Arial',
      fontSize: '24px',
      color: '#ffffff'
    }).setOrigin(0.5);
    
    // Descrizione
    const description = this.add.text(0, -80, 
      'This map shows the three research laboratories participating in the\n' +
      'federated learning network. Each lab specializes in different aspects\n' +
      'of privacy-preserving collaborative machine learning.', {
      fontFamily: 'Arial',
      fontSize: '16px',
      color: '#ffffff',
      align: 'center'
    }).setOrigin(0.5);
    
    // Pulsante di chiusura
    const closeButton = this.add.image(220, -170, 'close-button')
      .setScale(0.5)
      .setInteractive()
      .on('pointerdown', () => this.toggleInfoPanel());
    
    this.infoPanel.add([panelBg, title, description, closeButton]);
  }

  private toggleInfoPanel(): void {
    this.infoPanel.setVisible(!this.infoPanel.visible);
  }

  private registerEvents(): void {
    // Registrazione degli eventi per gestire la navigazione tra le scene
    this.events.on('shutdown', () => {
      // Pulizia quando la scena viene chiusa
      this.events.off('shutdown');
      
      // Rimuovi il controller degli agenti
      if (this.globalAgentController) {
        this.globalAgentController.destroy();
      }
    });
    
    // Correzione dell'errore TS2802 usando Array.from
    Array.from(this.labMiniatures.values()).forEach(miniature => {
      if (miniature.on && typeof miniature.on === 'function') {
        miniature.on('labSelected', (targetScene: string) => {
          if (this.scene.manager && typeof this.scene.manager.start === 'function') {
            // Usa il game instance per navigare correttamente
            const game = this.game as any;
            if (game.startLabScene && typeof game.startLabScene === 'function') {
              game.startLabScene(targetScene);
            } else {
              console.log(`Starting scene: ${targetScene} (fallback method)`);
              this.scene.start(targetScene);
            }
          }
        });
      }
    });
  }
}