import { BaseLabScene, LabTheme } from './BaseLabScene';
import { Agent } from '../sprites/Agent';
import { ResearcherAgent } from '../sprites/ResearcherAgent';
import { MedicalResearcher } from '../sprites/MedicalResearcher';
import { ResearcherType, MedicalResearcherType, MedicalSpecialization } from '../../types/AgentTypes';

export class OPBGLabScene extends BaseLabScene {
  // Tema specifico per il laboratorio OPBG
  protected labTheme: LabTheme = {
    name: 'OPBG Lab',
    primaryColor: 0x00b8d4,
    secondaryColor: 0xffb6c1,
    floorColor: 0xf0f0f0,
    wallColor: 0xdeeaee,
    accentColor: 0x5bc8ac
  };
  
  // Array di ricercatori medici
  private medicalResearchers: MedicalResearcher[] = [];
  
  constructor() {
    super('OPBGLabScene');
  }
  
  preload(): void {
    super.preload();
    
    // Carica asset specifici per OPBG
    this.load.image('opbg-logo', 'assets/images/opbg-logo.png');
    this.load.image('medical-icon', 'assets/images/medical-icon.png');
    this.load.image('hospital-bed', 'assets/images/hospital-bed.png');
    this.load.image('medical-equipment', 'assets/images/medical-equipment.png');
    
    // Spritesheet per ricercatori OPBG
    this.load.spritesheet('researcher-opbg', 
      'assets/sprites/researcher-opbg.png',
      { frameWidth: 16, frameHeight: 24 }
    );
    
    // Spritesheet per medici
    this.load.spritesheet('doctor', 
      'assets/sprites/doctor.png',
      { frameWidth: 16, frameHeight: 24 }
    );
    
    // Spritesheet per ingegneri biomedici
    this.load.spritesheet('biomedical-engineer', 
      'assets/sprites/biomedical-engineer.png',
      { frameWidth: 16, frameHeight: 24 }
    );
  }
  
  create(): void {
    // Inizializza la scena base
    super.create();
    
    // Crea l'ambiente specifico OPBG
    this.createOPBGEnvironment();
    
    // Aggiungi ricercatori e staff medico
    this.createMedicalStaff();
  }
  
  /**
   * Crea l'ambiente specifico del laboratorio OPBG
   */
  private createOPBGEnvironment(): void {
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    // Aggiungi logo OPBG
    const logo = this.add.image(width - 60, 40, 'opbg-logo');
    logo.setScale(0.5);
    
    // Crea l'area server protetta (rappresenta dati sensibili)
    const serverArea = this.add.rectangle(
      width / 2,
      height / 2 - 50,
      120,
      80,
      this.labTheme.primaryColor,
      0.2
    );
    
    // Aggiungi confini visivi all'area server
    const serverBorder = this.add.graphics();
    serverBorder.lineStyle(2, this.labTheme.primaryColor, 1);
    serverBorder.strokeRect(
      width / 2 - 60,
      height / 2 - 90,
      120,
      80
    );
    
    // Etichetta area server
    const serverLabel = this.add.text(
      width / 2,
      height / 2 - 100,
      'Secure Data Area',
      { fontSize: '10px', color: '#000000' }
    );
    serverLabel.setOrigin(0.5);
    
    // Crea postazioni di lavoro mediche
    this.createMedicalWorkstations();
    
    // Crea area clinica simulata
    this.createClinicalArea();
  }
  
  /**
   * Crea postazioni di lavoro specifiche per medici e ricercatori medici
   */
  private createMedicalWorkstations(): void {
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    // Crea postazioni con doppi monitor per analisi medicali
    for (let i = 0; i < 3; i++) {
      // Posizione della postazione
      const x = 100 + i * 150;
      const y = height - 100;
      
      // Crea la scrivania
      const desk = this.add.rectangle(x, y, 100, 40, this.labTheme.secondaryColor);
      
      // Crea monitor doppi
      const monitor1 = this.add.rectangle(x - 20, y - 30, 30, 25, 0x333333);
      const monitor2 = this.add.rectangle(x + 20, y - 30, 30, 25, 0x333333);
      
      // Schermi dei monitor
      const screen1 = this.add.rectangle(x - 20, y - 30, 26, 21, 0x88ccff);
      const screen2 = this.add.rectangle(x + 20, y - 30, 26, 21, 0x88ccff);
      
      // Interazione: al clic sui monitor, mostra un messaggio informativo
      monitor1.setInteractive();
      monitor2.setInteractive();
      
      monitor1.on('pointerdown', () => {
        this.showInfoPopup(x - 20, y - 60, 'Medical Analysis Station');
      });
      
      monitor2.on('pointerdown', () => {
        this.showInfoPopup(x + 20, y - 60, 'Patient Data Viewer');
      });
    }
  }
  
  /**
   * Crea un'area clinica simulata per test
   */
  private createClinicalArea(): void {
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    // Area clinica nella parte destra della scena
    const clinicalArea = this.add.rectangle(
      width - 150,
      height / 2 + 50,
      200,
      150,
      this.labTheme.secondaryColor,
      0.2
    );
    
    // Bordo area clinica
    const clinicalBorder = this.add.graphics();
    clinicalBorder.lineStyle(2, this.labTheme.secondaryColor, 1);
    clinicalBorder.strokeRect(
      width - 250,
      height / 2 - 25,
      200,
      150
    );
    
    // Letti ospedalieri pixelati per simulazione
    for (let i = 0; i < 3; i++) {
      const bed = this.add.image(
        width - 220 + i * 60, 
        height / 2 + 50,
        'hospital-bed'
      );
      bed.setScale(0.8);
    }
    
    // Etichetta area clinica
    const clinicalLabel = this.add.text(
      width - 150,
      height / 2 - 35,
      'Clinical Simulation Area',
      { fontSize: '10px', color: '#000000' }
    );
    clinicalLabel.setOrigin(0.5);
    
    // Icona medica sopra l'area
    const medicalIcon = this.add.image(clinicalArea.x, clinicalArea.y - 20, 'medical-icon');
    medicalIcon.setScale(0.6);
  }
  
  /**
   * Crea ricercatori e personale medico
   */
  private createMedicalStaff(): void {
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    // Definizioni dei tipi di ricercatori normali
    const researcherTypes: { type: ResearcherType, specialization: string }[] = [
      { type: 'phd-student', specialization: 'data-science' },
      { type: 'data-engineer', specialization: 'data-pipeline' },
      { type: 'privacy-specialist', specialization: 'differential-privacy' },
    ];
    
    // Definizioni dei tipi di ricercatori medici
    const medicalTypes: { type: MedicalResearcherType, specialization: MedicalSpecialization }[] = [
      { type: 'medical-doctor', specialization: 'clinical-data' },
      { type: 'medical-doctor', specialization: 'diagnostic-models' },
      { type: 'biomedical-engineer', specialization: 'medical-imaging' },
      { type: 'biomedical-engineer', specialization: 'biosignal-processing' }
    ];
    
    // Crea alcuni ricercatori normali
    for (let i = 0; i < 5; i++) {
      // Posizione casuale
      const pos = this.getRandomPosition();
      
      // Scegli un tipo casuale
      const type = Phaser.Utils.Array.GetRandom(researcherTypes);
      
      // Crea il ricercatore
      const researcher = new ResearcherAgent(
        this,
        pos.x,
        pos.y,
        'researcher-opbg',
        type.type,
        type.specialization as any
      );
      
      // Aggiungi al gruppo di agenti
      this.agents.push(researcher);
    }
    
    // Crea ricercatori medici
    for (let i = 0; i < 4; i++) {
      // Posizione casuale
      const pos = this.getRandomPosition();
      
      // Scegli un tipo casuale
      const type = Phaser.Utils.Array.GetRandom(medicalTypes);
      
      // Scegli la texture appropriata
      const texture = type.type === 'medical-doctor' ? 'doctor' : 'biomedical-engineer';
      
      // Crea il ricercatore medico
      const medicalResearcher = new MedicalResearcher(
        this,
        pos.x,
        pos.y,
        texture,
        type.type,
        type.specialization
      );
      
      // Aggiungi al gruppo di agenti e all'array specifico
      this.agents.push(medicalResearcher);
      this.medicalResearchers.push(medicalResearcher);
    }
  }
  
  /**
   * Mostra un popup informativo temporaneo
   */
  private showInfoPopup(x: number, y: number, text: string): void {
    // Crea il testo del popup
    const popup = this.add.text(x, y, text, {
      fontSize: '12px',
      backgroundColor: '#ffffff',
      padding: { x: 5, y: 3 },
      color: '#000000'
    });
    popup.setOrigin(0.5);
    
    // Crea una timeline per animare il popup
    this.tweens.add({
      targets: popup,
      y: y - 20,
      alpha: { from: 1, to: 0 },
      duration: 2000,
      ease: 'Power2',
      onComplete: () => {
        popup.destroy();
      }
    });
  }
  
  /**
   * Ottieni una posizione casuale valida all'interno della scena
   */
  private getRandomPosition(): { x: number, y: number } {
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    return {
      x: Phaser.Math.Between(50, width - 50),
      y: Phaser.Math.Between(50, height - 50)
    };
  }
  
  update(time: number, delta: number): void {
    super.update(time, delta);
    
    // Aggiornamenti specifici per il laboratorio OPBG
    // ...
  }
}