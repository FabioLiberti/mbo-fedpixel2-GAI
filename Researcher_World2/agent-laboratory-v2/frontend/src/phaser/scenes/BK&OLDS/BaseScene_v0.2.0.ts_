// frontend/src/phaser/scenes/BaseScene.ts

import { Scene } from 'phaser';
import { AssetLoader, createAssetLoader } from '../loader';
import { ASSETS, verifyAssets } from '../assetConfig';

/**
 * Classe base per tutte le scene di laboratorio
 * Gestisce funzionalità comuni come caricamento asset, animazioni, ecc.
 */
export class BaseScene extends Scene {
  protected assetLoader!: AssetLoader; // Il '!' indica a TypeScript che sarà sicuramente inizializzato dopo la costruzione
  protected assetsLoaded: boolean = false;
  protected animationsCreated: boolean = false;

  constructor(key: string) {
    super(key);
  }

  init(): void {
    // Inizializza il loader di asset
    this.assetLoader = createAssetLoader(this);
    
    // Verifica configurazione asset in fase di sviluppo
    if (process.env.NODE_ENV === 'development') {
      verifyAssets();
    }
    
    this.assetsLoaded = false;
    this.animationsCreated = false;
    
    // Gestione errori di caricamento
    this.load.on('loaderror', (fileObj: any) => {
      console.error(`Error loading asset: ${fileObj.key} (${fileObj.type})`);
      
      // Gestione specifica per tipo di errore
      if (fileObj.type === 'spritesheet') {
        // Carica un placeholder per sprite mancanti
        this.assetLoader.loadPlaceholder(fileObj.key, 'spritesheet', 32, 48);
      } else if (fileObj.type === 'image') {
        // Carica un placeholder per immagini mancanti
        this.assetLoader.loadPlaceholder(fileObj.key, 'image');
      }
    });
    
    // Completamento caricamento
    this.load.on('complete', () => {
      this.assetsLoaded = true;
      console.log(`[${this.scene.key}] Assets loaded successfully`);
    });
  }

  /**
   * Carica asset di base comuni a tutte le scene
   */
  preload(): void {
    // Tentativo di debug del path degli asset
    console.log(`[${this.scene.key}] Loading assets from base path:`, ASSETS.ui.placeholder);
    
    // Carica tileset base
    this.assetLoader.loadImage('tiles', ASSETS.tilesets.main);
    
    // Carica placeholder per debug
    this.assetLoader.loadImage('placeholder', ASSETS.ui.placeholder);
    
    // Carica spritesheets personaggi
    Object.entries(ASSETS.characters).forEach(([key, char]) => {
      this.assetLoader.loadSpritesheet(key, char.path, char.config);
    });
  }

  /**
   * Crea animazioni per tutti i personaggi
   */
  protected createAnimations(): void {
    if (this.animationsCreated) return;
    
    try {
      // Animazioni per professore
      if (this.textures.exists('professor')) {
        this.anims.create({
          key: ASSETS.animations.professor.idle.key,
          frames: this.anims.generateFrameNumbers('professor', 
            { start: ASSETS.animations.professor.idle.frames.start, end: ASSETS.animations.professor.idle.frames.end }),
          frameRate: ASSETS.animations.professor.idle.frameRate,
          repeat: ASSETS.animations.professor.idle.repeat
        });
        
        this.anims.create({
          key: ASSETS.animations.professor.walk.key,
          frames: this.anims.generateFrameNumbers('professor', 
            { start: ASSETS.animations.professor.walk.frames.start, end: ASSETS.animations.professor.walk.frames.end }),
          frameRate: ASSETS.animations.professor.walk.frameRate,
          repeat: ASSETS.animations.professor.walk.repeat
        });
      } else {
        console.warn('Professor texture not available for animations');
      }
      
      // Animazioni per ricercatore
      if (this.textures.exists('researcher')) {
        this.anims.create({
          key: ASSETS.animations.researcher.idle.key,
          frames: this.anims.generateFrameNumbers('researcher', 
            { start: ASSETS.animations.researcher.idle.frames.start, end: ASSETS.animations.researcher.idle.frames.end }),
          frameRate: ASSETS.animations.researcher.idle.frameRate,
          repeat: ASSETS.animations.researcher.idle.repeat
        });
        
        this.anims.create({
          key: ASSETS.animations.researcher.walk.key,
          frames: this.anims.generateFrameNumbers('researcher', 
            { start: ASSETS.animations.researcher.walk.frames.start, end: ASSETS.animations.researcher.walk.frames.end }),
          frameRate: ASSETS.animations.researcher.walk.frameRate,
          repeat: ASSETS.animations.researcher.walk.repeat
        });
      } else {
        console.warn('Researcher texture not available for animations');
      }
      
      this.animationsCreated = true;
      console.log(`[${this.scene.key}] Animations created successfully`);
    } catch (error) {
      console.error('Error creating animations:', error);
    }
  }

  /**
   * Gestisce la creazione del tilemap
   * Da implementare nelle classi derivate
   */
  protected createTilemap(): Phaser.Tilemaps.Tilemap | null {
    // Implementazione di base vuota, da sovrascrivere nelle scene specifiche
    return null;
  }
  
  /**
   * Utility per verificare se tutti gli asset richiesti sono stati caricati
   */
  protected verifyRequiredAssets(requiredAssets: string[]): boolean {
    const missingAssets = requiredAssets.filter(asset => !this.textures.exists(asset));
    
    if (missingAssets.length > 0) {
      console.warn(`[${this.scene.key}] Missing required assets:`, missingAssets);
      return false;
    }
    
    return true;
  }
  
  /**
   * Utility per creare placeholder per asset mancanti
   */
  protected createPlaceholdersForMissingAssets(requiredAssets: string[]): void {
    requiredAssets.forEach(asset => {
      if (!this.textures.exists(asset)) {
        this.assetLoader.loadPlaceholder(asset, 'image');
      }
    });
  }
}