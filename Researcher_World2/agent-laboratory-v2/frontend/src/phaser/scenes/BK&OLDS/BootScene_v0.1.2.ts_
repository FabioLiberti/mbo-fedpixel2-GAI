import * as Phaser from 'phaser';
import { BaseScene } from './BaseScene';
import { SCENE_KEYS } from '../game';

/**
 * BootScene è la prima scena che viene caricata ed è responsabile del 
 * pre-caricamento delle risorse essenziali prima di passare alla scena principale.
 */
export class BootScene extends BaseScene {
  // Flag di debug
  private debugMode: boolean = true;
  private debugText!: Phaser.GameObjects.Text;
  private preloadComplete: boolean = false;
  private assetsLoaded: string[] = [];
  private assetErrors: string[] = [];

  constructor() {
    super('BootScene');
  }

  preload(): void {
    console.log('BootScene: Preloading assets...');
    
    // Configurazione eventi di preload per debugging
    this.setupPreloadDebug();

    // Caricamento assets UI base
    this.loadUIAssets();
    
    // Caricamento miniature laboratori
    this.loadLabMiniatures();
    
    // Caricamento sprite base per agenti
    this.loadAgentSprites();
    
    // Caricamento texture per connessioni della mappa
    this.loadMapAssets();
  }

  create(): void {
    console.log('BootScene: Create phase started');
    
    // Aggiorna stato debug
    if (this.debugMode && this.debugText) {
      this.debugText.setText(
        `BootScene: Assets loaded\n` +
        `Total assets: ${this.assetsLoaded.length}\n` +
        `Errors: ${this.assetErrors.length}\n` +
        `Starting WorldMapScene...`
      );
    }
    
    // Simulazione di un breve ritardo prima di passare alla scena principale
    // Questo può essere utile per mostrare schermate di caricamento o loghi
    this.time.delayedCall(1000, () => {
      console.log('BootScene: Transitioning to WorldMapScene');
      this.scene.start(SCENE_KEYS.WORLD_MAP);
    });
  }

  private setupPreloadDebug(): void {
    // Creazione testo di debug
    if (this.debugMode) {
      this.debugText = this.add.text(10, 10, 'Loading assets...', {
        fontSize: '18px',
        color: '#ffffff',
        backgroundColor: '#000000',
        padding: { x: 10, y: 5 }
      });
      this.debugText.setDepth(100);
      
      // Mostra una progress bar per il preload
      const progressBar = this.add.graphics();
      const progressBox = this.add.graphics();
      progressBox.fillStyle(0x222222, 0.8);
      progressBox.fillRect(240, 270, 320, 50);
      
      // Aggiungi eventi di progresso
      this.load.on('progress', (value: number) => {
        progressBar.clear();
        progressBar.fillStyle(0xffffff, 1);
        progressBar.fillRect(250, 280, 300 * value, 30);
        
        if (this.debugText) {
          this.debugText.setText(
            `Loading: ${Math.floor(value * 100)}%\n` +
            `Assets loaded: ${this.assetsLoaded.length}\n` +
            `Errors: ${this.assetErrors.length}`
          );
        }
      });
      
      // Registra gli asset caricati
      this.load.on('filecomplete', (key: string) => {
        this.assetsLoaded.push(key);
        console.log(`Asset loaded: ${key}`);
      });
      
      // Registra errori di caricamento
      this.load.on('loaderror', (file: Phaser.Loader.File) => {
        this.assetErrors.push(file.key as string);
        console.error(`Error loading asset: ${file.key}`, file);
      });
      
      // Pulizia alla fine
      this.load.on('complete', () => {
        progressBar.destroy();
        progressBox.destroy();
        this.preloadComplete = true;
        
        console.log('Preload complete:', {
          loaded: this.assetsLoaded,
          errors: this.assetErrors
        });
      });
    }
  }

  private loadUIAssets(): void {
    // UI elements
    this.load.image('logo', 'assets/ui/placeholder.png');
    this.load.image('info-button', 'assets/ui/placeholder.png');
    this.load.image('settings-button', 'assets/ui/placeholder.png');
    this.load.image('close-button', 'assets/ui/placeholder.png');
    
    // Background per la mappa mondiale
    this.load.image('world-map-background', 'assets/ui/world-map-background.png');
    
    // Icone generiche
    this.load.image('data-exchange-icon', 'assets/ui/data-exchange-icon.ico');
  }

  private loadLabMiniatures(): void {
    // Caricamento miniature laboratori con percorsi multipli per maggiore compatibilità
    // Mercatorum
    this.load.image('mercatorum-miniature', 'assets/ui/mercatorum-logo.png');
    this.load.image('lab_mercatorum_miniature', 'assets/ui/mercatorum-logo.png');
    this.load.image('mercatorum', 'assets/images/labs/mercatorum_preview.png');
    
    // Blekinge
    this.load.image('blekinge-miniature', 'assets/ui/blekinge-logo.png');
    this.load.image('lab_blekinge_miniature', 'assets/ui/blekinge-logo.png');
    this.load.image('blekinge', 'assets/images/labs/blekinge_preview.png');
    
    // OPBG
    this.load.image('opbg-miniature', 'assets/ui/opbg-logo.png');
    this.load.image('lab_opbg_miniature', 'assets/ui/opbg-logo.png');
    this.load.image('opbg', 'assets/images/labs/opbg_preview.png');
    
    // Default/fallback
    this.load.image('default_lab', 'assets/images/labs/default_preview.png');
  }

  private loadAgentSprites(): void {
    // Caricamento sprite base per visualizzazione agenti nella mappa mondiale
    // Questi sono sprite semplificati usati solo per le miniature
    this.load.image('agent-dot', 'assets/ui/placeholder.png');
    this.load.image('researcher', 'assets/images/agents/researcher.png');
    this.load.image('professor', 'assets/images/agents/professor.png');
    this.load.image('phd_student', 'assets/images/agents/phd_student.png');
    this.load.image('default_researcher', 'assets/images/agents/researcher.png');
  }

  private loadMapAssets(): void {
    // Asset per la visualizzazione delle connessioni sulla mappa
    this.load.image('lab-connection', 'assets/ui/placeholder.png');
    this.load.image('lab-connection-active', 'assets/ui/placeholder.png');
  }
}