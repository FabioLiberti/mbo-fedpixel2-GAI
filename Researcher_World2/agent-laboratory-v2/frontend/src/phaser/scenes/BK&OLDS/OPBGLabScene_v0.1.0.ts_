import { BaseLabScene, LabTheme } from './BaseLabScene';
import { Agent } from '../sprites/Agent';
import { ResearcherAgent } from '../sprites/ResearcherAgent';
import { MedicalResearcher } from '../sprites/MedicalResearcher';

export class OPBGLabScene extends BaseLabScene {
  // Tema specifico per il laboratorio OPBG
  protected theme: LabTheme = {
    name: 'OPBG IRCCS Lab',
    backgroundColor: 0xf0f7fa, // Bianco leggermente azzurrato
    tilesetKey: 'opbg-tileset',
    colorPalette: {
      primary: 0x00a896,   // Verde acqua
      secondary: 0xef476f, // Rosa pallido
      accent: 0x4cc9f0,    // Blu cielo
      background: 0xf0f7fa // Bianco azzurrino
    }
  };
  
  // Effetto pulsante per area sicura dati
  private secureAreaPulse!: Phaser.GameObjects.Ellipse;
  
  constructor() {
    super('OPBGLabScene');
  }
  
  preload(): void {
    // Carica il tileset specifico per OPBG
    this.load.image(this.theme.tilesetKey, 'assets/tilesets/opbg-tileset.png');
    
    // Carica la mappa Tilemap in formato JSON
    this.load.tilemapTiledJSON('opbg-map', 'assets/maps/opbg-lab.json');
    
    // Carica gli sprite degli agenti
    this.load.spritesheet('medical-staff', 'assets/sprites/medical-staff.png', {
      frameWidth: 16,
      frameHeight: 24
    });
    
    // Carica gli sprite dei ricercatori
    this.load.spritesheet('researcher-opbg', 'assets/sprites/researchers-opbg.png', {
      frameWidth: 16,
      frameHeight: 24
    });
    
    // Altri asset specifici per il laboratorio OPBG
    this.load.image('opbg-logo', 'assets/ui/opbg-logo.png');
    this.load.image('medical-icon', 'assets/ui/medical-icon.png');
    this.load.image('secure-data-icon', 'assets/ui/secure-data.png');
  }
  
  protected createMap(): void {
    // Crea la mappa dal JSON di Tiled
    this.map = this.make.tilemap({ key: 'opbg-map' });
    
    // Aggiunge il tileset alla mappa
    this.tileset = this.map.addTilesetImage('opbg-tileset', this.theme.tilesetKey);
    
    // Crea i diversi layer della mappa
    this.floorLayer = this.map.createLayer('Floor', this.tileset);
    this.wallsLayer = this.map.createLayer('Walls', this.tileset);
    this.furnitureLayer = this.map.createLayer('Furniture', this.tileset);
    
    // Layer decorativo per elementi clinici
    const decorLayer = this.map.createLayer('Decorations', this.tileset);
    
    // Imposta le collisioni per i muri e i mobili
    this.wallsLayer.setCollisionByProperty({ collides: true });
    this.furnitureLayer.setCollisionByProperty({ collides: true });
  }
  
  protected createInteractionZones(): void {
    // Definisce le zone di interazione specifiche per il laboratorio OPBG
    
    // Area centrale sicura per dati sensibili (server room stilizzata)
    const secureDataArea = this.add.zone(300, 200, 120, 100);
    secureDataArea.setName('secure-data-area');
    secureDataArea.setData('type', 'secure-data');
    this.interactionZones.push(secureDataArea);
    
    // Postazioni con doppi monitor per analisi medicali
    const analysisStation1 = this.add.zone(150, 150, 50, 50);
    analysisStation1.setName('analysis-station-1');
    analysisStation1.setData('type', 'analysis');
    this.interactionZones.push(analysisStation1);
    
    const analysisStation2 = this.add.zone(450, 150, 50, 50);
    analysisStation2.setName('analysis-station-2');
    analysisStation2.setData('type', 'analysis');
    this.interactionZones.push(analysisStation2);
    
    // Area con letti ospedalieri per simulazione clinica
    const clinicalArea = this.add.zone(450, 300, 120, 80);
    clinicalArea.setName('clinical-area');
    clinicalArea.setData('type', 'clinical');
    this.interactionZones.push(clinicalArea);
    
    // Bacheca con immagini stilizzate di pazienti pediatrici
    const patientBoard = this.add.zone(200, 350, 80, 40);
    patientBoard.setName('patient-board');
    patientBoard.setData('type', 'information');
    this.interactionZones.push(patientBoard);
    
    // Visualizza le zone in debug solo in modalità di sviluppo
    if (process.env.NODE_ENV === 'development') {
      this.interactionZones.forEach(zone => {
        const rect = this.add.rectangle(zone.x, zone.y, zone.width, zone.height);
        rect.setStrokeStyle(1, 0x00ff00, 0.5);
        rect.setFillStyle(0x00ff00, 0.2);
      });
    }
  }
  
  protected createAgents(): void {
    // Crea i ricercatori e il personale medico specifico per il laboratorio OPBG
    
    // Definisce posizioni iniziali sparse
    const startPositions = [
      { x: 150, y: 200 },
      { x: 200, y: 150 },
      { x: 350, y: 200 },
      { x: 400, y: 250 },
      { x: 250, y: 300 },
      { x: 450, y: 350 }
    ];
    
    // Crea diversi tipi di personale
    const staffTypes = [
      { type: 'doctor', specialization: 'clinical-data' },
      { type: 'biomedical-engineer', specialization: 'medical-imaging' },
      { type: 'researcher', specialization: 'privacy-medical' },
      { type: 'phd-student', specialization: 'genetic-data' },
      { type: 'privacy-specialist', specialization: 'differential-privacy' },
      { type: 'doctor', specialization: 'diagnostics' }
    ];
    
    // Crea gli agenti e li aggiungi alla scena
    for (let i = 0; i < Math.min(startPositions.length, staffTypes.length); i++) {
      const pos = startPositions[i];
      const type = staffTypes[i];
      
      let agent;
      
      // Crea agenti diversi in base al tipo
      if (type.type === 'doctor' || type.type === 'biomedical-engineer') {
        agent = new MedicalResearcher(
          this,
          pos.x,
          pos.y,
          'medical-staff',
          type.type,
          type.specialization
        );
      } else {
        agent = new ResearcherAgent(
          this,
          pos.x,
          pos.y,
          'researcher-opbg',
          type.type,
          type.specialization
        );
      }
      
      this.agents.push(agent);
    }
  }
  
  protected setupLabSpecificEvents(): void {
    // Eventi specifici per il laboratorio OPBG
    
    // Effetto per l'area dati sicura
    const secureArea = this.interactionZones.find(zone => zone.name === 'secure-data-area');
    if (secureArea) {
      // Icona di sicurezza dati
      const secureIcon = this.add.image(secureArea.x, secureArea.y - 30, 'secure-data-icon');
      secureIcon.setScale(0.8);
      
      // Effetto pulsante di sicurezza
      this.secureAreaPulse = this.add.ellipse(secureArea.x, secureArea.y, 100, 80);
      this.secureAreaPulse.setStrokeStyle(2, this.theme.colorPalette.accent);
      this.secureAreaPulse.setFillStyle(this.theme.colorPalette.accent, 0.1);
      
      // Animazione pulsante
      this.tweens.add({
        targets: this.secureAreaPulse,
        scaleX: 1.2,
        scaleY: 1.2,
        alpha: { from: 0.1, to: 0.3 },
        duration: 1500,
        yoyo: true,
        repeat: -1
      });
    }
    
    // Aggiunge il logo dell'ospedale
    const logo = this.add.image(50, 50, 'opbg-logo');
    logo.setScale(0.5);
    logo.setScrollFactor(0); // Fisso sullo schermo
    
    // Aggiunge icone medicali nell'area clinica
    const clinicalArea = this.interactionZones.find(zone => zone.name === 'clinical-area');
    if (clinicalArea) {
      const medicalIcon = this.add.image(clinicalArea.x, clinicalArea.y - 20, 'medical-icon');
      medicalIcon.setScale(0.6);
    }