// frontend/src/phaser/scenes/BaseLabScene.ts
import { BaseScene } from './BaseScene';
import { Agent } from '../sprites/Agent';

// Interfaccia per il tema del laboratorio
export interface LabTheme {
  name: string;
  backgroundColor: number;
  tilesetKey: string;
  colorPalette: {
    primary: number;
    secondary: number;
    accent: number;
    background: number;
  };
}

/**
 * Scene base per tutti i laboratori
 */
export class BaseLabScene extends BaseScene {
  // Agenti e interazioni
  protected agents: Agent[] = [];
  protected interactionZones: Phaser.GameObjects.Zone[] = [];
  
  // Grid per il pathfinding
  protected grid: number[][] = [];
  
  // Tema del laboratorio (deve essere implementato nelle sottoclassi)
  protected theme: LabTheme = {
    name: "Base Lab",
    backgroundColor: 0x000000,
    tilesetKey: 'tiles_main',
    colorPalette: {
      primary: 0x333333,
      secondary: 0x555555,
      accent: 0x777777,
      background: 0x999999
    }
  };
  
  constructor(key: string) {
    super(key);
    console.log(`BaseLabScene constructor called with key: ${key}`);
  }
  
  init(): void {
    super.init();
    this.grid = [];
    this.agents = [];
    this.interactionZones = [];
    console.log(`BaseLabScene initialized: ${this.scene.key}`);
  }
  
  /**
   * Inizializza la griglia per il pathfinding
   */
  protected initializeGrid(): void {
    console.log('Base initializeGrid method called');
  }
  
  /**
   * Crea le zone di interazione nel laboratorio
   */
  protected createInteractionZones(): void {
    console.log('Base createInteractionZones method called');
  }
  
  /**
   * Crea alcuni agenti di test per il laboratorio
   */
  protected createTestAgents(): void {
    console.log('Base createTestAgents method called');
  }
  
  /**
   * Aggiorna tutti gli agenti
   */
  protected updateAgents(time: number, delta: number): void {
    this.agents.forEach(agent => {
      if (typeof agent.update === 'function') {
        agent.update(time, delta);
      }
    });
  }
  
  /**
   * Controlla le interazioni tra agenti e con l'ambiente
   */
  protected checkInteractions(): void {
    console.log('Base checkInteractions method called');
  }
  
  /**
   * Configura la camera
   */
  protected setupCamera(): void {
    console.log('Base setupCamera method called');
  }
  
  /**
   * Trova un percorso tra due punti
   */
  protected findPath(startX: number, startY: number, targetX: number, targetY: number): {x: number, y: number}[] {
    return [
      { x: startX, y: startY },
      { x: targetX, y: targetY }
    ];
  }
}