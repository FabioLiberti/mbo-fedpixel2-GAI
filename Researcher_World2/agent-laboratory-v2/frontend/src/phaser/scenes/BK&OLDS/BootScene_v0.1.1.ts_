import * as Phaser from 'phaser';

export default class BootScene extends Phaser.Scene {
  private loadingBar!: Phaser.GameObjects.Graphics;
  private progressBar!: Phaser.GameObjects.Graphics;
  private loadingText!: Phaser.GameObjects.Text;
  private errorMessages: string[] = [];
  
  constructor() {
    super({ key: 'BootScene' });
  }

  preload() {
    console.log("BootScene: Preloading assets...");
    
    // Create loading UI
    this.createLoadingUI();
    
    // Log start of asset loading
    console.log("Beginning asset loading...");
    
    // Setup error handler
    this.setupErrorHandler();
    
    // Load world map
    this.logAndLoad('image', 'world_map', 'assets/images/world_map.jpg');
    
    // Load lab miniatures - try different paths and extensions
    const labIds = ['mercatorum', 'blekinge', 'opbg'];
    const extensions = ['.jpg', '.png', '.jpeg'];
    const pathFormats = [
      'assets/images/labs/%s_miniature%s',
      'assets/images/labs/%s%s', 
      'assets/images/%s_miniature%s',
      'assets/images/%s%s'
    ];
    
    // Try various combinations to find the correct paths
    labIds.forEach(labId => {
      pathFormats.forEach(format => {
        extensions.forEach(ext => {
          const key = `lab_${labId}_miniature`;
          const path = format.replace(/%s/g, (_, i) => i === 0 ? labId : ext);
          this.logAndLoad('image', key, path);
        });
      });
    });
    
    // Load researcher sprites with debug information
    const researcherTypes = [
      'professor', 'researcher', 'phd', 'ml_engineer', 
      'data_engineer', 'privacy_specialist', 'doctor', 'biomedical'
    ];
    
    researcherTypes.forEach(type => {
      // Try different paths for researcher sprites
      [
        `assets/images/researchers/${type}.png`,
        `assets/images/researchers/${type}.jpg`,
        `assets/sprites/researchers/${type}.png`,
        `assets/sprites/researchers/${type}.jpg`,
        `assets/sprites/${type}.png`,
        `assets/sprites/${type}.jpg`
      ].forEach(path => {
        this.logAndLoad('image', `researcher_${type}`, path);
      });
    });

    // Load data transfer icon
    this.logAndLoad('image', 'data_transfer', 'assets/images/data_transfer.png');
    // Also try with jpg extension
    this.logAndLoad('image', 'data_transfer', 'assets/images/data_transfer.jpg');
    
    // Load default textures for fallbacks
    this.logAndLoad('image', 'default_lab', 'assets/images/default_lab.png');
    this.logAndLoad('image', 'default_researcher', 'assets/images/default_researcher.png');
    this.logAndLoad('image', 'default_map', 'assets/images/default_map.jpg');

    // Update loading progress
    this.load.on('progress', (value: number) => {
      this.updateLoadingProgress(value);
    });

    this.load.on('complete', () => {
      console.log("Asset loading complete!");
      this.displayLoadingSummary();
    });
  }

  create() {
    console.log("BootScene: Create phase starting...");
    
    // If there were loading errors, show them on screen
    if (this.errorMessages.length > 0) {
      this.showErrorSummary();
      return;
    }
    
    // List all successfully loaded textures
    console.log("Successfully loaded textures:", Object.keys(this.textures.list));
    
    // Continue to the main scene
    console.log("Starting WorldMapScene...");
    this.scene.start('WorldMapScene');
  }

  private createLoadingUI() {
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    // Background
    this.add.rectangle(width/2, height/2, width, height, 0x000000);
    
    // Loading text
    this.loadingText = this.add.text(width/2, height/2 - 50, 'Loading Assets...', {
      fontSize: '24px',
      color: '#FFFFFF'
    }).setOrigin(0.5);
    
    // Loading bar background
    this.loadingBar = this.add.graphics();
    this.loadingBar.fillStyle(0x222222, 1);
    this.loadingBar.fillRect(width/2 - 160, height/2 - 25, 320, 50);
    
    // Progress bar
    this.progressBar = this.add.graphics();
  }

  private updateLoadingProgress(value: number) {
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    // Clear previous progress
    this.progressBar.clear();
    
    // Draw new progress
    this.progressBar.fillStyle(0x00aa00, 1);
    this.progressBar.fillRect(width/2 - 150, height/2 - 15, 300 * value, 30);
    
    // Update text
    const percent = Math.floor(value * 100);
    this.loadingText.setText(`Loading Assets... ${percent}%`);
  }
  
  private setupErrorHandler() {
    this.load.on('loaderror', (file: any) => {
      console.error(`Error loading file: ${file.key} (${file.url})`);
      
      // Only record first occurrence of each path
      const errorMsg = `Failed to load: ${file.key} (${file.url})`;
      if (!this.errorMessages.includes(errorMsg)) {
        this.errorMessages.push(errorMsg);
      }
    });
  }
  
  private displayLoadingSummary() {
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    // Clear progress UI
    this.loadingBar.destroy();
    this.progressBar.destroy();
    this.loadingText.destroy();
    
    // Show summary
    this.add.text(width/2, height/2 - 50, 'Asset Loading Complete', {
      fontSize: '24px',
      color: '#00FF00'
    }).setOrigin(0.5);
    
    // Show count of loaded assets
    this.add.text(width/2, height/2, 
      `Loaded ${Object.keys(this.textures.list).length - 1} textures`, {
      fontSize: '16px',
      color: '#FFFFFF'
    }).setOrigin(0.5);
    
    // Show error count if any
    if (this.errorMessages.length > 0) {
      this.add.text(width/2, height/2 + 30, 
        `Errors: ${this.errorMessages.length} (see console for details)`, {
        fontSize: '16px',
        color: '#FF0000'
      }).setOrigin(0.5);
    }
    
    // Countdown to next scene
    let countdown = 2;
    const countdownText = this.add.text(width/2, height/2 + 70, 
      `Continuing in ${countdown}...`, {
      fontSize: '14px',
      color: '#AAAAAA'
    }).setOrigin(0.5);
    
    const timer = this.time.addEvent({
      delay: 1000,
      callback: () => {
        countdown--;
        if (countdown <= 0) {
          timer.destroy();
        } else {
          countdownText.setText(`Continuing in ${countdown}...`);
        }
      },
      callbackScope: this,
      repeat: countdown
    });
  }
  
  private showErrorSummary() {
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    // Title
    this.add.text(width/2, 100, 'Asset Loading Errors', {
      fontSize: '24px',
      color: '#FF0000'
    }).setOrigin(0.5);
    
    // Create scrollable error list
    const errorList = this.add.text(width/2, 150, 
      this.errorMessages.slice(0, 15).join('\n'), {
      fontSize: '12px',
      color: '#FFFFFF',
      align: 'left',
      wordWrap: { width: width - 100 }
    }).setOrigin(0.5, 0);
    
    // Add continue button regardless of errors
    const continueButton = this.add.text(width/2, height - 100, 'Continue Anyway', {
      fontSize: '18px',
      color: '#FFFFFF',
      backgroundColor: '#AA0000',
      padding: { x: 15, y: 10 }
    }).setOrigin(0.5).setInteractive();
    
    continueButton.on('pointerdown', () => {
      this.scene.start('WorldMapScene');
    });
  }
  
  private logAndLoad(type: string, key: string, path: string) {
    // Avoid duplicate loading
    if (this.textures.exists(key)) {
      console.log(`Skipping duplicate load for ${key}`);
      return;
    }
    
    console.log(`Loading ${type}: ${key} from ${path}`);
    
    try {
      // Add to loader
      if (type === 'image') {
        this.load.image(key, path);
      } else if (type === 'spritesheet') {
        // If spritesheet, add appropriate config
        this.load.spritesheet(key, path, { frameWidth: 32, frameHeight: 32 });
      }
    } catch (e) {
      console.error(`Error setting up load for ${key}:`, e);
    }
  }
}