import Phaser from 'phaser';

export class BootScene extends Phaser.Scene {
  constructor() {
    super('BootScene');
  }

  preload(): void {
    // Mostra barra di caricamento
    this.createLoadingBar();
    
    // Carica assets UI base
    this.loadUIAssets();
    
    // Carica assets della mappa mondiale
    this.loadWorldMapAssets();
    
    // Carica assets dei laboratori
    this.loadLabAssets();
    
    // Carica assets degli agenti
    this.loadAgentAssets();
    
    // Carica suoni e musica
    this.loadAudioAssets();
  }

  create(): void {
    console.log('Boot scene completata. Passaggio alla World Map.');
    this.scene.start('WorldMapScene');
  }

  private createLoadingBar(): void {
    // Crea una barra di caricamento
    const width = this.cameras.main.width;
    const height = this.cameras.main.height;
    
    const progressBar = this.add.graphics();
    const progressBox = this.add.graphics();
    progressBox.fillStyle(0x222222, 0.8);
    progressBox.fillRect(width / 2 - 160, height / 2 - 25, 320, 50);
    
    const loadingText = this.add.text(width / 2, height / 2 - 50, 'Caricamento...', {
      fontFamily: 'Arial',
      fontSize: '20px',
      color: '#ffffff'
    });
    loadingText.setOrigin(0.5, 0.5);
    
    const percentText = this.add.text(width / 2, height / 2, '0%', {
      fontFamily: 'Arial',
      fontSize: '18px',
      color: '#ffffff'
    });
    percentText.setOrigin(0.5, 0.5);
    
    // Eventi di caricamento
    this.load.on('progress', (value: number) => {
      percentText.setText(parseInt(value * 100 + '') + '%');
      progressBar.clear();
      progressBar.fillStyle(0xffffff, 1);
      progressBar.fillRect(width / 2 - 150, height / 2 - 15, 300 * value, 30);
    });
    
    this.load.on('complete', () => {
      progressBar.destroy();
      progressBox.destroy();
      loadingText.destroy();
      percentText.destroy();
    });
  }

  private loadUIAssets(): void {
    // Carica assets dell'interfaccia utente
    this.load.image('logo', 'assets/ui/logo.png');
    this.load.image('button', 'assets/ui/button.png');
    this.load.image('info-button', 'assets/ui/info-button.png');
    this.load.image('settings-button', 'assets/ui/settings-button.png');
    this.load.image('close-button', 'assets/ui/close-button.png');
    this.load.image('pause-button', 'assets/ui/pause-button.png');
    this.load.image('play-button', 'assets/ui/play-button.png');
    this.load.image('panel-bg', 'assets/ui/panel-background.png');
    this.load.image('data-exchange-icon', 'assets/ui/data-exchange-icon.png');
  }

  private loadWorldMapAssets(): void {
    // Carica assets della mappa mondiale
    this.load.image('world-map-background', 'assets/ui/world-map-background.png');
    
    // Carica le anteprime dei laboratori (immagini più dettagliate per le miniature)
    this.load.image('mercatorum-preview', 'assets/images/labs/mercatorum_preview.png');
    this.load.image('blekinge-preview', 'assets/images/labs/blekinge_preview.png');
    this.load.image('opbg-preview', 'assets/images/labs/opbg_preview.png');
    this.load.image('default-preview', 'assets/images/labs/default_preview.png');
  }

  private loadLabAssets(): void {
    // Carica tileset e asset per i laboratori
    
    // Mercatorum Lab
    this.load.image('mercatorum-background', 'assets/labs/mercatorum/background.png');
    this.load.image('mercatorum-floor', 'assets/labs/mercatorum/floor.png');
    this.load.image('mercatorum-furniture', 'assets/labs/mercatorum/furniture.png');
    
    // Blekinge Lab
    this.load.image('blekinge-background', 'assets/labs/blekinge/background.png');
    this.load.image('blekinge-floor', 'assets/labs/blekinge/floor.png');
    this.load.image('blekinge-furniture', 'assets/labs/blekinge/furniture.png');
    
    // OPBG Lab
    this.load.image('opbg-background', 'assets/labs/opbg/background.png');
    this.load.image('opbg-floor', 'assets/labs/opbg/floor.png');
    this.load.image('opbg-furniture', 'assets/labs/opbg/furniture.png');
    
    // Oggetti interattivi comuni
    this.load.image('computer', 'assets/labs/common/computer.png');
    this.load.image('whiteboard', 'assets/labs/common/whiteboard.png');
    this.load.image('desk', 'assets/labs/common/desk.png');
    this.load.image('chair', 'assets/labs/common/chair.png');
  }

  private loadAgentAssets(): void {
    // Carica gli sprite degli agenti
    
    // Sprite per la mappa mondiale (versioni piccole)
    this.load.image('phd-student-sprite', 'assets/images/agents/phd_student.png');
    this.load.image('researcher-sprite', 'assets/images/agents/researcher.png');
    this.load.image('professor-sprite', 'assets/images/agents/professor.png');
    //this.load.image('ml-engineer-sprite', 'assets/images/agents/ml_engineer.png');
    //this.load.image('data-engineer-sprite', 'assets/images/agents/data_engineer.png');
    //this.load.image('privacy-specialist-sprite', 'assets/images/agents/privacy_specialist.png');
    //this.load.image('medical-doctor-sprite', 'assets/images/agents/medical_doctor.png');
    //this.load.image('biomedical-engineer-sprite', 'assets/images/agents/biomedical_engineer.png');
    //this.load.image('default-agent-sprite', 'assets/images/agents/default_agent.png');
    // Usa placeholder per quelli mancanti
    this.load.image('ml-engineer-sprite', 'assets/ui/placeholder.png');
    this.load.image('data-engineer-sprite', 'assets/ui/placeholder.png');
    this.load.image('privacy-specialist-sprite', 'assets/ui/placeholder.png');
    this.load.image('medical-doctor-sprite', 'assets/ui/placeholder.png');
    this.load.image('biomedical-engineer-sprite', 'assets/ui/placeholder.png');
    this.load.image('default-agent-sprite', 'assets/ui/placeholder.png');


    // Spritesheet per gli agenti nei laboratori (versioni complete animate)
    this.load.spritesheet('phd-student', 'assets/agents/phd_student.png', { frameWidth: 32, frameHeight: 48 });
    this.load.spritesheet('researcher', 'assets/agents/researcher.png', { frameWidth: 32, frameHeight: 48 });
    this.load.spritesheet('professor', 'assets/agents/professor.png', { frameWidth: 32, frameHeight: 48 });
    this.load.spritesheet('ml-engineer', 'assets/agents/ml_engineer.png', { frameWidth: 32, frameHeight: 48 });
    this.load.spritesheet('data-engineer', 'assets/agents/data_engineer.png', { frameWidth: 32, frameHeight: 48 });
    this.load.spritesheet('privacy-specialist', 'assets/agents/privacy_specialist.png', { frameWidth: 32, frameHeight: 48 });
    this.load.spritesheet('medical-doctor', 'assets/agents/medical_doctor.png', { frameWidth: 32, frameHeight: 48 });
    this.load.spritesheet('biomedical-engineer', 'assets/agents/biomedical_engineer.png', { frameWidth: 32, frameHeight: 48 });
  }

  private loadAudioAssets(): void {
    // Carica suoni ed effetti audio
    this.load.audio('click', 'assets/audio/click.mp3');
    this.load.audio('lab-ambience', 'assets/audio/lab-ambience.mp3');
    this.load.audio('data-transfer', 'assets/audio/data-transfer.mp3');
    this.load.audio('background-music', 'assets/audio/background-music.mp3');
  }
}