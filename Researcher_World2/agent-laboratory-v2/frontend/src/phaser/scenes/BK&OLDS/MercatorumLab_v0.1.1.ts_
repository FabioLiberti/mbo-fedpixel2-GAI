import Phaser from 'phaser';
import { webSocketService } from '../../services/api';

export class MercatorumLab extends Phaser.Scene {
  private tilemap?: Phaser.Tilemaps.Tilemap;
  private player?: Phaser.Physics.Arcade.Sprite;
  private cursors?: Phaser.Types.Input.Keyboard.CursorKeys;
  private researchers: Phaser.Physics.Arcade.Sprite[] = [];
  private statusText?: Phaser.GameObjects.Text;

  constructor() {
    super({ key: 'MercatorumLab' });
  }

  preload() {
    // Caricamento tileset e sprites
    this.load.image('tiles', 'assets/tileset/mercatorum-tiles.png');
    this.load.tilemapTiledJSON('mercatorum-map', 'assets/maps/mercatorum-lab.json');
    
    // Caricamento sprites personaggi
    this.load.spritesheet('researcher', 'assets/sprites/researcher.png', { 
      frameWidth: 32, 
      frameHeight: 32 
    });
    
    this.load.spritesheet('professor', 'assets/sprites/professor.png', { 
      frameWidth: 32, 
      frameHeight: 32 
    });
    
    // Fallback per assets mancanti (importanti per il debug)
    this.load.image('placeholder', 'assets/sprites/placeholder.png');
  }

  create() {
    try {
      // Crea tilemap se abbiamo caricato il JSON
      if (this.cache.tilemap.exists('mercatorum-map')) {
        this.tilemap = this.make.tilemap({ key: 'mercatorum-map' });
        const tileset = this.tilemap.addTilesetImage('mercatorum-tiles', 'tiles');
        
        if (tileset) {
          // Crea layers dalla mappa
          const floorLayer = this.tilemap.createLayer('Floor', tileset);
          const wallsLayer = this.tilemap.createLayer('Walls', tileset);
          const furnitureLayer = this.tilemap.createLayer('Furniture', tileset);
          
          // Configurazione collisioni
          if (wallsLayer) wallsLayer.setCollisionByProperty({ collides: true });
          if (furnitureLayer) furnitureLayer.setCollisionByProperty({ collides: true });
        }
      } else {
        // Fallback per debugging/sviluppo se la mappa non è disponibile
        this.createDebugEnvironment();
      }

      // Crea il player
      this.player = this.physics.add.sprite(400, 300, 'researcher');
      this.player.setCollideWorldBounds(true);
      
      // Crea ricercatori AI
      this.createResearchers();
      
      // Imposta la camera per seguire il player
      this.cameras.main.setBounds(0, 0, 800, 600);
      if (this.player) {
        this.cameras.main.startFollow(this.player, true, 0.09, 0.09);
      }
      
      // Crea animazioni
      this.createAnimations();
      
      // Inizializza input
      this.cursors = this.input.keyboard?.createCursorKeys();
      
      // Status text
      this.statusText = this.add.text(16, 16, 'Università Mercatorum Lab', { 
        fontSize: '18px', 
        color: '#ffffff',
        stroke: '#000000',
        strokeThickness: 2,
        fontFamily: 'Arial'
      });
      this.statusText.setScrollFactor(0);
      
      // Evento di connessione WebSocket
      webSocketService.onMessage('researcherMove', (data) => {
        this.handleResearcherMove(data);
      });
    } catch (error) {
      console.error('Error in MercatorumLab create():', error);
    }
  }

  update() {
    // Movimento del player
    if (this.player && this.cursors) {
      const speed = 150;
      
      if (this.cursors.left?.isDown) {
        this.player.setVelocityX(-speed);
        this.player.setVelocityY(0);
        this.player.anims.play('walk-left', true);
      } else if (this.cursors.right?.isDown) {
        this.player.setVelocityX(speed);
        this.player.setVelocityY(0);
        this.player.anims.play('walk-right', true);
      } else if (this.cursors.up?.isDown) {
        this.player.setVelocityY(-speed);
        this.player.setVelocityX(0);
        this.player.anims.play('walk-up', true);
      } else if (this.cursors.down?.isDown) {
        this.player.setVelocityY(speed);
        this.player.setVelocityX(0);
        this.player.anims.play('walk-down', true);
      } else {
        this.player.setVelocityX(0);
        this.player.setVelocityY(0);
        this.player.anims.stop();
      }
    }
    
    // Aggiorna movimento ricercatori AI
    this.updateResearchers();
  }

  private createDebugEnvironment() {
    // Crea un ambiente di base per debugging/sviluppo
    const graphics = this.add.graphics();
    
    // Disegna un pavimento con pattern a griglia
    graphics.fillStyle(0x222222);
    graphics.fillRect(0, 0, 800, 600);
    
    graphics.lineStyle(1, 0x444444);
    for (let x = 0; x < 800; x += 32) {
      graphics.moveTo(x, 0);
      graphics.lineTo(x, 600);
    }
    for (let y = 0; y < 600; y += 32) {
      graphics.moveTo(0, y);
      graphics.lineTo(800, y);
    }
    graphics.strokePath();
    
    // Aggiungi alcuni oggetti di arredo per simulare l'ambiente
    for (let i = 0; i < 5; i++) {
      const x = Phaser.Math.Between(100, 700);
      const y = Phaser.Math.Between(100, 500);
      
      const furniture = this.add.rectangle(x, y, 64, 64, 0x885511);
      this.physics.add.existing(furniture, true);
    }
    
    // Aggiungi un'area centrale stile tavolo riunioni
    const centerTable = this.add.ellipse(400, 300, 120, 80, 0x663311);
    this.physics.add.existing(centerTable, true);
    
    // Aggiungi un testo informativo
    this.add.text(400, 50, 'Debug Environment: Assets not found', {
      fontSize: '16px',
      color: '#ffffff'
    }).setOrigin(0.5);
  }

  private createResearchers() {
    // Crea alcuni ricercatori AI nel lab
    const researcherTypes = ['researcher', 'professor'];
    const positions = [
      { x: 200, y: 200 },
      { x: 300, y: 150 },
      { x: 500, y: 250 },
      { x: 600, y: 400 },
      { x: 400, y: 450 }
    ];
    
    positions.forEach((pos, i) => {
      const spriteKey = researcherTypes[i % researcherTypes.length];
      const researcher = this.physics.add.sprite(pos.x, pos.y, spriteKey);
      
      // Aggiungi proprietà custom
      researcher.setData('id', `researcher-${i}`);
      researcher.setData('type', spriteKey);
      researcher.setData('state', 'idle');
      researcher.setData('targetX', pos.x);
      researcher.setData('targetY', pos.y);
      researcher.setData('moveTimer', 0);
      
      this.researchers.push(researcher);
      
      // Aggiungi indicatore stato sopra il ricercatore
      const statusEmoji = this.add.text(pos.x, pos.y - 20, '💻', { fontSize: '16px' });
      researcher.setData('statusEmoji', statusEmoji);
    });
  }

  private updateResearchers() {
    // Simula il comportamento autonomo dei ricercatori
    const time = this.time.now;
    
    this.researchers.forEach(researcher => {
      const moveTimer = researcher.getData('moveTimer') as number;
      const state = researcher.getData('state') as string;
      
      if (time > moveTimer) {
        // Cambia stato casualmente
        if (Phaser.Math.Between(0, 10) > 8) {
          const states = ['idle', 'moving', 'working', 'discussing'];
          const newState = states[Phaser.Math.Between(0, states.length - 1)];
          researcher.setData('state', newState);
          
          // Aggiorna emoji di stato
          const statusEmoji = researcher.getData('statusEmoji') as Phaser.GameObjects.Text;
          switch (newState) {
            case 'idle': statusEmoji.setText('💭'); break;
            case 'moving': statusEmoji.setText('🚶'); break;
            case 'working': statusEmoji.setText('💻'); break;
            case 'discussing': statusEmoji.setText('💬'); break;
          }
          
          // Se in movimento, imposta una nuova destinazione
          if (newState === 'moving') {
            researcher.setData('targetX', Phaser.Math.Between(100, 700));
            researcher.setData('targetY', Phaser.Math.Between(100, 500));
          }
        }
        
        // Imposta un nuovo timer
        researcher.setData('moveTimer', time + Phaser.Math.Between(1000, 3000));
      }
      
      // Gestisci movimento verso la destinazione
      if (state === 'moving') {
        const targetX = researcher.getData('targetX') as number;
        const targetY = researcher.getData('targetY') as number;
        
        const dx = targetX - researcher.x;
        const dy = targetY - researcher.y;
        const distance = Math.sqrt(dx * dx + dy * dy);
        
        if (distance > 5) {
          const speed = 50;
          const velocityX = (dx / distance) * speed;
          const velocityY = (dy / distance) * speed;
          
          researcher.setVelocity(velocityX, velocityY);
          
          // Animazione in base alla direzione
          if (Math.abs(dx) > Math.abs(dy)) {
            researcher.anims.play(dx > 0 ? 'walk-right' : 'walk-left', true);
          } else {
            researcher.anims.play(dy > 0 ? 'walk-down' : 'walk-up', true);
          }
        } else {
          researcher.setVelocity(0, 0);
          researcher.setData('state', 'idle');
          const statusEmoji = researcher.getData('statusEmoji') as Phaser.GameObjects.Text;
          statusEmoji.setText('💭');
        }
      } else {
        researcher.setVelocity(0, 0);
      }
      
      // Aggiorna posizione dell'emoji di stato
      const statusEmoji = researcher.getData('statusEmoji') as Phaser.GameObjects.Text;
      statusEmoji.setPosition(researcher.x, researcher.y - 20);
    });
  }

  private createAnimations() {
    // Crea animazioni per tutti i personaggi
    const characters = ['researcher', 'professor'];
    
    characters.forEach(character => {
      // Animazioni camminata in 4 direzioni
      this.anims.create({
        key: `${character}-walk-left`,
        frames: this.anims.generateFrameNumbers(character, { start: 0, end: 3 }),
        frameRate: 10,
        repeat: -1
      });
      
      this.anims.create({
        key: `${character}-walk-right`,
        frames: this.anims.generateFrameNumbers(character, { start: 4, end: 7 }),
        frameRate: 10,
        repeat: -1
      });
      
      this.anims.create({
        key: `${character}-walk-up`,
        frames: this.anims.generateFrameNumbers(character, { start: 8, end: 11 }),
        frameRate: 10,
        repeat: -1
      });
      
      this.anims.create({
        key: `${character}-walk-down`,
        frames: this.anims.generateFrameNumbers(character, { start: 12, end: 15 }),
        frameRate: 10,
        repeat: -1
      });
    });
    
    // Animazioni generiche
    this.anims.create({
      key: 'walk-left',
      frames: this.anims.generateFrameNumbers('researcher', { start: 0, end: 3 }),
      frameRate: 10,
      repeat: -1
    });
    
    this.anims.create({
      key: 'walk-right',
      frames: this.anims.generateFrameNumbers('researcher', { start: 4, end: 7 }),
      frameRate: 10,
      repeat: -1
    });
    
    this.anims.create({
      key: 'walk-up',
      frames: this.anims.generateFrameNumbers('researcher', { start: 8, end: 11 }),
      frameRate: 10,
      repeat: -1
    });
    
    this.anims.create({
      key: 'walk-down',
      frames: this.anims.generateFrameNumbers('researcher', { start: 12, end: 15 }),
      frameRate: 10,
      repeat: -1
    });
  }

  private handleResearcherMove(data: any) {
    // Gestisci messaggi WebSocket per movimento ricercatori
    const { id, x, y, state } = data;
    
    // Trova il ricercatore corrispondente
    const researcher = this.researchers.find(r => r.getData('id') === id);
    if (researcher) {
      researcher.setData('targetX', x);
      researcher.setData('targetY', y);
      researcher.setData('state', state);
    }
  }
}