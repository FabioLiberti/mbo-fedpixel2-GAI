// frontend/src/phaser/controllers/DialogController.ts

import Phaser from 'phaser';
import { FLDialogType as DialogType, CognitiveProcessType } from '../types/DialogTypes';
import { SpeechBubble } from '../ui/SpeechBubble';
import { ThoughtBubble } from '../ui/ThoughtBubble';
import { DecisionBubble } from '../ui/DecisionBubble';
import { api } from '../../services/api';
import { LabTheme } from '../scenes/BaseLabScene';

/**
 * Configurazione per un dialogo o un processo cognitivo
 */
interface DialogConfig {
  sourceId: string;                   // ID dell'agente
  targetId?: string;                  // ID dell'agente target (opzionale)
  type: DialogType;                   // Tipo di dialogo
  text: string;                       // Testo del dialogo
  duration?: number;                  // Durata in ms
  showEffect?: boolean;               // Se mostrare effetti visivi
  callback?: () => void;              // Callback dopo il dialogo
  isLLMDialog?: boolean;              // Se generato da LLM
  cognitiveType?: CognitiveProcessType; // Tipo di processo cognitivo
  metadata?: any;                     // Metadati aggiuntivi
  priority?: number;                  // Priorità nella coda (0-10)
}

/**
 * Controller migliorato per gestire dialoghi e processi cognitivi degli agenti
 */
export class DialogController {
  private scene: Phaser.Scene;
  private activeBubbles: Map<string, SpeechBubble | ThoughtBubble | DecisionBubble> = new Map();
  private dialogQueue: DialogConfig[] = [];
  private isProcessingQueue: boolean = false;
  private debugMode: boolean = false;
  private isLLMAvailable: boolean = false;
  private labTheme: LabTheme | null = null;
  private lastLLMCheck: number = 0;
  private readonly LLM_CHECK_INTERVAL: number = 60000; // 1 minuto
  
  // Contatore per ID unici dei processi cognitivi
  private cognitiveProcessCounter: number = 0;

  constructor(scene: Phaser.Scene, labTheme?: LabTheme) {
    this.scene = scene;
    this.labTheme = labTheme || null;
    this.debugMode = localStorage.getItem('dialog_debug') === 'true';
    
    // Controlla disponibilità LLM
    this.checkLLMAvailability();
    
    // Registra gli eventi
    this.registerEvents();
  }

  /**
   * Verifica disponibilità del servizio LLM
   */
  private async checkLLMAvailability(): Promise<void> {
    // Evita controlli troppo frequenti
    const now = Date.now();
    if (now - this.lastLLMCheck < this.LLM_CHECK_INTERVAL) {
      return;
    }
    
    this.lastLLMCheck = now;
    
    try {
      const result = await api.checkLLMAvailability();
      this.isLLMAvailable = result.available;
      
      if (this.debugMode) {
        console.log(`[DialogController] LLM service availability: ${this.isLLMAvailable}`);
      }
    } catch (error) {
      console.error('Failed to check LLM availability:', error);
      this.isLLMAvailable = false;
    }
  }
  
  /**
   * Registra tutti gli eventi necessari
   */
  private registerEvents(): void {
    try {
      // Eventi principali
      const gameEvents = this.scene.game.events;
      
      // Interazioni tra agenti
      gameEvents.on('agent-interaction', this.handleAgentInteraction, this);
      
      // Nuovi eventi per processi cognitivi
      gameEvents.on('agent-thinking', this.handleAgentThinking, this);
      gameEvents.on('agent-decision', this.handleAgentDecision, this);
      gameEvents.on('agent-planning', this.handleAgentPlanning, this);
      gameEvents.on('agent-reaction', this.handleAgentReaction, this);
      
      // Eventi FL
      gameEvents.on('fl-event', this.handleFLEvent, this);
      
      // Nuovi eventi specifici per eventi FL
      gameEvents.on('fl-training-started', this.handleFLTrainingStarted, this);
      gameEvents.on('fl-round-completed', this.handleFLRoundCompleted, this);
      gameEvents.on('fl-client-selected', this.handleFLClientSelected, this);
      gameEvents.on('fl-privacy-breach', this.handleFLPrivacyBreach, this);
      gameEvents.on('fl-convergence-reached', this.handleFLConvergenceReached, this);
      
      if (this.debugMode) {
        console.log('[DialogController] Events registered successfully');
      }
    } catch (error) {
      console.error('Error registering events:', error);
    }
  }
  
  /**
   * Gestisce interazioni tra agenti
   */
  private async handleAgentInteraction(data: {
    agentId1: string;
    agentId2: string;
    type: string;
  }): Promise<void> {
    if (this.debugMode) {
      console.log(`[DialogController] Handling agent interaction between ${data.agentId1} and ${data.agentId2}`);
    }
    
    try {
      // Ottieni dettagli degli agenti
      const agent1 = this.getAgentDetails(data.agentId1);
      const agent2 = this.getAgentDetails(data.agentId2);
      
      if (!agent1 || !agent2) {
        console.warn('[DialogController] Could not find agent details for interaction');
        return;
      }
      
      // Ottieni stato FL corrente
      const flState = this.getCurrentFLState();
      
      // Ricontrolla disponibilità LLM se necessario
      if (!this.isLLMAvailable) {
        await this.checkLLMAvailability();
      }
      
      // Usa LLM se disponibile
      if (this.isLLMAvailable) {
        try {
          // Prima mostra il "pensiero" dell'agente 1 (processo cognitivo)
          const thinkingResult = await api.generateAgentThinking({
            agentId: agent1.id,
            agentName: agent1.name,
            agentRole: agent1.role,
            agentSpecialization: agent1.specialization || 'general',
            targetAgentId: agent2.id,
            targetAgentName: agent2.name,
            targetAgentRole: agent2.role,
            interactionType: data.type,
            labType: this.getLabTypeString(),
            flState: flState
          });
          
          // Crea bolla di pensiero
          if (thinkingResult.thinking) {
            this.createCognitiveProcess({
              sourceId: agent1.id,
              type: DialogType.GENERAL,
              text: thinkingResult.thinking,
              cognitiveType: CognitiveProcessType.THINKING,
              isLLMDialog: true,
              showEffect: false,
              duration: 3000,
              priority: 5
            });
          }
          
          // Poi genera dialogo dopo breve ritardo
          setTimeout(async () => {
            const dialogResult = await api.generateAgentDialog({
              agentId: agent1.id,
              agentName: agent1.name,
              agentRole: agent1.role,
              agentSpecialization: agent1.specialization || 'general',
              targetAgentId: agent2.id,
              targetAgentName: agent2.name,
              targetAgentRole: agent2.role,
              interactionType: data.type,
              labType: this.getLabTypeString(),
              flState: flState
            });
            
            // Crea dialogo normale
            this.createDialog({
              sourceId: agent1.id,
              targetId: agent2.id,
              type: this.getDialogTypeForRole(agent1.role),
              text: dialogResult.dialog,
              isLLMDialog: true,
              showEffect: true,
              priority: 7
            });
          }, 3000);
          
          // Dopo altro ritardo, genera risposta del secondo agente
          setTimeout(async () => {
            // Prima il pensiero
            const thinkingResult2 = await api.generateAgentThinking({
              agentId: agent2.id,
              agentName: agent2.name,
              agentRole: agent2.role,
              agentSpecialization: agent2.specialization || 'general',
              targetAgentId: agent1.id,
              targetAgentName: agent1.name,
              targetAgentRole: agent1.role,
              interactionType: data.type,
              labType: this.getLabTypeString(),
              flState: flState
            });
            
            if (thinkingResult2.thinking) {
              this.createCognitiveProcess({
                sourceId: agent2.id,
                type: DialogType.GENERAL,
                text: thinkingResult2.thinking,
                cognitiveType: CognitiveProcessType.THINKING,
                isLLMDialog: true,
                showEffect: false,
                duration: 3000,
                priority: 5
              });
            }
            
            // Poi il dialogo
            setTimeout(async () => {
              const dialogResult2 = await api.generateAgentDialog({
                agentId: agent2.id,
                agentName: agent2.name,
                agentRole: agent2.role,
                agentSpecialization: agent2.specialization || 'general',
                targetAgentId: agent1.id,
                targetAgentName: agent1.name,
                targetAgentRole: agent1.role,
                interactionType: data.type,
                labType: this.getLabTypeString(),
                flState: flState
              });
              
              this.createDialog({
                sourceId: agent2.id,
                targetId: agent1.id,
                type: this.getDialogTypeForRole(agent2.role),
                text: dialogResult2.dialog,
                isLLMDialog: true,
                showEffect: false,
                priority: 7
              });
            }, 3000);
          }, 6000);
          
          return;
        } catch (error) {
          console.error('[DialogController] Error generating LLM content:', error);
          // Fallback ai dialoghi predefiniti
        }
      }
      
      // Fallback: crea dialoghi predefiniti
      this.createPresetDialogForInteraction(agent1, agent2, data.type);
      
    } catch (error) {
      console.error('[DialogController] Error handling agent interaction:', error);
    }
  }
  
  /**
   * Gestisce il processo di pensiero di un agente
   */
  private async handleAgentThinking(data: {
    agentId: string;
    context: string;
  }): Promise<void> {
    if (!this.isLLMAvailable) {
      await this.checkLLMAvailability();
      if (!this.isLLMAvailable) return;
    }
    
    try {
      const agent = this.getAgentDetails(data.agentId);
      if (!agent) return;
      
      const thinkingResult = await api.generateAgentThinking({
        agentId: agent.id,
        agentName: agent.name,
        agentRole: agent.role,
        agentSpecialization: agent.specialization || 'general',
        interactionType: 'thinking',
        labType: this.getLabTypeString(),
        context: data.context,
        flState: this.getCurrentFLState()
      });
      
      if (thinkingResult.thinking) {
        // Analizza il testo per rilevare possibili decisioni o piani incorporati
        const { processedText, processType } = this.analyzeText(thinkingResult.thinking);
        
        this.createCognitiveProcess({
          sourceId: agent.id,
          type: DialogType.RESEARCH,
          text: processedText,
          cognitiveType: processType || CognitiveProcessType.THINKING,
          isLLMDialog: true,
          priority: 6
        });
      }
    } catch (error) {
      console.error('[DialogController] Error handling agent thinking:', error);
    }
  }
  
  /**
   * Analizza il testo per rilevare tag speciali o pattern che indicano diversi tipi di processi cognitivi
   */
  private analyzeText(text: string): { processedText: string, processType: CognitiveProcessType | null } {
    // Pattern per identificare tipi di processi cognitivi
    const decisionPattern = /<decision>([\s\S]*?)<\/decision>/;
    const planPattern = /<plan>([\s\S]*?)<\/plan>/;
    const thinkPattern = /<think>([\s\S]*?)<\/think>/;
    
    // Controlla se c'è un tag di decisione
    const decisionMatch = text.match(decisionPattern);
    if (decisionMatch) {
      return {
        processedText: decisionMatch[1].trim(),
        processType: CognitiveProcessType.DECISION
      };
    }
    
    // Controlla se c'è un tag di piano
    const planMatch = text.match(planPattern);
    if (planMatch) {
      return {
        processedText: planMatch[1].trim(),
        processType: CognitiveProcessType.PLANNING
      };
    }
    
    // Controlla se c'è un tag di pensiero
    const thinkMatch = text.match(thinkPattern);
    if (thinkMatch) {
      return {
        processedText: thinkMatch[1].trim(),
        processType: CognitiveProcessType.THINKING
      };
    }
    
    // Se non ci sono tag, ritorna il testo originale
    return {
      processedText: text,
      processType: null
    };
  }
  
  /**
   * Gestisce una decisione di un agente relativa al FL
   */
  private async handleAgentDecision(data: {
    agentId: string;
    decisionType: string;
    context: string;
  }): Promise<void> {
    if (!this.isLLMAvailable) {
      await this.checkLLMAvailability();
      if (!this.isLLMAvailable) return;
    }
    
    try {
      const agent = this.getAgentDetails(data.agentId);
      if (!agent) return;
      
      const decisionResult = await api.generateFLDecision({
        agentId: agent.id,
        agentName: agent.name,
        agentRole: agent.role,
        agentSpecialization: agent.specialization || 'general',
        decisionType: data.decisionType,
        labType: this.getLabTypeString(),
        context: data.context,
        flState: this.getCurrentFLState()
      });
      
      if (decisionResult.decision) {
        // Estrai processo di pensiero se presente
        let decisionText = decisionResult.decision;
        let thinkingText = null;
        
        // Cerca pattern come <think>...</think> nella risposta
        const thinkMatch = decisionText.match(/<think>([\s\S]*?)<\/think>/);
        if (thinkMatch) {
          thinkingText = thinkMatch[1].trim();
          // Rimuovi il tag thinking dalla decisione
          decisionText = decisionText.replace(/<think>[\s\S]*?<\/think>/, '').trim();
        }
        
        // Prima mostra il pensiero se presente
        if (thinkingText) {
          this.createCognitiveProcess({
            sourceId: agent.id,
            type: DialogType.MODEL,
            text: thinkingText,
            cognitiveType: CognitiveProcessType.THINKING,
            isLLMDialog: true,
            duration: 4000,
            priority: 6
          });
          
          // Poi mostra la decisione dopo un ritardo
          setTimeout(() => {
            this.createCognitiveProcess({
              sourceId: agent.id,
              type: DialogType.MODEL,
              text: decisionText,
              cognitiveType: CognitiveProcessType.DECISION,
              isLLMDialog: true,
              priority: 8
            });
          }, 4000);
        } else {
          // Mostra solo la decisione
          this.createCognitiveProcess({
            sourceId: agent.id,
            type: DialogType.MODEL,
            text: decisionText,
            cognitiveType: CognitiveProcessType.DECISION,
            isLLMDialog: true,
            priority: 8
          });
        }
      }
    } catch (error) {
      console.error('[DialogController] Error handling agent decision:', error);
    }
  }
  
  /**
   * Gestisce la pianificazione di azioni da parte di un agente
   */
  private async handleAgentPlanning(data: {
    agentId: string;
    planningType: string;
    context: string;
  }): Promise<void> {
    if (!this.isLLMAvailable) {
      await this.checkLLMAvailability();
      if (!this.isLLMAvailable) return;
    }
    
    try {
      const agent = this.getAgentDetails(data.agentId);
      if (!agent) return;
      
      const planResult = await api.generateActionPlan({
        agentId: agent.id,
        agentName: agent.name,
        agentRole: agent.role,
        agentSpecialization: agent.specialization || 'general',
        planningType: data.planningType,
        labType: this.getLabTypeString(),
        context: data.context,
        flState: this.getCurrentFLState()
      });
      
      if (planResult.plan) {
        // Estrai processo di pensiero se presente
        let planText = planResult.plan;
        let thinkingText = null;
        
        // Cerca pattern come <think>...</think> nella risposta
        const thinkMatch = planText.match(/<think>([\s\S]*?)<\/think>/);
        if (thinkMatch) {
          thinkingText = thinkMatch[1].trim();
          // Rimuovi il tag thinking dal piano
          planText = planText.replace(/<think>[\s\S]*?<\/think>/, '').trim();
        }
        
        // Prima mostra il pensiero se presente
        if (thinkingText) {
          this.createCognitiveProcess({
            sourceId: agent.id,
            type: DialogType.RESEARCH,
            text: thinkingText,
            cognitiveType: CognitiveProcessType.THINKING,
            isLLMDialog: true,
            duration: 4000,
            priority: 6
          });
          
          // Poi mostra il piano dopo un ritardo
          setTimeout(() => {
            this.createCognitiveProcess({
              sourceId: agent.id,
              type: DialogType.RESEARCH,
              text: planText,
              cognitiveType: CognitiveProcessType.PLANNING,
              isLLMDialog: true,
              priority: 8
            });
          }, 4000);
        } else {
          // Mostra solo il piano
          this.createCognitiveProcess({
            sourceId: agent.id,
            type: DialogType.RESEARCH,
            text: planText,
            cognitiveType: CognitiveProcessType.PLANNING,
            isLLMDialog: true,
            priority: 8
          });
        }
      }
    } catch (error) {
      console.error('[DialogController] Error handling agent planning:', error);
    }
  }
  
  /**
   * Gestisce la reazione di un agente a un evento
   */
  private async handleAgentReaction(data: {
    agentId: string;
    eventType: string;
    context: string;
  }): Promise<void> {
    if (!this.isLLMAvailable) {
      await this.checkLLMAvailability();
      if (!this.isLLMAvailable) return;
    }
    
    try {
      const agent = this.getAgentDetails(data.agentId);
      if (!agent) return;
      
      const reactionResult = await api.generateEventReaction({
        agentId: agent.id,
        agentName: agent.name,
        agentRole: agent.role,
        agentSpecialization: agent.specialization || 'general',
        eventType: data.eventType,
        labType: this.getLabTypeString(),
        context: data.context,
        flState: this.getCurrentFLState()
      });
      
      if (reactionResult.reaction) {
        // Estrai processo di pensiero se presente
        let reactionText = reactionResult.reaction;
        let thinkingText = null;
        
        // Cerca pattern come <think>...</think> nella risposta
        const thinkMatch = reactionText.match(/<think>([\s\S]*?)<\/think>/);
        if (thinkMatch) {
          thinkingText = thinkMatch[1].trim();
          // Rimuovi il tag thinking dalla reazione
          reactionText = reactionText.replace(/<think>[\s\S]*?<\/think>/, '').trim();
        }
        
        // Prima mostra il pensiero se presente
        if (thinkingText) {
          this.createCognitiveProcess({
            sourceId: agent.id,
            type: DialogType.GENERAL,
            text: thinkingText,
            cognitiveType: CognitiveProcessType.THINKING,
            isLLMDialog: true,
            duration: 3000,
            priority: 7
          });
          
          // Poi mostra la reazione come dialogo normale
          setTimeout(() => {
            this.createDialog({
              sourceId: agent.id,
              type: this.getDialogTypeForRole(agent.role),
              text: reactionText,
              isLLMDialog: true,
              showEffect: true,
              priority: 9
            });
          }, 3000);
        } else {
          // Mostra solo la reazione
          this.createDialog({
            sourceId: agent.id,
            type: this.getDialogTypeForRole(agent.role),
            text: reactionText,
            isLLMDialog: true,
            showEffect: true,
            priority: 9
          });
        }
      }
    } catch (error) {
      console.error('[DialogController] Error handling agent reaction:', error);
    }
  }
  
  /**
   * Gestisce eventi relativi al federated learning
   */
  private async handleFLEvent(data: {
    eventType: string;
    context: string;
    agentIds?: string[];
  }): Promise<void> {
    if (!this.isLLMAvailable) {
      await this.checkLLMAvailability();
      if (!this.isLLMAvailable) return;
    }
    
    try {
      // Se non sono specificati agenti, seleziona agenti casuali
      const agentIds = data.agentIds || this.selectRandomAgents(2);
      
      // Genera reazioni per ciascun agente
      for (const agentId of agentIds) {
        this.handleAgentReaction({
          agentId,
          eventType: data.eventType,
          context: data.context
        });
        
        // Aggiungi ritardo tra le reazioni
        await new Promise(resolve => setTimeout(resolve, 1000));
      }
    } catch (error) {
      console.error('[DialogController] Error handling FL event:', error);
    }
  }
  
  /**
   * Gestisce l'inizio del training FL
   */
  private handleFLTrainingStarted(data: {
    context: string;
    rounds: number;
    clientsCount: number;
  }): void {
    if (this.debugMode) {
      console.log('[DialogController] FL Training Started:', data);
    }
    
    // Seleziona un agente casuale per commentare l'inizio del training
    const agent = this.getRandomAgentByRole('researcher');
    if (agent) {
      this.handleAgentReaction({
        agentId: agent.id,
        eventType: 'training_started',
        context: `Training started with ${data.clientsCount} clients and ${data.rounds} rounds. ${data.context}`
      });
    }
  }
  
  /**
   * Gestisce il completamento di un round FL
   */
  private handleFLRoundCompleted(data: {
    context: string;
    round: number;
    totalRounds: number;
    accuracy: number;
    loss: number;
  }): void {
    if (this.debugMode) {
      console.log('[DialogController] FL Round Completed:', data);
    }
    
    // Se siamo a metà del training o alla fine, genera una reazione
    if (data.round === Math.floor(data.totalRounds / 2) || 
        data.round === data.totalRounds - 1) {
      
      // Seleziona un agente casuale per commentare i progressi
      const agent = this.getRandomAgentByRole('researcher');
      if (agent) {
        this.handleAgentReaction({
          agentId: agent.id,
          eventType: 'round_completed',
          context: `Round ${data.round + 1}/${data.totalRounds} completed. 
                   Accuracy: ${(data.accuracy * 100).toFixed(2)}%, 
                   Loss: ${data.loss.toFixed(4)}. ${data.context}`
        });
      }
    }
  }
  
  /**
   * Gestisce la selezione di un client per il round FL
   */
  private handleFLClientSelected(data: {
    context: string;
    agentId: string;
    round: number;
  }): void {
    if (this.debugMode) {
      console.log('[DialogController] FL Client Selected:', data);
    }
    
    // L'agente selezionato esprime la sua reazione
    this.handleAgentReaction({
      agentId: data.agentId,
      eventType: 'client_selected',
      context: `Selected as client for round ${data.round + 1}. ${data.context}`
    });
  }
  
  /**
   * Gestisce una violazione della privacy
   */
  private handleFLPrivacyBreach(data: {
    context: string;
    severity: 'low' | 'medium' | 'high';
    affectedAgentId?: string;
  }): void {
    if (this.debugMode) {
      console.log('[DialogController] FL Privacy Breach:', data);
    }
    
    // Seleziona uno specialista della privacy per commentare
    const agent = this.getRandomAgentByRole('privacy_specialist') || 
                this.getRandomAgentByRole('researcher');
    
    if (agent) {
      // Prepara contesto basato sulla gravità
      let severityContext = "";
      switch (data.severity) {
        case 'high':
          severityContext = "Critical privacy breach detected! Immediate action required.";
          break;
        case 'medium':
          severityContext = "Moderate privacy leak detected. Protocol review needed.";
          break;
        case 'low':
          severityContext = "Minor privacy concern detected. Monitoring the situation.";
          break;
      }
      
      this.handleAgentReaction({
        agentId: agent.id,
        eventType: 'privacy_breach',
        context: `${severityContext} ${data.context}`
      });
      
      // Se c'è un agente specificamente colpito, mostra anche la sua reazione
      if (data.affectedAgentId) {
        setTimeout(() => {
          this.handleAgentReaction({
            agentId: data.affectedAgentId!,
            eventType: 'privacy_affected',
            context: `My data privacy may have been compromised. ${data.context}`
          });
        }, 3000);
      }
    }
  }
  
  /**
   * Gestisce il raggiungimento della convergenza
   */
  private handleFLConvergenceReached(data: {
    context: string;
    rounds: number;
    finalAccuracy: number;
  }): void {
    if (this.debugMode) {
      console.log('[DialogController] FL Convergence Reached:', data);
    }
    
    // Celebra il successo con almeno due agenti
    const agentIds = this.selectRandomAgents(2);
    
    // Prepara un contesto più dettagliato
    const enrichedContext = `Model has converged after ${data.rounds} rounds with ${(data.finalAccuracy * 100).toFixed(2)}% 
                            accuracy. ${data.context}`;
    
    // Genera reazioni di celebrazione
    agentIds.forEach((agentId, index) => {
      setTimeout(() => {
        this.handleAgentReaction({
          agentId,
          eventType: 'convergence_reached',
          context: enrichedContext
        });
      }, index * 3000); // Mostra reazioni in sequenza
    });
  }
  
  /**
   * Ottiene un agente casuale con un determinato ruolo
   */
  private getRandomAgentByRole(role: string): any {
    try {
      const agents = this.scene.children.getChildren()
        .filter((child: any) => {
          if (!child.getData) return false;
          const agentRole = child.getData('role') || child.getData('type');
          return agentRole && agentRole.toLowerCase() === role.toLowerCase();
        });
      
      if (agents.length === 0) return null;
      
      const randomIndex = Math.floor(Math.random() * agents.length);
      const agent = agents[randomIndex];
      
      return {
        id: agent.getData('id'),
        name: agent.getData('name') || 'Unknown Agent',
        role: agent.getData('role') || agent.getData('type') || role,
        specialization: agent.getData('specialization') || 'general'
      };
    } catch (error) {
      console.error(`[DialogController] Error getting random agent by role ${role}:`, error);
      return null;
    }
  }
  
  /**
   * Seleziona un numero casuale di agenti dalla scena
   */
  private selectRandomAgents(count: number = 1): string[] {
    try {
      // Trova tutti gli agenti nella scena
      const agents = this.scene.children.getChildren()
        .filter((child: any) => child.getData && child.getData('id'));
      
      // Mescola e prendi il numero richiesto
      return agents
        .sort(() => 0.5 - Math.random())
        .slice(0, count)
        .map((agent: any) => agent.getData('id'));
    } catch (error) {
      console.error('[DialogController] Error selecting random agents:', error);
      return [];
    }
  }
  
  /**
   * Crea dialoghi predefiniti per un'interazione
   */
  private createPresetDialogForInteraction(
    agent1: any,
    agent2: any,
    interactionType: string
  ): void {
    // Crea dialogo per il primo agente
    this.createDialog({
      sourceId: agent1.id,
      targetId: agent2.id,
      type: this.getDialogTypeForRole(agent1.role),
      text: this.getPresetDialog(agent1.role, interactionType),
      showEffect: true,
      priority: 5
    });
    
    // Ritardo per il secondo dialogo
    setTimeout(() => {
      this.createDialog({
        sourceId: agent2.id,
        targetId: agent1.id,
        type: this.getDialogTypeForRole(agent2.role),
        text: this.getPresetDialog(agent2.role, interactionType),
        showEffect: false,
        priority: 5
      });
    }, 1500);
  }
  
  /**
   * Ottiene lo stato corrente del FL
   */
  private getCurrentFLState(): any {
    try {
      // Cerca il controller FL nella scena
      const flController = (this.scene as any).flController;
      if (flController && flController.getState) {
        return flController.getState();
      }
    } catch (error) {
      console.warn('[DialogController] Error getting FL state:', error);
    }
    
    return null;
  }
  
  /**
   * Ottiene il tipo di laboratorio come stringa
   */
  private getLabTypeString(): string {
    if (!this.labTheme) return 'default';
    
    if (this.labTheme.name.includes('Mercatorum')) {
      return 'mercatorum';
    } else if (this.labTheme.name.includes('Blekinge')) {
      return 'blekinge';
    } else if (this.labTheme.name.includes('OPBG') || this.labTheme.name.includes('Bambino Gesù')) {
      return 'opbg';
    }
    
    return 'default';
  }
  
  /**
   * Ottiene dettagli di un agente dall'ID
   */
  private getAgentDetails(agentId: string): any {
    try {
      const agents = this.scene.children.getChildren()
        .filter((child: any) => 
          (child.getData && child.getData('id') === agentId) || 
          (child.getId && child.getId() === agentId)
        );
      
      if (agents.length > 0) {
        const agent = agents[0] as any;
        return {
          id: agentId,
          name: agent.name || agent.getData('name') || 'Unknown Agent',
          role: agent.role || agent.getData('role') || agent.type || agent.getData('type') || 'researcher',
          specialization: agent.specialization || agent.getData('specialization') || 'general',
          x: agent.x,
          y: agent.y
        };
      }
    } catch (error) {
      console.error(`[DialogController] Error getting agent details for ${agentId}:`, error);
    }
    
    return null;
  }

  /**
   * Ottiene il tipo di dialogo in base al ruolo dell'agente
   */
  private getDialogTypeForRole(role: string): DialogType {
    // Mapping semplificato dei ruoli ai tipi di dialogo
    const roleToTypeMap: { [key: string]: DialogType } = {
      'professor': DialogType.RESEARCH,
      'researcher': DialogType.RESEARCH,
      'phd_student': DialogType.RESEARCH,
      'student': DialogType.RESEARCH,
      'doctor': DialogType.DATA,
      'engineer': DialogType.MODEL,
      'ml_engineer': DialogType.MODEL,
      'data_engineer': DialogType.DATA,
      'privacy_specialist': DialogType.PRIVACY
    };
    
    // Ottieni il tipo di dialogo basato sul ruolo o usa GENERAL come default
    return roleToTypeMap[role.toLowerCase()] || DialogType.GENERAL;
  }

  /**
   * Attiva/disattiva la modalità debug
   */
  setDebugMode(enabled: boolean): void {
    this.debugMode = enabled;
    localStorage.setItem('dialog_debug', String(enabled));
    
    if (this.debugMode) {
      console.log('[DialogController] Debug mode enabled');
    }
  }

  /**
   * Crea un dialogo normale tra agenti
   */
  createDialog(config: DialogConfig): void {
    // Aggiungi il dialogo alla coda
    this.dialogQueue.push(config);
    
    if (this.debugMode) {
      console.log(`[DialogController] Dialog queued: ${config.type} from ${config.sourceId} to ${config.targetId || 'broadcast'}`);
    }
    
    // Se non stiamo già processando la coda, iniziamo
    if (!this.isProcessingQueue) {
      this.processDialogQueue();
    }
  }
  
  /**
   * Crea un processo cognitivo (pensiero, decisione, piano)
   */
  createCognitiveProcess(config: DialogConfig): void {
    // Se non è specificato un tipo cognitivo, usa THINKING come default
    if (!config.cognitiveType) {
      config.cognitiveType = CognitiveProcessType.THINKING;
    }
    
    // Genera un ID univoco per processi cognitivi che non sono attribuiti a un agente specifico
    // (utile per rappresentare "pensieri del sistema")
    if (!config.sourceId || config.sourceId === 'system') {
      config.sourceId = `cognitive_${this.cognitiveProcessCounter++}`;
    }
    
    // Aggiungi alla coda
    this.dialogQueue.push(config);
    
    if (this.debugMode) {
      console.log(`[DialogController] Cognitive process queued: ${config.cognitiveType} for ${config.sourceId}`);
    }
    
    // Se non stiamo già processando la coda, iniziamo
    if (!this.isProcessingQueue) {
      this.processDialogQueue();
    }
  }

  /**
   * Processa la coda dei dialoghi
   */
  private processDialogQueue(): void {
    if (this.dialogQueue.length === 0) {
      this.isProcessingQueue = false;
      return;
    }
    
    this.isProcessingQueue = true;
    
    // Ordina la coda per priorità (se definita)
    this.dialogQueue.sort((a, b) => {
      const priorityA = a.priority !== undefined ? a.priority : 5;
      const priorityB = b.priority !== undefined ? b.priority : 5;
      return priorityB - priorityA; // Ordine decrescente (priorità più alta prima)
    });
    
    const dialog = this.dialogQueue.shift();
    
    if (!dialog) {
      this.isProcessingQueue = false;
      return;
    }
    
    // Ottieni le posizioni degli agenti coinvolti
    const sourcePosition = this.getAgentPosition(dialog.sourceId);
    
    // Se non possiamo trovare la posizione, ma è un processo cognitivo "di sistema",
    // creiamo una posizione al centro della scena
    if (!sourcePosition && dialog.sourceId.startsWith('cognitive_')) {
      const cameraCenter = {
        x: this.scene.cameras.main.centerX,
        y: this.scene.cameras.main.centerY
      };
      this.showCognitiveProcess(dialog, cameraCenter, null);
    } else if (!sourcePosition) {
      console.warn(`[DialogController] Could not find agent with ID ${dialog.sourceId}`);
      this.processDialogQueue(); // Passa al dialogo successivo
      return;
    } else {
      let targetPosition = null;
      if (dialog.targetId) {
        targetPosition = this.getAgentPosition(dialog.targetId);
        if (!targetPosition && this.debugMode) {
          console.warn(`[DialogController] Could not find target agent with ID ${dialog.targetId}`);
        }
      }
      
      // Decide se mostrare un processo cognitivo o un dialogo normale
      if (dialog.cognitiveType) {
        this.showCognitiveProcess(dialog, sourcePosition, targetPosition);
      } else {
        this.showSpeechBubble(dialog, sourcePosition, targetPosition);
      }
      
      // Mostra effetti visivi se richiesto
      if (dialog.showEffect) {
        this.showDialogEffect(dialog.type, sourcePosition, targetPosition);
      }
    }
    
    // Calcola la durata in base alla lunghezza del testo se non specificata
    const duration = dialog.duration || Math.min(2000 + dialog.text.length * 30, 8000);
    
    // Programma la rimozione della bolla e il passaggio al dialogo successivo
    this.scene.time.delayedCall(duration, () => {
      this.removeBubble(dialog.sourceId);
      
      if (dialog.callback) {
        dialog.callback();
      }
      
      // Piccolo ritardo prima del prossimo dialogo
      this.scene.time.delayedCall(300, () => {
        this.processDialogQueue();
      });
    });
  }
  
  /**
   * Mostra un processo cognitivo (pensiero, decisione, piano)
   */
  private showCognitiveProcess(
    dialog: DialogConfig,
    sourcePos: { x: number, y: number },
    targetPos: { x: number, y: number } | null
  ): void {
    // Se c'è già una bolla attiva per questo agente, la rimuoviamo
    if (this.activeBubbles.has(dialog.sourceId)) {
      this.removeBubble(dialog.sourceId);
    }
    
    try {
      let bubble;
      
      // Crea il tipo appropriato di bolla in base al processo cognitivo
      switch(dialog.cognitiveType) {
        case CognitiveProcessType.THINKING:
          bubble = new ThoughtBubble(
            this.scene,
            sourcePos.x,
            sourcePos.y - 40, // Posiziona sopra l'agente
            dialog.text,
            dialog.type,
            {
              width: 180,
              padding: 8,
              isLLMGenerated: dialog.isLLMDialog || false
            }
          );
          break;
          
        case CognitiveProcessType.DECISION:
          bubble = new DecisionBubble(
            this.scene,
            sourcePos.x,
            sourcePos.y - 40, // Posiziona sopra l'agente
            dialog.text,
            dialog.type,
            {
              width: 180,
              padding: 8,
              isLLMGenerated: dialog.isLLMDialog || false
            }
          );
          break;
          
        case CognitiveProcessType.PLANNING:
          bubble = new DecisionBubble( // Usa DecisionBubble anche per il piano, ma con stile diverso
            this.scene,
            sourcePos.x,
            sourcePos.y - 40, // Posiziona sopra l'agente
            dialog.text,
            dialog.type,
            {
              width: 200,  // Più ampia per contenere i piani
              padding: 10,
              isLLMGenerated: dialog.isLLMDialog || false,
              isPlan: true  // Flag speciale per lo stile del piano
            }
          );
          break;
          
        default:
          // Per qualsiasi altro tipo, usa una ThoughtBubble generica
          bubble = new ThoughtBubble(
            this.scene, 
            sourcePos.x, 
            sourcePos.y - 40,
            dialog.text,
            dialog.type,
            {
              width: 160,
              padding: 8,
              isLLMGenerated: dialog.isLLMDialog || false
            }
          );
      }
      
      // Aggiungila alla mappa delle bolle attive
      this.activeBubbles.set(dialog.sourceId, bubble);
      
      if (this.debugMode) {
        console.log(`[DialogController] Cognitive process created for ${dialog.sourceId}: ${dialog.cognitiveType}`);
      }
    } catch (error) {
      console.error('[DialogController] Error creating cognitive process:', error);
    }
  }

  /**
   * Mostra una bolla di dialogo
   */
  private showSpeechBubble(
    dialog: DialogConfig,
    sourcePos: { x: number, y: number },
    targetPos: { x: number, y: number } | null
  ): void {
    // Se c'è già una bolla attiva per questo agente, la rimuoviamo
    if (this.activeBubbles.has(dialog.sourceId)) {
      this.removeBubble(dialog.sourceId);
    }
    
    try {
      // Crea una nuova bolla di dialogo
      const bubble = new SpeechBubble(
        this.scene,
        sourcePos.x,
        sourcePos.y - 40, // Posiziona sopra l'agente
        dialog.text,
        dialog.type,
        {
          width: 160,
          padding: 8,
          targetPos: targetPos ? { x: targetPos.x, y: targetPos.y } : undefined,
          isLLMDialog: dialog.isLLMDialog || false  // Passa il flag LLM
        }
      );
      
      // Aggiungila alla mappa delle bolle attive
      this.activeBubbles.set(dialog.sourceId, bubble);
      
      if (this.debugMode) {
        console.log(`[DialogController] Speech bubble created for ${dialog.sourceId}`);
        if (dialog.isLLMDialog) {
          console.log(`[DialogController] Dialog is LLM-generated`);
        }
      }
    } catch (error) {
      console.error('[DialogController] Error creating speech bubble:', error);
    }
  }

  /**
   * Rimuove qualsiasi tipo di bolla
   */
  removeBubble(agentId: string): void {
    const bubble = this.activeBubbles.get(agentId);
    if (bubble) {
      bubble.destroy();
      this.activeBubbles.delete(agentId);
      
      if (this.debugMode) {
        console.log(`[DialogController] Bubble removed for ${agentId}`);
      }
    }
  }
  
  /**
   * Rimuove tutte le bolle
   */
  removeAllBubbles(): void {
    this.activeBubbles.forEach((bubble, id) => {
      bubble.destroy();
    });
    
    this.activeBubbles.clear();
    this.dialogQueue = [];
    this.isProcessingQueue = false;
    
    if (this.debugMode) {
      console.log('[DialogController] All bubbles removed');
    }
  }

  /**
   * Ottiene la posizione di un agente dal suo ID
   */
  private getAgentPosition(agentId: string): { x: number, y: number } | null {
    try {
      // Se l'ID inizia con "cognitive_", è un processo cognitivo "di sistema"
      if (agentId.startsWith('cognitive_')) {
        return {
          x: this.scene.cameras.main.centerX,
          y: this.scene.cameras.main.centerY
        };
      }
      
      // Cerca l'agente nella scena
      const agent = this.scene.children.getChildren()
        .find((child: Phaser.GameObjects.GameObject) => {
          return (child.getData && 
                 child.getData('id') === agentId) || 
                 ((child as any).getId && 
                 (child as any).getId() === agentId);
        });
      
      if (agent && 'x' in agent && 'y' in agent) {
        return { x: agent.x as number, y: agent.y as number };
      }
    } catch (error) {
      console.error(`[DialogController] Error getting agent position for ${agentId}:`, error);
    }
    
    return null;
  }

  /**
   * Ottiene un dialogo predefinito in base al ruolo e tipo di interazione
   */
  private getPresetDialog(role: string, interactionType: string): string {
    const dialogs: { [key: string]: string[] } = {
      'professor': [
        "Let's analyze this research approach.",
        "I've been working on a new theoretical model.",
        "What do you think about differential privacy?",
        "Have you seen the latest federated learning paper?",
        "This algorithm shows promising convergence properties."
      ],
      'researcher': [
        "I'm working on optimizing client selection.",
        "My experiments show interesting non-IID behavior.",
        "Let's collaborate on model compression techniques.",
        "Communication efficiency is the key challenge here.",
        "I've found a way to reduce the privacy budget."
      ],
      'phd_student': [
        "I'm implementing a new aggregation method.",
        "Could you review my experimental design?",
        "The data heterogeneity is causing issues.",
        "My literature review found some gaps in this area.",
        "I'm trying to reproduce those benchmark results."
      ],
      'student': [
        "I'm implementing a new aggregation method.",
        "Could you review my experimental design?",
        "The data heterogeneity is causing issues.",
        "My literature review found some gaps in this area.",
        "I'm trying to reproduce those benchmark results."
      ],
      'doctor': [
        "Patient privacy must be our first priority.",
        "This diagnostic model shows promising results.",
        "We need more diverse medical data.",
        "The ethical implications are significant.",
        "Federated learning could transform clinical research."
      ],
      'engineer': [
        "I've optimized the system throughput.",
        "The deployment pipeline is almost ready.",
        "Let's benchmark against the baseline.",
        "We need more efficient resource allocation.",
        "I've implemented the compression algorithm."
      ],
      'privacy_specialist': [
        "This approach leaks too much information.",
        "Let's analyze the privacy guarantees.",
        "We need to increase the noise parameter.",
        "The attack surface can be reduced.",
        "I've developed a new secure aggregation protocol."
      ]
    };
    
    // Ottieni i dialoghi per il ruolo, o usa quelli generici
    const roleDialogs = dialogs[role.toLowerCase()] || dialogs['researcher'];
    
    // Scegli un dialogo casuale
    const randomIndex = Math.floor(Math.random() * roleDialogs.length);
    return roleDialogs[randomIndex];
  }

  /**
   * Mostra effetti visivi basati sul tipo di dialogo
   */
  private showDialogEffect(
    type: DialogType,
    sourcePos: { x: number, y: number },
    targetPos: { x: number, y: number } | null
  ): void {
    try {
      if (!targetPos) return;
      
      switch (type) {
        case DialogType.MODEL:
          this.showModelEffect(sourcePos.x, sourcePos.y);
          break;
        case DialogType.DATA:
          this.showDataEffect(sourcePos.x, sourcePos.y, targetPos.x, targetPos.y);
          break;
        case DialogType.PRIVACY:
          this.showPrivacyEffect(sourcePos.x, sourcePos.y);
          break;
        case DialogType.RESEARCH:
          this.showResearchEffect(sourcePos.x, sourcePos.y);
          break;
      }
    } catch (error) {
      console.warn('Error showing dialog effect:', error);
      // Continuiamo l'esecuzione anche in caso di errore nell'effetto visivo
    }
  }

  /**
   * Effetto visivo per dialoghi di tipo MODEL
   */
  private showModelEffect(x: number, y: number): void {
    // Crea un sistema di particelle per l'effetto
    const particles = this.scene.add.particles('model-particle');
    if (!particles) return;
    
    // Definisci la dimensione del cerchio prima di usarla
    const radius = 40;
    const duration = 2000;
    
    const emitter = particles.createEmitter({
      blendMode: 'ADD',
      tint: 0x00ff88
    });
    
    // Configura l'emettitore per un effetto circolare
    emitter.x = x;
    emitter.y = y;
    emitter.speed = 80;
    emitter.emitZone = {
      type: 'edge',
      source: new Phaser.Geom.Circle(0, 0, radius),
      quantity: 32,
      yoyo: false
    };
    
    // Attiva l'emettitore
    emitter.start();
    
    // Imposta un timer per fermarlo e pulire
    this.scene.time.delayedCall(duration, () => {
      emitter.stop();
      this.scene.time.delayedCall(1500, () => {
        particles.destroy();
      });
    });
  }

  /**
   * Effetto visivo per dialoghi di tipo PRIVACY
   */
  private showPrivacyEffect(x: number, y: number): void {
    // Crea un sistema di particelle per l'effetto
    const particles = this.scene.add.particles('privacy-particle');
    if (!particles) return;
    
    const emitter = particles.createEmitter({
      blendMode: 'ADD',
      tint: 0xaa44ff
    });
    
    // Imposta l'emettitore
    emitter.x = x;
    emitter.y = y;
    emitter.scale = { start: 0.6, end: 0 };
    emitter.speed = 60;
    emitter.lifespan = 800;

    // Crea un effetto di scudo/protezione
    const shield = this.scene.add.graphics();
    shield.lineStyle(2, 0xaa44ff, 0.8);
    shield.strokeCircle(x, y, 30);
    
    // Attiva l'emettitore
    emitter.start();
    
    // Imposta l'animazione dello scudo
    this.scene.tweens.add({
      targets: shield,
      alpha: { from: 0.8, to: 0 },
      duration: 1800,
      ease: 'Power2',
      onComplete: () => {
        shield.destroy();
        emitter.stop();
        this.scene.time.delayedCall(1000, () => {
          particles.destroy();
        });
      }
    });
  }

  /**
   * Effetto visivo per dialoghi di tipo RESEARCH
   */
  private showResearchEffect(x: number, y: number): void {
    // Crea un sistema di particelle per l'effetto
    const particles = this.scene.add.particles('research-particle');
    if (!particles) return;
    
    const emitter = particles.createEmitter({
      blendMode: 'ADD',
      tint: 0xff8800
    });
    
    // Configura l'emettitore per convergere verso il centro
    emitter.x = x;
    emitter.y = y;
    emitter.speed = { min: 80, max: 120 };
    emitter.scale = { start: 0.2, end: 0.5 };
    emitter.lifespan = 1000;
    emitter.emitZone = {
      type: 'edge',
      source: new Phaser.Geom.Circle(0, 0, 100),
      quantity: 24,
      yoyo: false
    };
    
    // Imposta la direzione delle particelle verso il centro
    emitter.emitAngle = {
      min: 0,
      max: 360
    };
    
    // Anima le particelle verso il centro
    emitter.gravityX = (x - emitter.x) * -1;
    emitter.gravityY = (y - emitter.y) * -1;

    // Attiva l'emettitore
    emitter.start();
    
    // Imposta un timer per fermarlo e pulire
    this.scene.time.delayedCall(2000, () => {
      emitter.stop();
      this.scene.time.delayedCall(1000, () => {
        particles.destroy();
      });
    });
  }

  /**
   * Effetto visivo per dialoghi di tipo DATA
   */
  private showDataEffect(sourceX: number, sourceY: number, targetX: number, targetY: number): void {
    // Crea un sistema di particelle per l'effetto
    const particles = this.scene.add.particles('data-particle');
    if (!particles) return;
    
    const emitter = particles.createEmitter({
      blendMode: 'ADD',
      tint: 0x0088ff
    });
    
    // Calcola l'angolo tra i due punti
    const angle = Phaser.Math.Angle.Between(sourceX, sourceY, targetX, targetY);
    
    // Attiva l'emettitore alla posizione di partenza
    emitter.x = sourceX;
    emitter.y = sourceY;
    emitter.angle = Phaser.Math.RadToDeg(angle);
    emitter.speed = 100;
    
    // Calcola la distanza per regolare la durata della vita delle particelle
    const distance = Phaser.Math.Distance.Between(sourceX, sourceY, targetX, targetY);
    const particleLifespan = Math.min(distance * 10, 2000); // Proporzionale alla distanza
    
    emitter.lifespan = particleLifespan;
    emitter.quantity = 2;
    emitter.frequency = 100;
    
    // Attiva l'emettitore
    emitter.start();
    
    // Imposta un timer per fermarlo e pulire
    this.scene.time.delayedCall(particleLifespan + 500, () => {
      emitter.stop();
      this.scene.time.delayedCall(1000, () => {
        particles.destroy();
      });
    });
  }

  /**
   * Aggiorna lo stato delle bolle attive
   */
  update(time: number, delta: number): void {
    // Aggiorna la posizione delle bolle basate sugli agenti
    this.activeBubbles.forEach((bubble, agentId) => {
      // Salta gli ID che iniziano con "cognitive_" (processi di sistema)
      if (agentId.startsWith('cognitive_')) return;
      
      const agentPos = this.getAgentPosition(agentId);
      if (agentPos && bubble.updatePosition) {
        bubble.updatePosition(agentPos.x, agentPos.y - 40);
      }
    });
  }

  /**
   * Pulisce tutte le bolle e le risorse quando si chiude la scena
   */
  destroy(): void {
    // Rimuovi tutte le bolle attive
    this.activeBubbles.forEach((bubble, id) => {
      bubble.destroy();
    });
    
    // Rimuovi event listeners
    const gameEvents = this.scene.game.events;
    gameEvents.off('agent-interaction', this.handleAgentInteraction, this);
    gameEvents.off('agent-thinking', this.handleAgentThinking, this);
    gameEvents.off('agent-decision', this.handleAgentDecision, this);
    gameEvents.off('agent-planning', this.handleAgentPlanning, this);
    gameEvents.off('agent-reaction', this.handleAgentReaction, this);
    gameEvents.off('fl-event', this.handleFLEvent, this);
    
    // Rimuovi eventi FL specifici
    gameEvents.off('fl-training-started', this.handleFLTrainingStarted, this);
    gameEvents.off('fl-round-completed', this.handleFLRoundCompleted, this);
    gameEvents.off('fl-client-selected', this.handleFLClientSelected, this);
    gameEvents.off('fl-privacy-breach', this.handleFLPrivacyBreach, this);
    gameEvents.off('fl-convergence-reached', this.handleFLConvergenceReached, this);
    
    this.activeBubbles.clear();
    this.dialogQueue = [];
    this.isProcessingQueue = false;
    
    if (this.debugMode) {
      console.log('[DialogController] Destroyed all dialog resources');
    }
  }
}