// frontend/src/phaser/controllers/DialogController.ts

import Phaser from 'phaser';
import { SpeechBubble } from '../ui/SpeechBubble';
import { FLDialogType, FL_DIALOG_TEMPLATES } from '../types/DialogTypes';
import { Agent } from '../sprites/Agent';

export class DialogController {
    private scene: Phaser.Scene;
    private bubbles: Map<string, SpeechBubble> = new Map();
    private minDialogInterval: number = 2000; // Min time between dialogs in ms
    private lastDialogTime: number = 0;
    private agentMap: Map<string, Agent> = new Map();
    
    constructor(scene: Phaser.Scene) {
        this.scene = scene;
        console.log('DialogController initialized');
    }
    
    /**
     * Registra un agente con il controller e crea una speech bubble per lui
     */
    registerAgent(agent: Agent): void {
        if (!agent || !agent.sprite) {
            console.warn('Cannot register agent: agent or sprite is null');
            return;
        }
        
        const agentId = agent.getId();
        
        // Store reference to agent
        this.agentMap.set(agentId, agent);
        
        // Create a speech bubble for this agent
        const bubble = new SpeechBubble(this.scene, agent.sprite);
        this.bubbles.set(agentId, bubble);
        
        console.log(`Agent ${agentId} registered with DialogController`);
    }
    
    /**
     * Rimuove un agente dal controller
     */
    unregisterAgent(agentId: string): void {
        const bubble = this.bubbles.get(agentId);
        if (bubble) {
            bubble.destroy();
            this.bubbles.delete(agentId);
        }
        
        this.agentMap.delete(agentId);
        console.log(`Agent ${agentId} unregistered from DialogController`);
    }
    
    /**
     * Mostra un dialogo per un agente specifico
     */
    showDialog(agentId: string, message: string, type: FLDialogType = FLDialogType.GENERAL, duration: number = 3000): void {
        const bubble = this.bubbles.get(agentId);
        if (bubble) {
            bubble.show(message, duration, type);
            console.log(`Showing dialog for agent ${agentId}: "${message}"`);
        } else {
            console.warn(`No bubble found for agent ${agentId}`);
        }
    }
    
    /**
     * Mostra un dialogo casuale per un agente specifico basato sul tipo
     */
    showRandomDialog(agentId: string, type: FLDialogType = FLDialogType.GENERAL, duration: number = 3000): void {
        const messages = FL_DIALOG_TEMPLATES[type];
        if (!messages || messages.length === 0) {
            console.warn(`No messages found for dialog type ${type}`);
            return;
        }
        
        // Pick a random message
        const randomIndex = Math.floor(Math.random() * messages.length);
        const message = messages[randomIndex];
        
        this.showDialog(agentId, message, type, duration);
    }
    
    /**
     * Avvia un dialogo tra due agenti (quando comunicano per FL)
     * Ritorna true se il dialogo è avvenuto, false se troppo recente
     */
    startAgentDialog(sourceId: string, targetId: string, type: FLDialogType): boolean {
        const now = Date.now();
        // Check if enough time has passed since last dialog
        if (now - this.lastDialogTime < this.minDialogInterval) {
            console.log(`Dialog too soon, skipping (last: ${now - this.lastDialogTime}ms ago)`);
            return false;
        }
        
        this.lastDialogTime = now;
        
        // Ensure both agents exist
        if (!this.bubbles.has(sourceId)) {
            console.warn(`Source agent ${sourceId} not found for dialog`);
            return false;
        }
        
        if (!this.bubbles.has(targetId)) {
            console.warn(`Target agent ${targetId} not found for dialog`);
            return false;
        }
        
        // Show dialog for both agents with different durations to create conversation effect
        this.showRandomDialog(sourceId, type, 3000);
        
        // Delay the second message slightly to create a conversation feel
        this.scene.time.delayedCall(800, () => {
            this.showRandomDialog(targetId, type, 3000);
        });
        
        console.log(`Started dialog between agents ${sourceId} and ${targetId} of type ${type}`);
        return true;
    }
    
    /**
     * Genera dialoghi casuali per simulare un ambiente attivo
     */
    generateRandomDialog(chance: number = 0.02): void {
        // Solo una piccola possibilità che avvenga un dialogo casuale
        if (Math.random() > chance) return;
        
        // Ottenere tutti gli agenti registrati come array
        const agentIds = Array.from(this.bubbles.keys());
        
        // Se non ci sono abbastanza agenti, esci
        if (agentIds.length < 2) return;
        
        // Scegli due agenti casuali diversi
        const randomSourceIndex = Math.floor(Math.random() * agentIds.length);
        let randomTargetIndex;
        do {
            randomTargetIndex = Math.floor(Math.random() * agentIds.length);
        } while (randomTargetIndex === randomSourceIndex);
        
        const sourceId = agentIds[randomSourceIndex];
        const targetId = agentIds[randomTargetIndex];
        
        // Scegli un tipo di dialogo casuale
        const dialogTypes = Object.values(FLDialogType);
        const randomType = dialogTypes[Math.floor(Math.random() * dialogTypes.length)];
        
        // Avvia il dialogo
        this.startAgentDialog(sourceId, targetId, randomType);
    }
    
    /**
     * Aggiorna tutte le nuvolette di dialogo attive
     */
    update(): void {
        // Aggiorna tutte le bolle
        for (const bubble of this.bubbles.values()) {
            bubble.update();
        }
        
        // Possibilità di generare dialoghi casuali
        this.generateRandomDialog();
    }
    
    /**
     * Distrugge tutte le nuvolette quando si cambia scena
     */
    destroy(): void {
        for (const bubble of this.bubbles.values()) {
            bubble.destroy();
        }
        this.bubbles.clear();
        this.agentMap.clear();
        console.log('DialogController destroyed');
    }
}