import Phaser from 'phaser';
import { WorldMapScene } from '../scenes/WorldMapScene';
import { SCENE_KEYS } from '../game';

/**
 * Interfaccia che definisce i dati di un agente per la visualizzazione sulla mappa mondiale
 */
interface AgentData {
  id: string;
  type: string;
  labScene: string;
  x: number;
  y: number;
}

/**
 * Controller globale per gestire gli agenti nella mappa mondiale.
 * Coordina le informazioni sugli agenti tra i diversi laboratori e aggiorna le miniature.
 */
export class GlobalAgentController {
  private scene: WorldMapScene;
  private agents: AgentData[] = [];
  private agentUpdateInterval: number = 0;
  
  constructor(scene: WorldMapScene) {
    this.scene = scene;
  }
  
  /**
   * Inizializza il controller globale degli agenti
   */
  initialize(): void {
    console.log("GlobalAgentController: Initializing");
    
    // Carica i dati iniziali degli agenti da tutti i laboratori
    this.loadAgentsData();
    
    // Imposta un intervallo per aggiornare periodicamente la posizione degli agenti
    this.agentUpdateInterval = window.setInterval(() => {
      this.updateAgentsData();
    }, 2000); // Aggiorna ogni 2 secondi
  }
  
  /**
   * Aggiorna la visualizzazione degli agenti a ogni frame
   */
  update(time: number, delta: number): void {
    // Questo metodo potrebbe essere usato per animazioni fluide
    // o aggiornamenti che devono avvenire a ogni frame
  }
  
  /**
   * Pulisce le risorse quando il controller non è più necessario
   */
  destroy(): void {
    console.log("GlobalAgentController: Cleaning up");
    
    // Pulisci le risorse quando il controller non è più necessario
    if (this.agentUpdateInterval) {
      clearInterval(this.agentUpdateInterval);
    }
  }
  
  /**
   * Carica i dati iniziali degli agenti dai laboratori
   */
  private loadAgentsData(): void {
    console.log("GlobalAgentController: Loading initial agent data");
    
    // In una implementazione reale, questi dati potrebbero provenire
    // da un'API o dallo store React/Redux
    
    // Dati di esempio per agenti del laboratorio Mercatorum
    const mercatorumAgents = [
      { id: 'prof1', type: 'professor', labScene: SCENE_KEYS.MERCATORUM, x: 200, y: 300 },
      { id: 'res1', type: 'researcher', labScene: SCENE_KEYS.MERCATORUM, x: 500, y: 250 },
      { id: 'stu1', type: 'phd_student', labScene: SCENE_KEYS.MERCATORUM, x: 350, y: 400 },
    ];
    
    // Dati di esempio per agenti del laboratorio Blekinge
    const blekingeAgents = [
      { id: 'prof2', type: 'professor', labScene: SCENE_KEYS.BLEKINGE, x: 300, y: 200 },
      { id: 'eng1', type: 'ml_engineer', labScene: SCENE_KEYS.BLEKINGE, x: 450, y: 350 },
      { id: 'res2', type: 'researcher', labScene: SCENE_KEYS.BLEKINGE, x: 600, y: 400 },
    ];
    
    // Dati di esempio per agenti del laboratorio OPBG
    const opbgAgents = [
      { id: 'doc1', type: 'doctor', labScene: SCENE_KEYS.OPBG, x: 250, y: 350 },
      { id: 'res3', type: 'researcher', labScene: SCENE_KEYS.OPBG, x: 400, y: 300 },
      { id: 'eng2', type: 'biomedical', labScene: SCENE_KEYS.OPBG, x: 550, y: 250 },
    ];
    
    // Unisci tutti i dati degli agenti
    this.agents = [...mercatorumAgents, ...blekingeAgents, ...opbgAgents];
    
    // Aggiorna la visualizzazione degli agenti nelle miniature
    this.updateLabMiniaturesWithAgents();
  }
  
  /**
   * Aggiorna i dati degli agenti, simulando il movimento
   */
  private updateAgentsData(): void {
    console.log("GlobalAgentController: Updating agent data");
    
    // In una implementazione reale, qui faresti una chiamata API per
    // ottenere i dati aggiornati degli agenti da tutti i laboratori
    
    // Per ora, simuliamo un movimento casuale degli agenti
    this.agents.forEach(agent => {
      agent.x += (Math.random() - 0.5) * 20;
      agent.y += (Math.random() - 0.5) * 20;
      
      // Mantieni gli agenti entro i confini del laboratorio
      agent.x = Math.max(50, Math.min(agent.x, 900));
      agent.y = Math.max(50, Math.min(agent.y, 900));
    });
    
    // Aggiorna la visualizzazione degli agenti nelle miniature
    this.updateLabMiniaturesWithAgents();
  }
  
  /**
   * Aggiorna le miniature dei laboratori con i dati degli agenti
   */
  private updateLabMiniaturesWithAgents(): void {
    console.log("GlobalAgentController: Updating lab miniatures");
    
    // Raggruppa gli agenti per laboratorio
    const mercatorumAgents = this.agents.filter(a => a.labScene === SCENE_KEYS.MERCATORUM);
    const blekingeAgents = this.agents.filter(a => a.labScene === SCENE_KEYS.BLEKINGE);
    const opbgAgents = this.agents.filter(a => a.labScene === SCENE_KEYS.OPBG);
    
    try {
      // Ottieni riferimenti alle miniature dei laboratori dalla scena
      const mercatorumMiniature = this.scene['labMiniatures'].get('mercatorum');
      const blekingeMiniature = this.scene['labMiniatures'].get('blekinge');
      const opbgMiniature = this.scene['labMiniatures'].get('opbg');
      
      // Aggiorna la posizione degli agenti in ciascuna miniatura
      if (mercatorumMiniature && typeof mercatorumMiniature.updateAgentPositions === 'function') {
        mercatorumMiniature.updateAgentPositions(mercatorumAgents);
      } else {
        console.warn("mercatorumMiniature is not available or doesn't have updateAgentPositions method");
      }
      
      if (blekingeMiniature && typeof blekingeMiniature.updateAgentPositions === 'function') {
        blekingeMiniature.updateAgentPositions(blekingeAgents);
      } else {
        console.warn("blekingeMiniature is not available or doesn't have updateAgentPositions method");
      }
      
      if (opbgMiniature && typeof opbgMiniature.updateAgentPositions === 'function') {
        opbgMiniature.updateAgentPositions(opbgAgents);
      } else {
        console.warn("opbgMiniature is not available or doesn't have updateAgentPositions method");
      }
    } catch (error) {
      console.error("Error updating lab miniatures:", error);
    }
  }
}