// frontend/src/phaser/ui/simple/SimpleLLMPanelController.ts

import { SimpleLLMPanelModel, SimpleLLMLogEntry, SimpleLLMModelEventListener } from './SimpleLLMPanelModel';
import { SimpleLLMPanelView } from './SimpleLLMPanelView';
import { DialogController } from '../../controllers/DialogController';

/**
 * Interfaccia per la risposta dell'API di stato LLM
 */
interface LLMStatusResponse {
  available: boolean;
  model?: string;
  message?: string;
}

/**
 * Controller per il pannello di controllo LLM semplificato
 * Gestisce la comunicazione tra il modello e la vista
 */
export class SimpleLLMPanelController {
  private model: SimpleLLMPanelModel;
  private view: SimpleLLMPanelView | null = null;
  private scene: Phaser.Scene;
  private dialogController: DialogController | null = null;
  private apiBaseUrl: string;
  private lastBackendCheck: number = 0;
  private checkInterval: number = 5000;
  private isDestroyed: boolean = false; // Flag per evitare chiamate dopo la distruzione
  private defaultModelInfo: any;
  private updateTimerId: number | null = null;
  
  constructor(scene: Phaser.Scene) {
    this.scene = scene;
    this.model = new SimpleLLMPanelModel();
    this.defaultModelInfo = this.model.getDefaultModelInfo();
    this.apiBaseUrl = this.getApiBaseUrl();
    
    // Inizializza il polling dello stato del backend
    this.startBackendStatusPolling();
  }
  
  /**
   * Imposta la vista 
   */
  public setView(view: SimpleLLMPanelView): void {
    this.view = view;
    
    // Inizializza la vista con i dati dal modello
    this.updateViewFromModel();
    
    // Registra listener per eventi del modello
    this.registerModelEventListeners();
  }
  
  /**
   * Registra i listener per gli eventi del modello
   */
  private registerModelEventListeners(): void {
    const listener: SimpleLLMModelEventListener = (event) => {
      if (!this.view || this.isDestroyed) return;
      
      switch (event.type) {
        case 'toggle-changed':
          this.view.updateToggleState(event.enabled);
          break;
        case 'message-type-changed':
          this.view.updateSelectedMessageType(event.messageType);
          break;
        case 'frequency-changed':
          this.view.updateFrequency(event.frequency);
          break;
        case 'log-updated':
          this.view.updateLogEntries(event.entries);
          break;
        case 'stats-updated':
          this.view.updateStats(event.stats);
          break;
        case 'backend-status-changed':
          this.view.updateBackendStatus(event.connected);
          break;
      }
    };
    
    this.model.addEventListener(listener);
  }
  
  /**
   * Aggiorna tutti i dati della vista dai valori nel modello
   */
  private updateViewFromModel(): void {
    if (!this.view) return;
    
    this.view.updateToggleState(this.model.getIsLLMEnabled());
    this.view.updateSelectedMessageType(this.model.getSelectedMessageType());
    this.view.updateFrequency(this.model.getMessageFrequency());
    this.view.updateLogEntries(this.model.getMessageLog());
    this.view.updateStats(this.model.getStats());
    this.view.updateBackendStatus(this.model.getIsBackendConnected());
  }
  
  /**
   * Ottiene l'URL base dell'API
   */
  private getApiBaseUrl(): string {
    // Cerca di ottenere l'URL base da una variabile di ambiente o config
    const apiUrl = (window as any).API_BASE_URL;
    
    if (apiUrl) {
      return apiUrl;
    }
    
    // Altrimenti, costruisci l'URL in base all'host corrente
    const protocol = window.location.protocol;
    const hostname = window.location.hostname;
    
    // Usa la porta 8091 per lo sviluppo locale
    return `${protocol}//${hostname}:8091`;
  }
  
  /**
   * Avvia il polling dello stato del backend
   */
  private startBackendStatusPolling(): void {
    // Controlla subito la prima volta
    this.checkBackendStatus();
    
    // Imposta un timer per controllare periodicamente
    this.updateTimerId = window.setInterval(() => {
      if (!this.isDestroyed) {
        this.checkBackendStatus();
      }
    }, this.checkInterval);
  }
  
  /**
   * Controlla lo stato del backend
   */
  public async checkBackendStatus(): Promise<boolean> {
    if (this.isDestroyed) return false;
    
    try {
      const now = Date.now();
      // Limita la frequenza dei controlli
      if (now - this.lastBackendCheck < this.checkInterval) {
        return this.model.getIsBackendConnected();
      }
      
      this.lastBackendCheck = now;
      
      // Effettua una chiamata all'API per controllare lo stato del servizio LLM
      const response = await fetch(`${this.apiBaseUrl}/ai/status`, {
        method: 'GET',
        headers: {
          'Content-Type': 'application/json',
        },
        // Aggiungi timeout per evitare attese troppo lunghe
        signal: AbortSignal.timeout(3000)
      });
      
      if (response.ok) {
        const data = await response.json() as LLMStatusResponse;
        const isConnected = data.available;
        
        // Aggiorna il modello solo se lo stato è cambiato
        if (isConnected !== this.model.getIsBackendConnected()) {
          this.model.setIsBackendConnected(isConnected);
          
          // Aggiorna le informazioni sul modello se disponibili
          if (data.model) {
            this.defaultModelInfo.name = data.model;
          }
        }
        
        return isConnected;
      } else {
        if (this.model.getIsBackendConnected()) {
          this.model.setIsBackendConnected(false);
        }
        return false;
      }
    } catch (error) {
      console.error('Error checking backend status:', error);
      if (this.model.getIsBackendConnected()) {
        this.model.setIsBackendConnected(false);
      }
      return false;
    }
  }
  
  /**
   * Imposta il controller dei dialoghi
   */
  public setDialogController(controller: DialogController): void {
    this.dialogController = controller;
    
    // Applica lo stato corrente
    if (controller && this.model.getIsLLMEnabled() !== undefined) {
      controller.toggleLLMDialogs(this.model.getIsLLMEnabled());
    }
  }
  
  /**
   * Gestisce il toggle dell'attivazione LLM
   */
  public handleToggleLLM(enabled: boolean): void {
    // Aggiorna il modello
    this.model.setIsLLMEnabled(enabled);
    
    // Aggiorna il controller dialoghi se presente
    if (this.dialogController) {
      this.dialogController.toggleLLMDialogs(enabled);
    }
  }
  
  /**
   * Gestisce il cambio del tipo di messaggio
   */
  public handleMessageTypeChange(type: string): void {
    this.model.setSelectedMessageType(type);
  }
  
  /**
   * Gestisce il cambio della frequenza dei messaggi
   */
  public handleFrequencyChange(value: number): void {
    this.model.setMessageFrequency(value);
  }
  
  /**
   * Genera un nuovo messaggio LLM o simulato
   */
  public async generateMessage(agentData?: any): Promise<void> {
    try {
      // Ottieni gli agenti dalla scena
      if (!agentData) {
        const agents = this.getSceneAgents();
        if (agents.length === 0) {
          console.warn('No agents found in scene');
          return;
        }
        
        // Seleziona un agente casuale
        const randomIndex = Math.floor(Math.random() * agents.length);
        agentData = agents[randomIndex];
      }
      
      // Tipo di messaggio selezionato
      const messageType = this.model.getSelectedMessageType();
      const isBackendConnected = this.model.getIsBackendConnected();
      
      // Categoria del messaggio
      const category = isBackendConnected ? 'llm' : 'simulated';
      
      // Placeholder per indicare che stiamo generando un messaggio
      const placeholderEntry: Omit<SimpleLLMLogEntry, 'id'> = {
        timestamp: Date.now(),
        agentId: agentData.id,
        agentName: agentData.name || `Agent ${agentData.id}`,
        text: isBackendConnected ? 'Generating LLM message...' : 'Generating simulated message...',
        type: messageType,
        category: category,
        modelInfo: this.defaultModelInfo
      };
      
      // Aggiungi il placeholder al log
      this.model.addLogEntry(placeholderEntry);
      
      // Genera il messaggio dal backend o simulato
      let messageText = '';
      
      if (isBackendConnected) {
        // Chiama l'API per generare un messaggio
        try {
          // Costruisci i dati per la richiesta API
          const requestData = {
            agent_id: agentData.id,
            agentId: agentData.id,
            agent_name: agentData.name || `Agent ${agentData.id}`,
            agentName: agentData.name || `Agent ${agentData.id}`,
            agent_role: agentData.role || 'researcher',
            agentRole: agentData.role || 'researcher',
            agent_specialization: agentData.specialization || 'Federated Learning',
            agentSpecialization: agentData.specialization || 'Federated Learning',
            target_agent_id: null,
            targetAgentId: null,
            target_agent_name: null,
            targetAgentName: null,
            target_agent_role: null,
            targetAgentRole: null,
            interaction_type: messageType === 'dialog' ? 'working' : messageType,
            interactionType: messageType === 'dialog' ? 'working' : messageType,
            lab_type: this.getLabTypeFromAgent(agentData),
            labType: this.getLabTypeFromAgent(agentData)
          };
          
          // Chiama l'API di generazione dialogo
          const response = await fetch(`${this.apiBaseUrl}/ai/generate-dialog`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(requestData),
            signal: AbortSignal.timeout(5000)
          });
          
          if (response.ok) {
            const data = await response.json();
            messageText = data.dialog || data.message || "No response from LLM service";
          } else {
            // Fallback ai messaggi simulati in caso di errore API
            console.warn('Error from LLM API, using simulated message');
            messageText = this.generateSimulatedMessage(messageType, agentData);
          }
        } catch (apiError) {
          console.error('API call failed:', apiError);
          messageText = this.generateSimulatedMessage(messageType, agentData);
        }
      } else {
        // Genera un messaggio simulato
        messageText = this.generateSimulatedMessage(messageType, agentData);
      }
      
      // Rimuovi il placeholder
      const log = this.model.getMessageLog();
      if (log.length > 0 && log[0].text.includes('Generating')) {
        // Non fare nulla, sarà sovrascritto dal nuovo messaggio
      }
      
      // Crea il nuovo messaggio
      const finalEntry: Omit<SimpleLLMLogEntry, 'id'> = {
        timestamp: Date.now(),
        agentId: agentData.id,
        agentName: agentData.name || `Agent ${agentData.id}`,
        text: messageText,
        type: messageType,
        category: category,
        modelInfo: this.defaultModelInfo
      };
      
      // Aggiungi il messaggio al log
      this.model.addLogEntry(finalEntry);
      
      // Emetti evento appropriato in base al tipo di messaggio
      this.emitMessageEvent(agentData, finalEntry);
    } catch (error) {
      console.error('Error generating message:', error);
    }
  }
  
  /**
   * Emette un evento in base al tipo di messaggio generato
   */
  private emitMessageEvent(agent: any, entry: Omit<SimpleLLMLogEntry, 'id'>): void {
    if (!this.scene || !this.scene.game || !this.scene.game.events) return;
    
    switch (entry.type) {
      case 'dialog':
        // Se c'è un altro agente, crea una conversazione
        if (this.getSceneAgents().length > 1) {
          // Trova un altro agente casuale diverso dal primo
          let targetAgent;
          do {
            const agents = this.getSceneAgents();
            const targetIndex = Math.floor(Math.random() * agents.length);
            targetAgent = agents[targetIndex];
          } while (targetAgent.id === agent.id);
          
          // Emetti un evento di interazione tra agenti
          this.scene.game.events.emit('agent-interaction', {
            agentId1: agent.id,
            agentId2: targetAgent.id,
            type: 'conversation',
            llm: true,
            isSimulated: entry.category === 'simulated'
          });
          
          // Emetti anche l'evento dialog-created per il conteggio
          this.scene.game.events.emit('dialog-created', {
            type: entry.category === 'llm' ? 'llm' : 'simulated',
            isSimulated: entry.category === 'simulated'
          });
        } else {
          // Crea un monologo
          this.scene.game.events.emit('agent-reaction', {
            agentId: agent.id,
            eventType: 'reflection',
            context: 'Federated learning research progress',
            llm: true,
            isSimulated: entry.category === 'simulated'
          });
          
          // Emetti anche l'evento dialog-created per il conteggio
          this.scene.game.events.emit('dialog-created', {
            type: entry.category === 'llm' ? 'llm' : 'simulated',
            isSimulated: entry.category === 'simulated'
          });
        }
        break;
      
      case 'thinking':
        // Genera un pensiero
        this.scene.game.events.emit('agent-thinking', {
          agentId: agent.id,
          context: 'Analyzing federated learning optimization challenges',
          llm: true,
          isSimulated: entry.category === 'simulated'
        });
        
        // Emetti anche l'evento dialog-created per il conteggio
        this.scene.game.events.emit('dialog-created', {
          type: entry.category === 'llm' ? 'llm' : 'simulated',
          isSimulated: entry.category === 'simulated'
        });
        break;
      
      case 'decision':
        // Genera una decisione
        this.scene.game.events.emit('agent-decision', {
          agentId: agent.id,
          decisionType: 'algorithm_selection',
          context: 'Optimizing federated learning algorithm for heterogeneous clients',
          llm: true,
          isSimulated: entry.category === 'simulated'
        });
        
        // Emetti anche l'evento dialog-created per il conteggio
        this.scene.game.events.emit('dialog-created', {
          type: entry.category === 'llm' ? 'llm' : 'simulated',
          isSimulated: entry.category === 'simulated'
        });
        break;
    }
  }
  
  /**
   * Genera un messaggio simulato
   */
  private generateSimulatedMessage(type: string, agentData: any): string {
    // Messaggi simulati per diversi tipi
    const dialogMessages = [
      "I'm researching Federated Learning in distributed environments.",
      "Let's analyze this federated learning approach in more detail.",
      "I've been working on optimizing the client selection algorithm.",
      "Have you considered the impact of non-IID data distribution on model convergence?",
      "We should implement differential privacy techniques to enhance the security.",
      "The communication efficiency could be improved with model compression."
    ];
    
    const thinkingMessages = [
      "The current aggregation method might be introducing bias due to the heterogeneous data sources...",
      "If we implement quantization on the client updates, we could reduce bandwidth by 70% while maintaining accuracy...",
      "The privacy-utility tradeoff is crucial here - increasing epsilon improves model performance but reduces privacy guarantees...",
      "What if we implemented a dynamic client selection strategy based on data quality and computational resources?",
      "The convergence rate seems to slow down after round 15, possibly due to client drift..."
    ];
    
    const decisionMessages = [
      "Decision: We should implement FedProx instead of FedAvg to handle the non-IID data distribution across clients.",
      "Decision: Implementing secure aggregation protocol to enhance privacy guarantees for sensitive medical data.",
      "Decision: We'll adopt adaptive learning rates for clients based on their local data distributions.",
      "Decision: Implement knowledge distillation on the server to reduce the model size before distribution.",
      "Decision: Applying differential privacy with a gradually decreasing epsilon value throughout training."
    ];
    
    // Seleziona l'array corretto
    let messageArray: string[];
    switch (type) {
      case 'dialog':
        messageArray = dialogMessages;
        break;
      case 'thinking':
        messageArray = thinkingMessages;
        break;
      case 'decision':
        messageArray = decisionMessages;
        break;
      default:
        messageArray = dialogMessages;
    }
    
    // Seleziona un messaggio casuale
    const randomIndex = Math.floor(Math.random() * messageArray.length);
    let baseMessage = messageArray[randomIndex];
    
    // Personalizza il messaggio in base al ruolo dell'agente
    if (agentData.role) {
      const role = agentData.role.toLowerCase();
      
      if (role.includes('professor')) {
        baseMessage = `As a professor, I believe ${baseMessage.toLowerCase()}`;
      } else if (role.includes('student')) {
        baseMessage = `I'm still learning, but ${baseMessage.toLowerCase()}`;
      } else if (role.includes('doctor') || role.includes('medical')) {
        baseMessage = `From a medical perspective, ${baseMessage.toLowerCase()}`;
      } else if (role.includes('engineer')) {
        baseMessage = `From an engineering standpoint, ${baseMessage.toLowerCase()}`;
      }
    }
    
    return baseMessage;
  }
  
  /**
   * Determina il tipo di laboratorio dall'agente
   */
  private getLabTypeFromAgent(agentData: any): string {
    // Se l'agente ha un laboratorio specificato, usalo
    if (agentData.lab) {
      return agentData.lab;
    }
    
    // Se l'agente ha un contesto di laboratorio, estrailo
    if (agentData.context && agentData.context.lab) {
      return agentData.context.lab;
    }
    
    // Altrimenti, determina il tipo di laboratorio dal ruolo dell'agente
    const role = agentData.role?.toLowerCase() || '';
    
    if (role.includes('medic') || role.includes('doctor') || role.includes('bio')) {
      return 'opbg';
    } else if (role.includes('engineer') || role.includes('tech')) {
      return 'blekinge';
    } else {
      return 'mercatorum';
    }
  }
  
  /**
   * Ottiene gli agenti dalla scena corrente
   */
  private getSceneAgents(): any[] {
    if (!this.scene) return [];
    
    let agents: any[] = [];
    
    try {
      // Prova prima a usare il controller degli agenti
      if ((this.scene as any).agentController && (this.scene as any).agentController.agents) {
        agents = (this.scene as any).agentController.agents;
      }
      // Se non presente, cerca direttamente nella scena
      else if ((this.scene as any).agents) {
        agents = (this.scene as any).agents;
      }
      // Se ancora niente, cerca nei children della scena
      else {
        agents = this.scene.children.getChildren()
          .filter((child: any) => {
            if (!child.getData) return false;
            return child.getData('id') && (child.getData('type') || child.getData('role'));
          })
          .map((agent: any) => {
            return {
              id: agent.getData('id'),
              name: agent.getData('name') || `Agent ${agent.getData('id')}`,
              type: agent.getData('type') || agent.getData('role'),
              role: agent.getData('role') || 'researcher',
              x: agent.x,
              y: agent.y
            };
          });
      }
      
      // Se non sono stati trovati agenti, crea un agente di sistema fittizio
      if (agents.length === 0) {
        agents = [{
          id: 'system_agent',
          name: 'System Agent',
          type: 'system',
          role: 'system',
          x: this.scene.cameras.main.centerX,
          y: this.scene.cameras.main.centerY
        }];
      }
      
      return agents;
    } catch (error) {
      console.error('Error getting agents:', error);
      return [{
        id: 'system_agent',
        name: 'System Agent',
        type: 'system',
        role: 'system',
        x: this.scene.cameras.main.centerX,
        y: this.scene.cameras.main.centerY
      }];
    }
  }
  
  /**
   * Gestisce la visualizzazione completa di un messaggio
   */
  public showMessageDetails(messageId: string): void {
    if (!this.view) return;
    
    // Trova il messaggio nel log
    const messages = this.model.getMessageLog();
    const message = messages.find(msg => msg.id === messageId);
    
    if (message) {
      this.view.showMessageDetails(message);
    }
  }
  
  /**
   * Reset dei contatori
   */
  public resetCounters(): void {
    this.model.resetCounters();
  }
  
  /**
   * Cancella il log dei messaggi
   */
  public clearLog(): void {
    this.model.clearLog();
  }
  
  /**
   * Distrugge il controller e pulisce le risorse
   */
  public destroy(): void {
    this.isDestroyed = true;
    
    // Ferma il timer di polling
    if (this.updateTimerId !== null) {
      window.clearInterval(this.updateTimerId);
      this.updateTimerId = null;
    }
    
    // Salva lo stato prima di uscire
    this.model.saveState();
  }
}