// frontend/src/phaser/ui/LLMMessagingService.ts

import { LLMLogEntry } from './LLMPanelState';

/**
 * Interfaccia per messaggi di errore
 */
interface ErrorWithMessage {
  message: string;
}

/**
 * Verifica se l'errore ha una proprietà message
 */
function isErrorWithMessage(error: unknown): error is ErrorWithMessage {
  return (
    typeof error === 'object' &&
    error !== null &&
    'message' in error &&
    typeof (error as Record<string, unknown>).message === 'string'
  );
}

/**
 * Converte un errore in un messaggio di errore leggibile
 */
function toErrorMessage(error: unknown): string {
  if (isErrorWithMessage(error)) {
    return error.message;
  }
  return String(error);
}

/**
 * Servizio per gestire la comunicazione con il backend per i messaggi LLM
 */
export class LLMMessagingService {
  private isBackendConnected: boolean = false;
  private lastBackendCheck: number = 0;
  private checkInterval: number = 5000;
  private defaultModelInfo: any;
  
  constructor(defaultModelInfo: any) {
    this.defaultModelInfo = defaultModelInfo;
    this.checkBackendStatus();
  }
  
  /**
   * Controlla lo stato del backend
   */
  public checkBackendStatus(): Promise<boolean> {
    return new Promise((resolve) => {
      try {
        const now = Date.now();
        // Limita la frequenza dei controlli
        if (now - this.lastBackendCheck < this.checkInterval) {
          resolve(this.isBackendConnected);
          return;
        }
        
        this.lastBackendCheck = now;
        
        // Controlla se c'è un flag globale o un segnale che indichi lo stato del backend
        const backendStatus = (window as any).backendConnected || false;
        
        // In alternativa, controlla cercando elementi nel DOM che indicano lo stato
        const backendIndicator = document.getElementById('backend-status');
        if (backendIndicator) {
          this.isBackendConnected = backendIndicator.getAttribute('data-connected') === 'true';
        } else {
          // Usa la variabile globale o il valore predefinito
          this.isBackendConnected = backendStatus;
        }
        
        resolve(this.isBackendConnected);
      } catch (error) {
        console.error('Error checking backend status:', error);
        resolve(false);
      }
    });
  }
  
  /**
   * Genera un messaggio LLM o simulato
   */
  public async generateMessage(agentData: any, messageType: string): Promise<LLMLogEntry> {
    try {
      // Verifica lo stato del backend
      await this.checkBackendStatus();
      
      // Ottieni i dati dell'agente
      const { id: agentId, name: agentName } = agentData;
      
      // Flag per indicare se il messaggio è simulato (quando il backend è disconnesso)
      const isSimulated = !this.isBackendConnected;
      
      let messageText = '';
      
      // Simula un messaggio o genera un messaggio LLM in base allo stato del backend
      if (isSimulated) {
        // Genera un messaggio simulato basato sul tipo
        messageText = this.generateSimulatedMessage(messageType, agentData);
      } else {
        // Qui si collegherebbe all'API per generare un messaggio LLM reale
        // Per ora implementiamo un messaggio "finto" LLM
        messageText = await this.callLLMApi(messageType, agentData);
      }
      
      // Crea e restituisci un oggetto messaggio
      return {
        timestamp: Date.now(),
        agentId,
        agentName: agentName || `Agent ${agentId}`,
        text: messageText,
        type: messageType,
        isSimulated,
        modelInfo: { ...this.defaultModelInfo }
      };
    } catch (error) {
      console.error('Error generating message:', error);
      
      // In caso di errore, restituisci un messaggio di errore simulato
      return {
        timestamp: Date.now(),
        agentId: agentData.id,
        agentName: agentData.name || `Agent ${agentData.id}`,
        text: `Error generating message: ${toErrorMessage(error)}`,
        type: messageType,
        isSimulated: true,
        modelInfo: { ...this.defaultModelInfo }
      };
    }
  }
  
  /**
   * Genera un messaggio simulato
   */
  private generateSimulatedMessage(type: string, agentData: any): string {
    const { role = 'researcher' } = agentData;
    
    // Messaggi simulati in base al tipo
    const dialogMessages = [
      "Let's analyze this federated learning approach in more detail.",
      "I've been working on optimizing the client selection algorithm.",
      "Have you considered the impact of non-IID data distribution on model convergence?",
      "We should implement differential privacy techniques to enhance the security.",
      "The communication efficiency could be improved with model compression."
    ];
    
    const thinkingMessages = [
      "The current aggregation method might be introducing bias due to the heterogeneous data sources...",
      "If we implement quantization on the client updates, we could reduce bandwidth by 70% while maintaining accuracy...",
      "The privacy-utility tradeoff is crucial here - increasing epsilon improves model performance but reduces privacy guarantees...",
      "What if we implemented a dynamic client selection strategy based on data quality and computational resources?",
      "The convergence rate seems to slow down after round 15, possibly due to client drift..."
    ];
    
    const decisionMessages = [
      "Decision: We should implement FedProx instead of FedAvg to handle the non-IID data distribution across clients.",
      "Decision: Implementing secure aggregation protocol to enhance privacy guarantees for sensitive medical data.",
      "Decision: We'll adopt adaptive learning rates for clients based on their local data distributions.",
      "Decision: Implement knowledge distillation on the server to reduce the model size before distribution.",
      "Decision: Applying differential privacy with a gradually decreasing epsilon value throughout training."
    ];
    
    // Seleziona un array di messaggi in base al tipo
    let messagesArray: string[];
    
    if (type === 'dialog') {
      messagesArray = dialogMessages;
    } else if (type === 'thinking') {
      messagesArray = thinkingMessages;
    } else if (type === 'decision') {
      messagesArray = decisionMessages;
    } else {
      messagesArray = dialogMessages; // Default
    }
    
    // Seleziona un messaggio casuale dall'array
    const randomIndex = Math.floor(Math.random() * messagesArray.length);
    return messagesArray[randomIndex];
  }
  
  /**
   * Simula una chiamata all'API LLM
   */
  private async callLLMApi(type: string, agentData: any): Promise<string> {
    // In un'implementazione reale, qui ci sarebbe una chiamata API
    // Per ora simuliamo una risposta ritardata
    return new Promise((resolve) => {
      setTimeout(() => {
        // Genera un messaggio più elaborato per simulare output LLM
        const messages: Record<string, string[]> = {
          dialog: [
            "I've been analyzing the convergence properties of various federated optimization algorithms under non-IID conditions. The client heterogeneity introduces significant challenges that we need to address.",
            "Have you considered implementing adaptive aggregation weights based on client data quality? My experiments show a 15% improvement in convergence speed compared to standard FedAvg.",
            "Let's explore the privacy-utility tradeoff in our current implementation. I believe we can increase the differential privacy budget slightly without compromising our security guarantees."
          ],
          thinking: [
            "The non-IID data distribution across clients is creating model drift during training. If we implement momentum on the server side, we might be able to stabilize the convergence trajectory while maintaining communication efficiency...",
            "Analyzing the trade-offs between model accuracy and privacy guarantees: increasing epsilon from 0.1 to 0.5 improved accuracy by 4.3% but increased vulnerability to membership inference attacks by an estimated 7.2%. Perhaps a dynamic privacy budget allocation strategy could optimize this balance?",
            "The client selection strategy seems suboptimal - we're consistently selecting clients with similar data distributions. If we implement a diversity-based selection mechanism, we could improve model generalization while reducing the number of communication rounds needed."
          ],
          decision: [
            "Decision: After analyzing convergence patterns across 50 training rounds, I've determined we should implement FedProx with μ=0.01 to mitigate client drift. This will add a proximal term to the local objective function, penalizing large deviations from the global model while still allowing for local specialization.",
            "Decision: We need to implement a more sophisticated secure aggregation protocol. Our current implementation is vulnerable to reconstruction attacks when client dropout exceeds 25%. I propose implementing the SecAgg+ protocol with threshold cryptography to ensure privacy guarantees even with significant client dropout.",
            "Decision: To address the communication bottleneck, we'll implement quantization on model updates using a 4-bit uniform quantization scheme. My analysis indicates this will reduce communication costs by 87.5% while incurring an accuracy loss of only 0.7% compared to full-precision updates."
          ]
        };
        
        // Ottieni i messaggi per il tipo richiesto o usa il default
        const typeMessages = messages[type] || messages.dialog;
        const randomIndex = Math.floor(Math.random() * typeMessages.length);
        resolve(typeMessages[randomIndex]);
      }, 500); // Simula un ritardo di rete
    });
  }
  
  /**
   * Restituisce lo stato attuale della connessione backend
   */
  public isConnected(): boolean {
    return this.isBackendConnected;
  }
}