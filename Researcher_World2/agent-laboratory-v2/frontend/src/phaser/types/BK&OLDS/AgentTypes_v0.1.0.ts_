// Definizione degli stati base per tutti gli agenti
export type AgentState = 
  | 'idle' 
  | 'moving'
  | 'working'
  | 'meeting'
  | 'resting'
  | 'discussing'
  | 'presenting';

// Stati specifici per i ricercatori
export type ResearcherState = 
  | AgentState 
  | 'researching'
  | 'analyzing'
  | 'collaborating'
  | 'writing';

// Stati specifici per i ricercatori medici
export type MedicalResearcherState = 
  | ResearcherState 
  | 'diagnostics'
  | 'patient-review'
  | 'medical-analysis';

// Tipi di ricercatori
export type ResearcherType = 
  | 'phd-student'
  | 'postdoc'
  | 'professor'
  | 'ml-engineer'
  | 'data-engineer'
  | 'privacy-specialist';

// Specializzazioni dei ricercatori
export type ResearcherSpecialization = 
  | 'data-science'
  | 'privacy-engineering'
  | 'optimization'
  | 'secure-aggregation'
  | 'non-iid-data'
  | 'communication-efficiency'
  | 'fl-architecture'
  | 'theoretical-guarantees'
  | 'privacy-economics'
  | 'model-optimization'
  | 'systems-integration'
  | 'empirical-evaluation'
  | 'data-pipeline'
  | 'heterogeneous-data'
  | 'quality-assurance'
  | 'differential-privacy'
  | 'attack-simulation'
  | 'compliance-verification';

// Tipi specifici per ricercatori medici
export type MedicalResearcherType = 
  | 'medical-doctor'
  | 'biomedical-engineer';

// Specializzazioni mediche
export type MedicalSpecialization = 
  | 'clinical-data'
  | 'diagnostic-models'
  | 'patient-adaptation'
  | 'medical-imaging'
  | 'biosignal-processing'
  | 'medical-device-integration';