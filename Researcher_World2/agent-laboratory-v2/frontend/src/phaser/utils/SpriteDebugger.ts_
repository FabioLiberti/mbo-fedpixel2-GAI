// frontend/src/phaser/utils/SpriteDebugger.ts

/**
 * Utility per debug avanzato delle sprite
 * Utile per diagnosticare problemi di visualizzazione
 */
export class SpriteDebugger {
  private scene: Phaser.Scene;
  private debugObjects: Phaser.GameObjects.GameObject[] = [];
  private debugPanel: Phaser.GameObjects.Container | null = null;
  private isActive: boolean = false;

  constructor(scene: Phaser.Scene) {
    this.scene = scene;
  }

  /**
   * Crea una griglia di test di tutte le texture disponibili
   */
  createTextureGrid(x = 100, y = 100, cols = 3, spacing = 70): void {
    // Pulisci gli oggetti di debug precedenti
    this.clearDebugObjects();

    // Ottieni tutte le texture disponibili
    const textureKeys = this.scene.textures.getTextureKeys()
      .filter((key: string) => key !== '__DEFAULT' && key !== '__MISSING');

    console.log('Available textures:', textureKeys);

    // Crea un pannello di debug
    const panel = this.scene.add.graphics();
    panel.fillStyle(0x000000, 0.7);
    panel.fillRect(x - 20, y - 20, cols * spacing + 40, Math.ceil(textureKeys.length / cols) * spacing + 40);
    panel.setDepth(1000);
    
    // Info label
    const infoLabel = this.scene.add.text(
      x, 
      y - 40, 
      `Testing ${textureKeys.length} textures`, 
      { 
        fontSize: '16px',
        backgroundColor: '#333333',
        padding: { left: 5, right: 5, top: 2, bottom: 2 }
      }
    );
    infoLabel.setDepth(1001);
    this.debugObjects.push(infoLabel);

    // Crea sprite per ogni texture
    textureKeys.forEach((key: string, index: number) => {
      const col = index % cols;
      const row = Math.floor(index / cols);
      const posX = x + col * spacing;
      const posY = y + row * spacing;

      try {
        // Visualizza tutte le informazioni su questa texture
        console.log(`Texture '${key}' details:`, this.getTextureDetails(key));

        // Crea sprite di test con dimensioni forzate
        const sprite = this.scene.add.sprite(posX, posY, key);
        sprite.setScale(1); // Forza scala a 1
        sprite.setAlpha(1); // Forza opacità a 1
        sprite.setTint(0xffffff); // Resetta tint
        sprite.setVisible(true); // Forza visibilità
        sprite.setDepth(1001); // Assicura che sia sopra il pannello
        
        // Aggiungi il contorno allo sprite
        const graphics = this.scene.add.graphics();
        graphics.lineStyle(2, 0xff0000);
        graphics.strokeRect(posX - sprite.width/2, posY - sprite.height/2, sprite.width, sprite.height);
        graphics.setDepth(1002);
        
        // Aggiungi il nome della texture
        const label = this.scene.add.text(
          posX, 
          posY + 25, 
          key, 
          { 
            fontSize: '10px',
            backgroundColor: '#000000',
            padding: { left: 3, right: 3, top: 1, bottom: 1 }
          }
        );
        label.setOrigin(0.5);
        label.setDepth(1001);
        
        this.debugObjects.push(sprite, graphics, label);
      } catch (error) {
        console.error(`Error displaying texture ${key}:`, error);
        
        // Visualizza errore come testo
        const errorText = this.scene.add.text(
          posX, 
          posY, 
          `Error: ${key}`, 
          { 
            fontSize: '10px',
            backgroundColor: '#ff0000',
            padding: { left: 3, right: 3, top: 1, bottom: 1 }
          }
        );
        errorText.setOrigin(0.5);
        errorText.setDepth(1001);
        
        this.debugObjects.push(errorText);
      }
    });
    
    // Crea un pulsante per chiudere il debugger
    const closeButton = this.scene.add.text(
      x + cols * spacing, 
      y - 40, 
      'X', 
      { 
        fontSize: '16px',
        backgroundColor: '#ff0000',
        padding: { left: 5, right: 5, top: 2, bottom: 2 }
      }
    );
    closeButton.setDepth(1001);
    closeButton.setInteractive({ useHandCursor: true });
    closeButton.on('pointerdown', () => {
      this.clearDebugObjects();
    });
    
    this.debugObjects.push(panel, closeButton);
    this.isActive = true;
  }

  /**
   * Pulisce tutti gli oggetti di debug
   */
  clearDebugObjects(): void {
    this.debugObjects.forEach(obj => {
      if (obj && !obj.destroy) {
        obj.destroy();
      }
    });
    this.debugObjects = [];
    
    if (this.debugPanel) {
      this.debugPanel.destroy();
      this.debugPanel = null;
    }
    
    this.isActive = false;
  }

  /**
   * Interfaccia per i frame di texture
   */
  interface TextureFrame {
    x: number;
    y: number;
    width: number;
    height: number;
    centerX: number;
    centerY: number;
  }

  /**
   * Restituisce dettagli completi su una texture
   */
  getTextureDetails(key: string): any {
    try {
      if (!this.scene.textures.exists(key)) {
        return { exists: false, error: 'Texture does not exist' };
      }
      
      const texture = this.scene.textures.get(key);
      const source = texture.source[0];
      
      // Raccoglie tutti i dettagli possibili
      return {
        exists: true,
        key: key,
        frameTotal: texture.frameTotal,
        width: source?.width || 0,
        height: source?.height || 0,
        frameNames: Object.keys(texture.frames),
        hasGL: !!source.glTexture,
        isRenderTexture: texture.isRenderTexture || false,
        // Prova a ottenere dettagli sui frame
        frames: Object.entries(texture.frames).map(([name, frameObj]) => {
          // Cast sicuro del frame
          const frame = frameObj as unknown as TextureFrame;
          return {
            name,
            x: frame.x,
            y: frame.y,
            width: frame.width,
            height: frame.height,
            centerX: frame.centerX,
            centerY: frame.centerY
          };
        }),
        // Dettagli tecnici aggiuntivi
        technical: {
          firstFrame: texture.firstFrame,
          CustomPipeline: texture.customPipeline,
          defaultPipeline: texture.defaultPipeline,
          isPowerOf2: source.isPowerOf2 || false,
          glIndex: source.glIndexCounter
        }
      };
    } catch (error) {
      return { exists: true, error: `Error getting details: ${error}` };
    }
  }

  /**
   * Crea un test forzato per visualizzare una sprite
   */
  createForcedSpriteTest(textureKey: string, x: number, y: number): void {
    if (!this.scene.textures.exists(textureKey)) {
      console.error(`Texture ${textureKey} does not exist for forced test`);
      return;
    }
    
    try {
      // Creiamo un canvas e disegniamo direttamente la texture
      const texture = this.scene.textures.get(textureKey);
      const source = texture.source[0];
      
      console.log(`Creating forced test for ${textureKey}:`, source);
      
      // Otteniamo i dati grezzi dal WebGL
      if (source.glTexture) {
        console.log('Has WebGL texture, trying to create direct sprite');
        
        // Crea uno sprite con dimensioni forzate
        const sprite = this.scene.add.sprite(x, y, textureKey);
        sprite.setScale(2);  // Scala x2 per visibilità
        sprite.setDepth(1000);
        
        // Indicatore visivo
        const marker = this.scene.add.graphics();
        marker.lineStyle(4, 0xff0000);
        marker.strokeCircle(x, y, 40);
        
        const label = this.scene.add.text(
          x, 
          y + 50, 
          `${textureKey} (forced)`, 
          { 
            fontSize: '14px',
            backgroundColor: '#000000',
            padding: { left: 3, right: 3, top: 2, bottom: 2 }
          }
        );
        label.setOrigin(0.5);
        
        this.debugObjects.push(sprite, marker, label);
      } else {
        console.log('No WebGL texture, trying canvas fallback');
        
        // Otteni il canvas dalla texture
        const canvas = source.getCanvas();
        if (canvas) {
          // Crea una nuova texture temporanea dal canvas
          const tempKey = `debug_${textureKey}_${Date.now()}`;
          this.scene.textures.addCanvas(tempKey, canvas);
          
          const sprite = this.scene.add.sprite(x, y, tempKey);
          sprite.setScale(2);
          sprite.setDepth(1000);
          
          const label = this.scene.add.text(
            x, 
            y + 50, 
            `${textureKey} (canvas)`, 
            { 
              fontSize: '14px',
              backgroundColor: '#000000',
              padding: { left: 3, right: 3, top: 2, bottom: 2 }
            }
          );
          label.setOrigin(0.5);
          
          this.debugObjects.push(sprite, label);
        } else {
          console.error('No canvas available for texture:', textureKey);
        }
      }
    } catch (error) {
      console.error(`Error in forced sprite test for ${textureKey}:`, error);
    }
  }
  
  /**
   * Crea una copia utilizzabile di una texture
   */
  copyTexture(sourceKey: string, destKey: string): boolean {
    try {
      if (!this.scene.textures.exists(sourceKey)) {
        console.error(`Source texture ${sourceKey} does not exist`);
        return false;
      }
      
      const sourceTexture = this.scene.textures.get(sourceKey);
      const sourceCanvas = sourceTexture.getSourceImage() as HTMLCanvasElement;
      
      if (!sourceCanvas) {
        console.error(`Cannot get source canvas for ${sourceKey}`);
        return false;
      }
      
      // Crea una nuova texture dall'immagine sorgente
      this.scene.textures.addCanvas(destKey, sourceCanvas);
      
      // Copia i frame se esistono
      if (sourceTexture.frameTotal > 1) {
        const destTexture = this.scene.textures.get(destKey);
        
        Object.entries(sourceTexture.frames).forEach(([frameName, frameObj]) => {
          if (frameName !== '__BASE') {
            // Cast sicuro del frame
            const frame = frameObj as unknown as TextureFrame;
            destTexture.add(frameName, 0, frame.x, frame.y, frame.width, frame.height);
          }
        });
        
        destTexture.refresh();
      }
      
      console.log(`Texture ${sourceKey} successfully copied to ${destKey}`);
      return true;
    } catch (error) {
      console.error(`Error copying texture ${sourceKey} to ${destKey}:`, error);
      return false;
    }
  }
  
  /**
   * Crea una texture tramite un canvas vuoto
   */
  createEmergencyTexture(key: string, width: number, height: number, frameCount: number = 4): void {
    try {
      // Crea un canvas
      const canvas = document.createElement('canvas');
      canvas.width = width;
      canvas.height = height * frameCount;
      
      const ctx = canvas.getContext('2d');
      if (!ctx) {
        console.error('Cannot get 2D context for emergency texture');
        return;
      }
      
      // Colore per il debug
      const colors = ['#FF0000', '#00FF00', '#0000FF', '#FFFF00'];
      
      // Disegna frame colorati differenti
      for (let i = 0; i < frameCount; i++) {
        // Sfondo
        ctx.fillStyle = colors[i % colors.length];
        ctx.fillRect(0, i * height, width, height);
        
        // Bordo
        ctx.strokeStyle = '#FFFFFF';
        ctx.lineWidth = 2;
        ctx.strokeRect(2, i * height + 2, width - 4, height - 4);
        
        // Testo con numero di frame
        ctx.fillStyle = '#FFFFFF';
        ctx.font = '10px Arial';
        ctx.textAlign = 'center';
        ctx.fillText(`Frame ${i}`, width / 2, i * height + height / 2);
        
        // Aggiungi il nome della texture
        ctx.fillText(key, width / 2, i * height + height - 10);
      }
      
      // Crea texture in Phaser
      this.scene.textures.addCanvas(key, canvas);
      
      // Definisci i frame
      const texture = this.scene.textures.get(key);
      for (let i = 0; i < frameCount; i++) {
        texture.add(i, 0, 0, i * height, width, height);
      }
      
      texture.refresh();
      console.log(`Created emergency texture ${key} with ${frameCount} frames`);
    } catch (error) {
      console.error(`Error creating emergency texture ${key}:`, error);
    }
  }
}