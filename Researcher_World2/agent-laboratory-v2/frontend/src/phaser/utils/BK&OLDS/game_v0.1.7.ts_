// frontend/src/phaser/game.ts

import Phaser from 'phaser';
import { MercatorumLab } from '../../scenes/MercatorumLab';
import { BlekingeLabScene } from '../../scenes/BlekingeLabScene';
import { OPBGLabScene } from '../../scenes/OPBGLabScene';
// Importa l'utility di storage
import { safeStorage, isLocalStorageAvailable } from '../../../utils/storageUtils';
// Importa utility di debug per gli asset
import { debugAssets } from '../../../utils/assetDebug';

// Estensione dell'interfaccia Game per accessibilità migliore
export interface Game extends Phaser.Game {
  // Proprietà aggiuntive specifiche della nostra implementazione
}

// Configurazione del gioco
const gameConfig: Phaser.Types.Core.GameConfig = {
  type: Phaser.AUTO,
  parent: 'phaser-game',
  width: 800,
  height: 600,
  backgroundColor: '#4b4b4b',
  pixelArt: true,
  physics: {
    default: 'arcade',
    arcade: {
      gravity: { x: 0, y: 0 },
      debug: process.env.NODE_ENV === 'development'
    }
  },
  scene: [MercatorumLab, BlekingeLabScene, OPBGLabScene],
  scale: {
    mode: Phaser.Scale.RESIZE,
    autoCenter: Phaser.Scale.CENTER_BOTH
  },
  render: {
    antialias: false,
    pixelArt: true,
    roundPixels: true
  },
  callbacks: {
    postBoot: (game) => {
      // Eseguito dopo l'inizializzazione del gioco
      console.log('Phaser game booted successfully');
    }
  }
};

// Variabile per l'istanza singleton del gioco
let gameInstance: Game | null = null;

/**
 * Inizializza il gioco Phaser
 * @param containerId ID del container DOM
 * @returns L'istanza del gioco
 */
export function initGame(containerId?: string): Game {
  // Se l'istanza esiste già, restituiscila
  if (gameInstance !== null) {
    return gameInstance;
  }
  
  // Modifica il container se specificato
  if (containerId) {
    gameConfig.parent = containerId;
  }
  
  try {
    // Patch localStorage per Phaser prima di inizializzare il gioco
    patchStorageForPhaser();
    
    // Debug asset in ambiente di sviluppo
    if (process.env.NODE_ENV === 'development') {
      debugAssets();
    }
    
    // Crea una nuova istanza del gioco
    gameInstance = new Phaser.Game(gameConfig) as Game;
    
    // Gestione errori a livello globale
    window.addEventListener('error', (event) => {
      if (event.error && event.error.message && 
          (event.error.message.includes('WebGL context') || 
           event.error.message.includes('Phaser'))) {
        console.error('Phaser error caught:', event.error);
      }
    });
    
    return gameInstance;
  } catch (error) {
    console.error('Failed to initialize Phaser game:', error);
    throw error;
  }
}

/**
 * Applica una patch per sostituire localStorage con il nostro safeStorage
 * Questo previene errori di "Access to storage is not allowed from this context"
 */
function patchStorageForPhaser() {
  // Verifica se localStorage è disponibile
  if (!isLocalStorageAvailable()) {
    console.log('Patching localStorage for Phaser with safe storage...');
    
    try {
      // Crea un proxy per localStorage che utilizza il nostro safeStorage
      const localStorageProxy = {
        getItem: (key: string) => safeStorage.getItem(key),
        setItem: (key: string, value: string) => safeStorage.setItem(key, value),
        removeItem: (key: string) => safeStorage.removeItem(key),
        clear: () => safeStorage.clear(),
        key: (index: number) => safeStorage.key(index),
        get length() { return safeStorage.length; }
      };
      
      // Cerca di sostituire localStorage con il nostro proxy
      // Questo potrebbe non funzionare in alcuni browser per motivi di sicurezza
      try {
        // @ts-ignore - Tentativo di sovrascrittura (potrebbe non essere permesso)
        window.localStorage = localStorageProxy;
      } catch (e) {
        console.warn('Could not replace localStorage directly:', e);
        
        // Alternativa: inietta proprietà singolarmente
        Object.defineProperty(window, 'localStorage', {
          get: function() { return localStorageProxy; }
        });
      }
    } catch (error) {
      console.error('Failed to patch localStorage for Phaser:', error);
    }
  }
}

/**
 * Distrugge l'istanza del gioco
 */
export function destroyGame(): void {
  if (gameInstance) {
    try {
      gameInstance.destroy(true);
      gameInstance = null;
      console.log('Phaser game instance destroyed');
    } catch (error) {
      console.error('Error destroying Phaser game:', error);
    }
  }
}

/**
 * Ottiene l'istanza corrente del gioco
 * @returns L'istanza del gioco o null se non inizializzata
 */
export function getGameInstance(): Game | null {
  return gameInstance;
}