// src/phaser/utils/AssetLoader.ts

import Phaser from 'phaser';

/**
 * Classe AssetLoader che gestisce il caricamento delle risorse nel gioco
 */
export class AssetLoader {
  scene: Phaser.Scene;
  
  constructor(scene: Phaser.Scene) {
    this.scene = scene;
  }
  
  /**
   * Carica un'immagine
   */
  loadImage(key: string, url: string): void {
    console.log(`[AssetLoader] Loading image: ${key} from ${url}`);
    if (this.scene && this.scene.load) {
      this.scene.load.image(key, url);
    } else {
      console.error('[AssetLoader] Cannot load image: scene or load method not available');
    }
  }
  
  /**
   * Carica una Tilemap JSON
   */
  loadTilemapJSON(key: string, url: string): void {
    console.log(`[AssetLoader] Loading tilemap JSON: ${key} from ${url}`);
    if (this.scene && this.scene.load) {
      this.scene.load.tilemapTiledJSON(key, url);
    } else {
      console.error('[AssetLoader] Cannot load tilemap: scene or load method not available');
    }
  }
  
  /**
   * Carica un spritesheet
   */
  loadSpritesheet(key: string, url: string, frameConfig: Phaser.Types.Loader.FileTypes.ImageFrameConfig): void {
    console.log(`[AssetLoader] Loading spritesheet: ${key} from ${url}`);
    if (this.scene && this.scene.load) {
      this.scene.load.spritesheet(key, url, frameConfig);
    } else {
      console.error('[AssetLoader] Cannot load spritesheet: scene or load method not available');
    }
  }
  
  /**
   * Carica un file audio
   */
  loadAudio(key: string, url: string): void {
    console.log(`[AssetLoader] Loading audio: ${key} from ${url}`);
    if (this.scene && this.scene.load) {
      this.scene.load.audio(key, url);
    } else {
      console.error('[AssetLoader] Cannot load audio: scene or load method not available');
    }
  }
  
  /**
   * Verifica se un asset è stato caricato
   */
  isLoaded(key: string): boolean {
    return this.scene.textures.exists(key);
  }
}

// Mappa di loader per scene
const loaderMap = new WeakMap<Phaser.Scene, AssetLoader>();

/**
 * Ottiene un AssetLoader per una scena
 */
export function getAssetLoader(scene: Phaser.Scene): AssetLoader {
  if (!loaderMap.has(scene)) {
    loaderMap.set(scene, new AssetLoader(scene));
  }
  return loaderMap.get(scene)!;
}

/**
 * Funzione di utility per garantire che i metodi di caricamento di Phaser siano disponibili
 * Questa funzione dovrebbe essere chiamata prima di inizializzare il gioco
 */
export function applyAssetLoaderFix(): void {
  console.log('[AssetLoader] Applying compatibility fixes');
  
  // Verifica e correggi i metodi di caricamento di Phaser se necessario
  if (Phaser.Loader && Phaser.Loader.prototype) {
    // Aggiungi tilemapTiledJSON se manca
    if (!Phaser.Loader.prototype.tilemapTiledJSON && Phaser.Loader.prototype.tilemapJSON) {
      // @ts-ignore - Compatibilità con versioni vecchie di Phaser
      Phaser.Loader.prototype.tilemapTiledJSON = function(key: string, url: string) {
        return this.tilemapJSON(key, url);
      };
      console.log('[AssetLoader] Added tilemapTiledJSON fallback method');
    }
  }
  
  // Non proviamo più a estendere Phaser.Scene.prototype direttamente
  // Utilizziamo invece il pattern della factory function (getAssetLoader)
}