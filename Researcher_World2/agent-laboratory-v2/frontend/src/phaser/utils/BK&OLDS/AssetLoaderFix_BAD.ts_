// src/phaser/utils/AssetLoaderFix.ts

import Phaser from 'phaser';

// Definiamo un'interfaccia per l'AssetLoader
export interface IAssetLoader {
  scene: Phaser.Scene;
  loadImage(key: string, url: string): void;
  loadTilemapJSON(key: string, url: string): void;
  loadSpritesheet(key: string, url: string, frameConfig: Phaser.Types.Loader.FileTypes.ImageFrameConfig): void;
  loadAudio(key: string, url: string): void;
}

/**
 * Classe AssetLoader che gestisce il caricamento delle risorse nel gioco
 */
export class AssetLoader implements IAssetLoader {
  scene: Phaser.Scene;

  constructor(scene: Phaser.Scene) {
    this.scene = scene;
  }

  /**
   * Carica un'immagine
   * @param key Chiave identificativa dell'immagine
   * @param url Percorso dell'immagine
   */
  loadImage(key: string, url: string): void {
    console.log(`[AssetLoader] Loading image: ${key} from ${url}`);
    if (this.scene && this.scene.load) {
      this.scene.load.image(key, url);
    } else {
      console.error('[AssetLoader] Cannot load image: scene or load method not available');
    }
  }

  /**
   * Carica una Tilemap JSON
   * @param key Chiave identificativa della tilemap
   * @param url Percorso del file JSON
   */
  loadTilemapJSON(key: string, url: string): void {
    console.log(`[AssetLoader] Loading tilemap JSON: ${key} from ${url}`);
    if (this.scene && this.scene.load) {
      this.scene.load.tilemapTiledJSON(key, url);
    } else {
      console.error('[AssetLoader] Cannot load tilemap: scene or load method not available');
    }
  }

  /**
   * Carica un spritesheet
   * @param key Chiave identificativa dello spritesheet
   * @param url Percorso dello spritesheet
   * @param frameConfig Configurazione dei frame
   */
  loadSpritesheet(key: string, url: string, frameConfig: Phaser.Types.Loader.FileTypes.ImageFrameConfig): void {
    console.log(`[AssetLoader] Loading spritesheet: ${key} from ${url}`);
    if (this.scene && this.scene.load) {
      this.scene.load.spritesheet(key, url, frameConfig);
    } else {
      console.error('[AssetLoader] Cannot load spritesheet: scene or load method not available');
    }
  }

  /**
   * Carica un file audio
   * @param key Chiave identificativa dell'audio
   * @param url Percorso del file audio
   */
  loadAudio(key: string, url: string): void {
    console.log(`[AssetLoader] Loading audio: ${key} from ${url}`);
    if (this.scene && this.scene.load) {
      this.scene.load.audio(key, url);
    } else {
      console.error('[AssetLoader] Cannot load audio: scene or load method not available');
    }
  }
}

/**
 * Funzione di utility per applicare un fix temporaneo al caricamento degli asset
 * Aggiunge metodi mancanti a Phaser.Scene.prototype se necessario
 */
export function applyAssetLoaderFix(): void {
  console.log('[AssetLoaderFix] Applying fixes for asset loading methods');
  
  // Verifica se il metodo loadTilemapJSON esiste già
  if (!Phaser.Scene.prototype.loadTilemapJSON) {
    Phaser.Scene.prototype.loadTilemapJSON = function(key: string, url: string): void {
      console.log(`[Scene] Loading tilemap JSON: ${key} from ${url}`);
      
      if (this.load) {
        this.load.tilemapTiledJSON(key, url);
      } else {
        console.error('[Scene] Cannot load tilemap: load method not available');
      }
    };
  }
  
  // Metodo per ottenere un'istanza di AssetLoader per la scena corrente
  if (!Phaser.Scene.prototype.getAssetLoader) {
    Phaser.Scene.prototype.getAssetLoader = function(): AssetLoader {
      if (!this._assetLoader) {
        this._assetLoader = new AssetLoader(this);
      }
      return this._assetLoader;
    };
  }
}