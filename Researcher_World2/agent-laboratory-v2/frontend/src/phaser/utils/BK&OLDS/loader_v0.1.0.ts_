// frontend/src/phaser/loader.ts

/**
 * Utility per gestire il caricamento delle risorse di Phaser
 */

import { Scene } from 'phaser';

// Base path per i assets
const ASSETS_BASE_PATH = '/assets/';

// Verifica se un URL è assoluto
const isAbsoluteUrl = (url: string): boolean => {
  return /^(?:https?:)?\/\//.test(url);
};

// Normalizza un path di asset
const normalizePath = (path: string): string => {
  if (isAbsoluteUrl(path)) {
    return path;
  }
  
  // Se il path inizia già con /assets, non aggiungere il prefisso
  if (path.startsWith('/assets/')) {
    return path;
  }
  
  // Rimuovi eventuali slash iniziali
  const cleanPath = path.startsWith('/') ? path.slice(1) : path;
  return `${ASSETS_BASE_PATH}${cleanPath}`;
};

// Funzioni di logging avanzate
const logAssetError = (type: string, key: string, url: string, error?: any): void => {
  console.error(`[Phaser Loader] Failed to load ${type} "${key}" from ${url}`, error);
};

const logAssetSuccess = (type: string, key: string): void => {
  console.log(`[Phaser Loader] Successfully loaded ${type} "${key}"`);
};

/**
 * Classe per gestire il caricamento delle risorse
 */
export class AssetLoader {
  private scene: Scene;
  
  constructor(scene: Scene) {
    this.scene = scene;
    
    // Aggiungi listener per errori di caricamento
    this.scene.load.on('loaderror', this.handleLoadError, this);
    this.scene.load.on('filecomplete', this.handleFileComplete, this);
  }
  
  private handleLoadError = (file: any): void => {
    logAssetError(file.type, file.key, file.url);
  };
  
  private handleFileComplete = (key: string, type: string): void => {
    logAssetSuccess(type, key);
  };
  
  // Carica un'immagine
  loadImage(key: string, url: string): this {
    const normalizedUrl = normalizePath(url);
    try {
      // Verifica se l'immagine è già caricata
      if (!this.scene.textures.exists(key)) {
        this.scene.load.image(key, normalizedUrl);
      }
    } catch (error) {
      logAssetError('image', key, normalizedUrl, error);
    }
    return this;
  }
  
  // Carica un tilemap JSON
  loadTilemapJSON(key: string, url: string): this {
    const normalizedUrl = normalizePath(url);
    try {
      this.scene.load.tilemapTiledJSON(key, normalizedUrl);
    } catch (error) {
      logAssetError('tilemapJSON', key, normalizedUrl, error);
    }
    return this;
  }
  
  // Carica un spritesheet
  loadSpritesheet(key: string, url: string, frameConfig: Phaser.Types.Loader.FileTypes.ImageFrameConfig): this {
    const normalizedUrl = normalizePath(url);
    try {
      // Verifica se il spritesheet è già caricato
      if (!this.scene.textures.exists(key)) {
        this.scene.load.spritesheet(key, normalizedUrl, frameConfig);
      }
    } catch (error) {
      logAssetError('spritesheet', key, normalizedUrl, error);
    }
    return this;
  }
  
  // Carica un audio
  loadAudio(key: string, url: string): this {
    const normalizedUrl = normalizePath(url);
    try {
      this.scene.load.audio(key, normalizedUrl);
    } catch (error) {
      logAssetError('audio', key, normalizedUrl, error);
    }
    return this;
  }
  
  // Verifica la disponibilità di una risorsa
  isAssetAvailable(key: string, type: 'image' | 'spritesheet' | 'tilemap' = 'image'): boolean {
    switch (type) {
      case 'image':
      case 'spritesheet':
        return this.scene.textures.exists(key);
      case 'tilemap':
        return this.scene.cache.tilemap.has(key);
      default:
        return false;
    }
  }
  
  // Carica un placeholder per risorse mancanti
  loadPlaceholder(key: string, type: 'image' | 'spritesheet', width = 64, height = 64): this {
    // Crea una texture placeholder dinamicamente
    if (!this.scene.textures.exists('__placeholder')) {
      const graphics = this.scene.add.graphics();
      graphics.fillStyle(0xcccccc);
      graphics.fillRect(0, 0, width, height);
      graphics.lineStyle(2, 0xff0000);
      graphics.strokeRect(0, 0, width, height);
      graphics.lineStyle(2, 0xff0000);
      graphics.lineBetween(0, 0, width, height);
      graphics.lineBetween(width, 0, 0, height);
      
      // Genera la texture
      graphics.generateTexture('__placeholder', width, height);
      graphics.destroy();
    }
    
    // Clona il placeholder con la chiave specifica
    if (!this.scene.textures.exists(key)) {
      this.scene.textures.addImage(key, this.scene.textures.get('__placeholder').getSourceImage());
      console.warn(`[Phaser Loader] Using placeholder for missing ${type} "${key}"`);
    }
    
    return this;
  }
  
  // Metodo per riprovare il caricamento di una risorsa fallita
  retryFailedAsset(key: string, url: string, type: 'image' | 'spritesheet' | 'tilemapJSON', config?: any): this {
    const normalizedUrl = normalizePath(url);
    console.log(`[Phaser Loader] Retrying to load ${type} "${key}" from ${normalizedUrl}`);
    
    switch (type) {
      case 'image':
        this.loadImage(key, normalizedUrl);
        break;
      case 'spritesheet':
        if (config) {
          this.loadSpritesheet(key, normalizedUrl, config);
        } else {
          console.error(`[Phaser Loader] Cannot retry spritesheet "${key}" without frame config`);
        }
        break;
      case 'tilemapJSON':
        this.loadTilemapJSON(key, normalizedUrl);
        break;
    }
    
    return this;
  }
}

// Funzione helper per ottenere un'istanza di AssetLoader
export function createAssetLoader(scene: Scene): AssetLoader {
  return new AssetLoader(scene);
}