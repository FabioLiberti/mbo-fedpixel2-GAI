// frontend/src/phaser/loader.ts

import Phaser from 'phaser';

/**
 * Interfaccia per il caricatore di asset
 */
export interface AssetLoader {
  /**
   * Carica un'immagine
   * @param key Chiave per identificare l'asset
   * @param path Percorso dell'immagine
   */
  loadImage(key: string, path: string): void;
  
  /**
   * Carica un'immagine da usare come tileset
   * @param key Chiave per identificare l'asset
   * @param path Percorso dell'immagine
   */
  loadTileset(key: string, path: string): void;
  
  /**
   * Carica un spritesheet
   * @param key Chiave per identificare l'asset
   * @param path Percorso dell'immagine
   * @param config Configurazione del spritesheet
   */
  loadSpritesheet(key: string, path: string, config: Phaser.Types.Loader.FileTypes.ImageFrameConfig): void;
  
  /**
   * Carica un tilemap JSON
   * @param key Chiave per identificare l'asset
   * @param path Percorso del file JSON
   */
  loadTilemapJSON(key: string, path: string): void;
  
  /**
   * Carica un file audio
   * @param key Chiave per identificare l'asset
   * @param path Percorso del file audio
   */
  loadAudio(key: string, path: string): void;
  
  /**
   * Genera un placeholder per asset mancanti
   * @param key Chiave per identificare l'asset
   * @param type Tipo di asset (image, spritesheet, ecc.)
   * @param width Larghezza opzionale per spritesheet
   * @param height Altezza opzionale per spritesheet
   */
  loadPlaceholder(key: string, type: 'image' | 'spritesheet' | 'tileset', width?: number, height?: number): void;
}

/**
 * Crea un'istanza dell'AssetLoader
 * @param scene Scena Phaser in cui caricare gli asset
 * @returns Istanza di AssetLoader
 */
export function createAssetLoader(scene: Phaser.Scene): AssetLoader {
  return {
    loadImage(key: string, path: string): void {
      console.log(`Loading image: ${key} from ${path}`);
      try {
        if (!scene.textures.exists(key)) {
          scene.load.image(key, path);
        } else {
          console.log(`Image ${key} already loaded, skipping`);
        }
      } catch (error) {
        console.error(`Error loading image ${key}:`, error);
        this.loadPlaceholder(key, 'image');
      }
    },
    
    loadTileset(key: string, path: string): void {
      console.log(`Loading tileset: ${key} from ${path}`);
      try {
        if (!scene.textures.exists(key)) {
          scene.load.image(key, path);
        } else {
          console.log(`Tileset ${key} already loaded, skipping`);
        }
      } catch (error) {
        console.error(`Error loading tileset ${key}:`, error);
        this.loadPlaceholder(key, 'tileset');
      }
    },
    
    loadSpritesheet(key: string, path: string, config: Phaser.Types.Loader.FileTypes.ImageFrameConfig): void {
      console.log(`Loading spritesheet: ${key} from ${path}`);
      try {
        if (!scene.textures.exists(key)) {
          scene.load.spritesheet(key, path, config);
        } else {
          console.log(`Spritesheet ${key} already loaded, skipping`);
        }
      } catch (error) {
        console.error(`Error loading spritesheet ${key}:`, error);
        this.loadPlaceholder(key, 'spritesheet', config.frameWidth, config.frameHeight);
      }
    },
    
    loadTilemapJSON(key: string, path: string): void {
      console.log(`Loading tilemap: ${key} from ${path}`);
      try {
        scene.load.tilemapTiledJSON(key, path);
      } catch (error) {
        console.error(`Error loading tilemap ${key}:`, error);
      }
    },
    
    loadAudio(key: string, path: string): void {
      console.log(`Loading audio: ${key} from ${path}`);
      try {
        scene.load.audio(key, path);
      } catch (error) {
        console.error(`Error loading audio ${key}:`, error);
      }
    },
    
    loadPlaceholder(key: string, type: 'image' | 'spritesheet' | 'tileset', width: number = 64, height: number = 64): void {
      console.log(`Creating placeholder for ${type} ${key}`);
      
      try {
        // Se la texture esiste già, non creare il placeholder
        if (scene.textures.exists(key)) {
          console.log(`Texture ${key} already exists, not creating placeholder`);
          return;
        }
        
        // Crea una texture di base con indicazione visiva che è un placeholder
        const graphics = scene.make.graphics({ x: 0, y: 0, add: false });
        
        // Colore di sfondo in base al tipo
        switch (type) {
          case 'image':
            graphics.fillStyle(0xff00ff, 0.5); // Magenta per immagini
            break;
          case 'spritesheet':
            graphics.fillStyle(0x00ffff, 0.5); // Ciano per spritesheet
            break;
          case 'tileset':
            graphics.fillStyle(0xffff00, 0.5); // Giallo per tileset
            break;
        }
        
        // Disegna un rettangolo di base
        graphics.fillRect(0, 0, width, height);
        
        // Aggiungi il bordo
        graphics.lineStyle(2, 0x000000, 1);
        graphics.strokeRect(0, 0, width, height);
        
        // Aggiungi una X diagonale
        graphics.lineStyle(2, 0xff0000, 1);
        graphics.lineBetween(0, 0, width, height);
        graphics.lineBetween(width, 0, 0, height);
        
        // Aggiungi il testo con il nome della chiave mancante
        const textConfig = {
          x: width / 2,
          y: height / 2,
          text: key,
          style: {
            fontSize: '10px',
            fontFamily: 'Arial',
            color: '#000000',
            align: 'center',
            backgroundColor: '#ffffff'
          }
        };
        
        // Il testo potrebbe non essere visibile su spritesheet molto piccoli
        if (width >= 32 && height >= 32) {
          graphics.generateTexture(key, width, height);
          
          // Sovrascrivi con una nuova texture che include il testo
          const graphicsWithText = scene.make.graphics({ x: 0, y: 0, add: false });
          graphicsWithText.fillStyle(0xff00ff, 0.5);
          graphicsWithText.fillRect(0, 0, width, height);
          graphicsWithText.lineStyle(2, 0x000000, 1);
          graphicsWithText.strokeRect(0, 0, width, height);
          graphicsWithText.lineStyle(2, 0xff0000, 1);
          graphicsWithText.lineBetween(0, 0, width, height);
          graphicsWithText.lineBetween(width, 0, 0, height);
          
          graphicsWithText.generateTexture(key, width, height);
          
          // Aggiungi il testo direttamente sulla scena
          const text = scene.add.text(textConfig.x, textConfig.y, textConfig.text, textConfig.style as any);
          text.setOrigin(0.5);
          
          // Genera un'immagine dalla texture generata
          const rt = scene.add.renderTexture(0, 0, width, height);
          rt.draw(graphicsWithText, 0, 0);
          rt.draw(text, textConfig.x, textConfig.y);
          rt.saveTexture(key);
          
          // Pulisci
          text.destroy();
          rt.destroy();
        } else {
          // Per spritesheet molto piccoli, usa solo il grafico base
          graphics.generateTexture(key, width, height);
        }
        
        // Pulisci la grafica temporanea
        graphics.destroy();
        
        console.log(`Placeholder created for ${key}`);
      } catch (error) {
        console.error(`Error creating placeholder for ${key}:`, error);
      }
    }
  };
}