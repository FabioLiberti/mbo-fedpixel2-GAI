/// frontend/src/phaser/entities/LabMiniature.ts

import * as Phaser from 'phaser';
import { LabType } from '../types/LabType';
import { ResearcherType } from '../types/ResearcherType';

export default class LabMiniature extends Phaser.GameObjects.Container {
  private lab: LabType;
  private researchers: ResearcherType[] = [];
  private bg!: Phaser.GameObjects.Image;
  private frame: Phaser.GameObjects.Rectangle;
  private agentSprites: Phaser.GameObjects.Sprite[] = [];
  private debugText: Phaser.GameObjects.Text;
  private debugContainer: Phaser.GameObjects.Container;
  private gameScene: any;
  
  // Aggiungiamo la proprietà targetScene per risolvere l'errore
  public targetScene: string = '';
  public name: string = '';

  constructor(scene: any, x: number, y: number, lab: LabType) {
    super(scene, x, y);
    this.lab = lab;
    this.gameScene = scene;
    
    // Impostiamo il nome dal lab passato come parametro
    this.name = lab.name;
    
    console.log(`Creating lab miniature for ${lab.name} at (${x}, ${y})`);
    
    // Create debug container to hold all debug elements
    this.debugContainer = new Phaser.GameObjects.Container(scene, 0, 0);
    this.add(this.debugContainer);
    
    // Add colored frame first (as background)
    const frameColor = this.getLabColor();
    this.frame = scene.add.rectangle(0, 0, 150, 120, frameColor, 0.3);
    this.frame.setStrokeStyle(4, frameColor);
    this.add(this.frame);
    
    // Try to get the texture key for this lab
    const textureKey = this.getLabTextureKey();
    console.log(`Lab ${lab.name} texture key: ${textureKey}`);
    
    // Check if texture exists
    if (scene.textures.exists(textureKey)) {
      console.log(`Texture ${textureKey} exists!`);
      
      // Get texture dimensions for debugging
      const textureFrame = scene.textures.getFrame(textureKey);
      console.log(`Texture dimensions: ${textureFrame.width}x${textureFrame.height}`);

      // Create background with lab image
      this.bg = scene.add.image(0, 0, textureKey);
      
      // Debug scaling - let's try different scale approaches
      // Scale to fit within 150x120 while maintaining aspect ratio
      const scale = Math.min(150 / textureFrame.width, 120 / textureFrame.height);
      this.bg.setScale(scale);
      console.log(`Applied scale: ${scale}`);
      
      this.add(this.bg);
      
      // Debug rectangle to show boundary
      const debugRect = scene.add.rectangle(
        0, 0, 
        this.bg.displayWidth, this.bg.displayHeight, 
        0xff0000, 0.2
      );
      this.debugContainer.add(debugRect);
    } else {
      console.warn(`Texture ${textureKey} does NOT exist!`);
      // Fallback - add colored rectangle with lab name
      const rect = scene.add.rectangle(0, 0, 150, 120, frameColor, 0.6);
      this.add(rect);
      
      const labName = scene.add.text(0, 0, lab.name, {
        fontSize: '12px',
        color: '#FFFFFF'
      }).setOrigin(0.5);
      this.add(labName);
    }
    
    // Add debug text with coordinates and dimensions
    this.debugText = scene.add.text(0, -70, 
      `Lab: ${lab.name}\nPos: (${x}, ${y})\nTexture: ${textureKey}`, 
      { fontSize: '10px', color: '#FFFF00', backgroundColor: '#000000' }
    ).setOrigin(0.5, 0);
    this.debugContainer.add(this.debugText);
    
    // Make the container interactive
    this.setSize(150, 120);
    this.setInteractive();
    
    // Add a debug border to show interactive area
    const interactiveBounds = scene.add.rectangle(
      0, 0, 150, 120, 0x00ff00, 0
    ).setStrokeStyle(2, 0x00ff00);
    this.debugContainer.add(interactiveBounds);
    
    scene.add.existing(this);
  }
  
  // Metodo per gestire l'interattività in modo più semplice
  setOnClick(callback: () => void): void {
    this.off('pointerdown'); // Rimuove eventuali handler precedenti
    this.on('pointerdown', callback);
  }
  
  updateResearchers(researchers: ResearcherType[]): void {
    this.researchers = researchers;
    console.log(`Updating ${researchers.length} researchers for ${this.lab.name}`);
    
    // Clear existing agent sprites
    this.agentSprites.forEach(sprite => sprite.destroy());
    this.agentSprites = [];
    
    // Create a grid layout for researchers
    const cols = 5;
    const spriteSize = 20; // Size of each researcher sprite
    const startX = -60;
    const startY = 30;
    
    // Use the stored scene reference
    const scene = this.gameScene;
    
    researchers.forEach((researcher, index) => {
      const col = index % cols;
      const row = Math.floor(index / cols);
      const x = startX + col * spriteSize;
      const y = startY + row * spriteSize;
      
      // Try to get appropriate sprite for researcher type
      const spriteKey = this.getResearcherSpriteKey(researcher.type);
      console.log(`Researcher ${researcher.id} sprite key: ${spriteKey}`);
      
      if (scene.textures.exists(spriteKey)) {
        console.log(`Texture ${spriteKey} exists!`);
        const sprite = scene.add.sprite(x, y, spriteKey).setScale(0.5);
        
        // Add colored circle behind sprite for visibility
        const circle = scene.add.circle(x, y, 8, 0x000000, 0.5);
        this.add(circle);
        
        this.add(sprite);
        this.agentSprites.push(sprite);
      } else {
        console.warn(`Texture ${spriteKey} does NOT exist! Using fallback.`);
        // Fallback to colored circle
        const circle = scene.add.circle(x, y, 8, 0xFFFFFF, 1);
        this.add(circle);
        this.agentSprites.push(circle as unknown as Phaser.GameObjects.Sprite);
      }
    });
    
    // Update debug text with researcher count
    this.debugText.setText(
      `Lab: ${this.lab.name}\nPos: (${this.x}, ${this.y})\nResearchers: ${researchers.length}`
    );
  }
  
  /**
   * Aggiorna la posizione degli agenti nella miniatura del laboratorio.
   * Questo metodo è richiesto da GlobalAgentController.
   * @param agents Array di agenti da visualizzare nella miniatura
   */
  updateAgentPositions(agents: any[]): void {
    // Converti i dati degli agenti in formato ResearcherType per compatibilità
    const researchers: ResearcherType[] = agents.map(agent => ({
      id: agent.id,
      name: agent.type, // Usa il tipo come nome se non c'è il nome
      type: agent.type,
      labId: this.lab.id
    }));
    
    // Utilizza il metodo updateResearchers per la visualizzazione effettiva
    this.updateResearchers(researchers);
    
    // Log per debug
    console.log(`Updated positions for ${agents.length} agents in ${this.lab.name}`);
  }
  
  getLabTextureKey(): string {
    // Use the stored scene reference
    const scene = this.gameScene;
    
    // Debug: log all available textures
    console.log("Available textures:", Object.keys(scene.textures.list));
    
    // Try multiple possible paths
    const possibleKeys = [
      `lab_${this.lab.id}_miniature`,
      `lab_${this.lab.name}_miniature`,
      `lab_${this.lab.name.toLowerCase()}_miniature`,
      `lab_${this.lab.id}`,
      `lab_${this.lab.name}`,
      `lab_${this.lab.name.toLowerCase()}`,
      `${this.lab.id}-miniature`,
      `${this.lab.name}-miniature`,
      `${this.lab.id}`,
      `${this.lab.name}`,
      // Add more possible paths as needed
    ];
    
    console.log("Possible texture keys:", possibleKeys);
    
    // Return the first key that exists, or a default
    for (const key of possibleKeys) {
      if (scene.textures.exists(key)) {
        return key;
      }
    }
    
    // If we reach here, no texture was found
    console.warn(`No texture found for lab ${this.lab.id} (${this.lab.name})`);
    return 'default_lab';
  }
  
  getResearcherSpriteKey(researcherType: string): string {
    // Use the stored scene reference
    const scene = this.gameScene;
    
    // Try different naming patterns
    const possibleKeys = [
      `researcher_${researcherType.toLowerCase()}`,
      `researcher_${researcherType}`,
      `agent_${researcherType.toLowerCase()}`,
      `agent_${researcherType}`,
      researcherType.toLowerCase(),
      researcherType
    ];
    
    for (const key of possibleKeys) {
      if (scene.textures.exists(key)) {
        return key;
      }
    }
    
    return 'default_researcher';
  }
  
  getLabColor(): number {
    switch(this.lab.id) {
      case 'mercatorum':
        return 0xE63946;
      case 'blekinge':
        return 0x457B9D;
      case 'opbg':
        return 0x2A9D8F;
      default:
        return 0xFFFFFF;
    }
  }
  
  // Toggle debug visuals
  toggleDebug(show: boolean): void {
    this.debugContainer.setVisible(show);
  }
}