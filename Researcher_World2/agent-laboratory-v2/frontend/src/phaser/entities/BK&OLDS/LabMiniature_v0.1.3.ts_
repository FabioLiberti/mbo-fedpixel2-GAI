import * as Phaser from 'phaser';

// Interfaccia LabConfig integrata
export interface LabConfig {
    name: string;
    id: string;
    backgroundColor: number;
    borderColor: number;
    width: number;
    height: number;
}

export class LabMiniature extends Phaser.GameObjects.Container {
    private background: Phaser.GameObjects.Rectangle;
    private border: Phaser.GameObjects.Rectangle;
    private label: Phaser.GameObjects.Text;
    private agentDots: Phaser.GameObjects.Graphics[] = [];
    private labConfig: LabConfig;
    private labWidth: number;
    private labHeight: number;
    
    constructor(scene: Phaser.Scene, x: number, y: number, width: number, height: number, labConfig: LabConfig) {
        // Usa un cast per evitare problemi di tipo
        super(scene as any, x, y);
        
        this.labWidth = width;
        this.labHeight = height;
        this.labConfig = labConfig;
        
        // Usa cast esplicito per evitare problemi di tipo
        const castedScene = scene as any;
        
        this.background = new Phaser.GameObjects.Rectangle(castedScene, 0, 0, width, height, labConfig.backgroundColor);
        this.background.setOrigin(0);
        this.add(this.background);
        
        this.border = new Phaser.GameObjects.Rectangle(castedScene, 0, 0, width, height, 0xffffff, 0);
        this.border.setOrigin(0);
        this.border.setStrokeStyle(2, labConfig.borderColor);
        this.add(this.border);
        
        this.label = new Phaser.GameObjects.Text(castedScene, width / 2, 10, labConfig.name, {
            fontFamily: 'Arial',
            fontSize: '12px',
            color: '#ffffff'
        });
        this.label.setOrigin(0.5, 0);
        this.add(this.label);
        
        // Aggiungiamo il container alla scena
        scene.add.existing(this);
    }
    
    /**
     * Aggiorna la visualizzazione degli agenti nella miniatura del laboratorio
     * @param agents Array di agenti nel laboratorio
     */
    public updateAgents(agents: any[]): void {
        // Elimina i punti agente esistenti
        this.agentDots.forEach(dot => dot.destroy());
        this.agentDots = [];
        
        // Crea un nuovo oggetto Graphics per disegnare tutti i punti
        const graphics = new Phaser.GameObjects.Graphics(this.scene as any);
        this.add(graphics);
        this.agentDots.push(graphics);
        
        // Aggiungi i nuovi punti agente
        agents.forEach(agent => {
            // Calcola la posizione relativa nella miniatura basata sulla posizione dell'agente nel laboratorio
            const relX = (agent.x / this.labConfig.width) * this.labWidth;
            const relY = (agent.y / this.labConfig.height) * this.labHeight;
            
            // Aggiungi il punto agente
            this.addAgentDot(graphics, relX, relY, agent.type);
        });
    }
    
    /**
     * Disegna un piccolo cerchio rappresentante un agente nella miniatura del laboratorio
     * @param graphics Oggetto Graphics su cui disegnare
     * @param x Posizione x nella miniatura
     * @param y Posizione y nella miniatura
     * @param agentType Tipo di agente
     */
    private addAgentDot(graphics: Phaser.GameObjects.Graphics, x: number, y: number, agentType: string): void {
        const color = this.getAgentColor(agentType);
        
        // Disegna un cerchio molto piccolo e semitrasparente
        graphics.fillStyle(color, 0.6);  // Opacità 0.6
        graphics.fillCircle(x, y, 2);    // Raggio 2 pixel
    }
    
    /**
     * Ottiene il colore associato al tipo di agente
     * @param agentType Tipo di agente
     * @returns Codice colore in formato esadecimale
     */
    private getAgentColor(agentType: string): number {
        switch (agentType) {
            case 'PhDStudent':
                return 0x4287f5; // Blu
            case 'Researcher':
                return 0x42f587; // Verde
            case 'Professor':
                return 0xf54242; // Rosso
            case 'MLEngineer':
                return 0xf5a742; // Arancione
            case 'DataEngineer':
                return 0x9042f5; // Viola
            case 'PrivacySpecialist':
                return 0xf542e9; // Rosa
            case 'MedicalDoctor':
                return 0x42f5f5; // Ciano
            case 'BiomedicalEngineer':
                return 0xf5f542; // Giallo
            default:
                return 0xffffff; // Bianco come colore di default
        }
    }
    
    /**
     * Imposta lo stato di selezione della miniatura
     * @param selected True se selezionato, false altrimenti
     */
    public setSelected(selected: boolean): void {
        // Enfatizza il bordo quando selezionato
        const borderWidth = selected ? 3 : 2;
        const borderColor = selected ? 0xffff00 : this.labConfig.borderColor;
        
        this.border.setStrokeStyle(borderWidth, borderColor);
    }
    
    /**
     * Ottiene la configurazione del laboratorio associata a questa miniatura
     * @returns Configurazione del laboratorio
     */
    public getLabConfig(): LabConfig {
        return this.labConfig;
    }
    
    /**
     * Gestisce l'interazione quando la miniatura viene cliccata
     * @param callback Funzione da chiamare quando la miniatura viene cliccata
     */
    public setInteractive(callback?: () => void): this {
        this.background.setInteractive({ useHandCursor: true });
        
        if (callback) {
            this.background.on('pointerdown', callback);
        }
        
        return this;
    }
    
    /**
     * Pulisce le risorse quando la miniatura viene distrutta
     */
    public destroy(): void {
        this.agentDots.forEach(dot => dot.destroy());
        super.destroy();
    }
}