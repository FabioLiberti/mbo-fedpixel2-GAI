// frontend/src/phaser/entities/LabMiniature.ts

import * as Phaser from 'phaser';
import { LabType } from '../types/LabType';
import { ResearcherType } from '../types/ResearcherType';

// Interfaccia estesa per gli agenti con coordinate specifiche per la miniatura
interface ExtendedAgentData {
  id: string;
  type: string;
  labScene: string;
  x: number;
  y: number;
  miniX?: number;
  miniY?: number;
  state?: string;
}

export default class LabMiniature extends Phaser.GameObjects.Container {
  private lab: LabType;
  private researchers: ResearcherType[] = [];
  private bg!: Phaser.GameObjects.Image;
  private frame: Phaser.GameObjects.Rectangle;
  private agentSprites: Map<string, Phaser.GameObjects.Sprite> = new Map();
  private agentCircles: Map<string, Phaser.GameObjects.Graphics> = new Map();
  private debugText: Phaser.GameObjects.Text;
  private debugContainer: Phaser.GameObjects.Container;
  private gameScene: any;
  
  // Aggiungiamo la proprietà targetScene per risolvere l'errore
  public targetScene: string = '';
  public name: string = '';

  constructor(scene: any, x: number, y: number, lab: LabType) {
    super(scene, x, y);
    this.lab = lab;
    this.gameScene = scene;
    
    // Impostiamo il nome dal lab passato come parametro
    this.name = lab.name;
    
    console.log(`Creating lab miniature for ${lab.name} at (${x}, ${y})`);
    
    // Create debug container to hold all debug elements
    this.debugContainer = new Phaser.GameObjects.Container(scene, 0, 0);
    this.add(this.debugContainer);
    
    // Add colored frame first (as background)
    const frameColor = this.getLabColor();
    this.frame = scene.add.rectangle(0, 0, 150, 120, frameColor, 0.2);
    this.frame.setStrokeStyle(4, frameColor, 1.0);
    this.add(this.frame);
    
    // Try to get the texture key for this lab
    const textureKey = this.getLabTextureKey();
    console.log(`Lab ${lab.name} texture key: ${textureKey}`);
    
    // Check if texture exists
    if (scene.textures.exists(textureKey)) {
      console.log(`Texture ${textureKey} exists!`);
      
      // Get texture dimensions for debugging
      const textureFrame = scene.textures.getFrame(textureKey);
      console.log(`Texture dimensions: ${textureFrame.width}x${textureFrame.height}`);

      // Create background with lab image
      this.bg = scene.add.image(0, 0, textureKey);
      
      // Debug scaling - let's try different scale approaches
      // Scale to fit within 150x120 while maintaining aspect ratio
      const scale = Math.min(150 / textureFrame.width, 120 / textureFrame.height);
      this.bg.setScale(scale);
      console.log(`Applied scale: ${scale}`);
      
      this.add(this.bg);
      
      // Debug rectangle to show boundary
      const debugRect = scene.add.rectangle(
        0, 0, 
        this.bg.displayWidth, this.bg.displayHeight, 
        0xff0000, 0.2
      );
      this.debugContainer.add(debugRect);
    } else {
      console.warn(`Texture ${textureKey} does NOT exist!`);
      // Fallback - add colored rectangle with lab name
      const rect = scene.add.rectangle(0, 0, 150, 120, frameColor, 0.6);
      this.add(rect);
      
      const labName = scene.add.text(0, 0, lab.name, {
        fontSize: '12px',
        color: '#FFFFFF'
      }).setOrigin(0.5);
      this.add(labName);
    }
    
    // Add debug text with coordinates and dimensions
    this.debugText = scene.add.text(0, -70, 
      `Lab: ${lab.name}\nPos: (${x}, ${y})\nTexture: ${textureKey}`, 
      { fontSize: '10px', color: '#FFFF00', backgroundColor: '#000000' }
    ).setOrigin(0.5, 0);
    this.debugContainer.add(this.debugText);
    
    // Make the container interactive
    this.setSize(150, 120);
    this.setInteractive();
    
    // Add a debug border to show interactive area
    const interactiveBounds = scene.add.rectangle(
      0, 0, 150, 120, 0x00ff00, 0
    ).setStrokeStyle(2, 0x00ff00);
    this.debugContainer.add(interactiveBounds);
    
    scene.add.existing(this);
  }
  
  // Metodo per gestire l'interattività in modo più semplice
  setOnClick(callback: () => void): void {
    this.off('pointerdown'); // Rimuove eventuali handler precedenti
    this.on('pointerdown', callback);
  }
  
  /**
   * Aggiorna la posizione degli agenti nella miniatura del laboratorio.
   * Questo metodo è richiesto da GlobalAgentController.
   * @param agents Array di agenti da visualizzare nella miniatura
   */
  updateAgentPositions(agents: ExtendedAgentData[]): void {
    // Riduciamo i log per evitare spam nella console
    // Console log solo se c'è stato un cambiamento significativo nel numero di agenti
    const currentAgentCount = this.agentSprites.size;
    if (Math.abs(currentAgentCount - agents.length) > 0) {
      console.log(`Updating positions for ${agents.length} agents in ${this.lab.name}`);
    }
    
    // Crea un Set con gli ID degli agenti correnti
    const currentAgentIds = new Set(agents.map(agent => agent.id));
    
    // Rimuovi gli agenti che non sono più presenti
    // Usa Array.from per essere compatibile con versioni meno recenti di TypeScript
    Array.from(this.agentSprites.keys()).forEach(id => {
      if (!currentAgentIds.has(id)) {
        // Rimuovi lo sprite dell'agente
        const sprite = this.agentSprites.get(id);
        if (sprite) {
          sprite.destroy();
        }
        this.agentSprites.delete(id);
        
        // Rimuovi il cerchio dell'agente
        const circle = this.agentCircles.get(id);
        if (circle) {
          circle.destroy();
        }
        this.agentCircles.delete(id);
      }
    });
    
    // Aggiorna o crea gli agenti correnti
    agents.forEach(agent => {
      // Usiamo le coordinate specifiche per la miniatura se disponibili
      const x = agent.miniX !== undefined ? agent.miniX : 0;
      const y = agent.miniY !== undefined ? agent.miniY : 0;
      
      // Controlla se l'agente esiste già
      if (this.agentSprites.has(agent.id)) {
        // Aggiorna la posizione dell'agente esistente
        const sprite = this.agentSprites.get(agent.id);
        const circle = this.agentCircles.get(agent.id);
        
        if (sprite) {
          // Usa tween per animare il movimento
          this.gameScene.tweens.add({
            targets: sprite,
            x: x,
            y: y,
            duration: 300,
            ease: 'Sine.easeInOut'
          });
        }
        
        if (circle) {
          // Usa tween per animare il movimento
          this.gameScene.tweens.add({
            targets: circle,
            x: x,
            y: y,
            duration: 300,
            ease: 'Sine.easeInOut'
          });
        }
      } else {
        // Crea un nuovo agente
        this.createAgent(agent, x, y);
      }
    });
    
    // Update debug text with agent count
    this.debugText.setText(
      `Lab: ${this.lab.name}\nPos: (${this.x}, ${this.y})\nAgents: ${agents.length}`
    );
  }
  
  /**
   * Crea un nuovo agente nella miniatura
   */
  private createAgent(agent: ExtendedAgentData, x: number, y: number): void {
    const scene = this.gameScene;
    
    // Try to get appropriate sprite for agent type
    const spriteKey = this.getResearcherSpriteKey(agent.type);
    console.log(`Agent ${agent.id} sprite key: ${spriteKey}`);
    
    // Crea un cerchio colorato per l'agente
    const color = this.getAgentColor(agent.type);
    const circle = scene.add.graphics();
    circle.fillStyle(color, 0.7);
    circle.fillCircle(0, 0, 8);
    circle.setPosition(x, y);
    this.add(circle);
    this.agentCircles.set(agent.id, circle);
    
    if (scene.textures.exists(spriteKey)) {
      // Crea lo sprite dell'agente
      const sprite = scene.add.sprite(x, y, spriteKey).setScale(0.5);
      this.add(sprite);
      this.agentSprites.set(agent.id, sprite);
    } else {
      // Se lo sprite non esiste, crea un testo con l'iniziale del tipo
      const initial = this.getAgentInitial(agent.type);
      const text = scene.add.text(x, y, initial, {
        fontSize: '10px',
        color: '#FFFFFF',
        fontStyle: 'bold'
      }).setOrigin(0.5);
      this.add(text);
      // Usiamo il testo come sprite per semplicità
      this.agentSprites.set(agent.id, text as unknown as Phaser.GameObjects.Sprite);
    }
  }
  
  getLabTextureKey(): string {
    // Use the stored scene reference
    const scene = this.gameScene;
    
    // Try multiple possible paths
    const possibleKeys = [
      `lab_${this.lab.id}_miniature`,
      `lab_${this.lab.name}_miniature`,
      `lab_${this.lab.name.toLowerCase()}_miniature`,
      `lab_${this.lab.id}`,
      `lab_${this.lab.name}`,
      `lab_${this.lab.name.toLowerCase()}`,
      `${this.lab.id}-miniature`,
      `${this.lab.name}-miniature`,
      `${this.lab.id}`,
      `${this.lab.name}`,
    ];
    
    // Return the first key that exists, or a default
    for (const key of possibleKeys) {
      if (scene.textures.exists(key)) {
        return key;
      }
    }
    
    // If we reach here, no texture was found
    console.warn(`No texture found for lab ${this.lab.id} (${this.lab.name})`);
    return 'default_lab';
  }
  
  getResearcherSpriteKey(researcherType: string): string {
    // Use the stored scene reference
    const scene = this.gameScene;
    
    // Try different naming patterns
    const possibleKeys = [
      `researcher_${researcherType.toLowerCase()}`,
      `researcher_${researcherType}`,
      `agent_${researcherType.toLowerCase()}`,
      `agent_${researcherType}`,
      researcherType.toLowerCase(),
      researcherType
    ];
    
    for (const key of possibleKeys) {
      if (scene.textures.exists(key)) {
        return key;
      }
    }
    
    return 'default_researcher';
  }
  
  getLabColor(): number {
    switch(this.lab.id) {
      case 'mercatorum':
        return 0xE63946;
      case 'blekinge':
        return 0x457B9D;
      case 'opbg':
        return 0x2A9D8F;
      default:
        return 0xFFFFFF;
    }
  }
  
  getAgentColor(agentType: string): number {
    switch(agentType.toLowerCase()) {
      case 'professor':
        return 0xE63946;
      case 'researcher':
        return 0x457B9D;
      case 'phd_student':
        return 0x2A9D8F;
      case 'doctor':
        return 0x9B5DE5;
      case 'ml_engineer':
        return 0xF15BB5;
      case 'biomedical':
        return 0xFEE440;
      default:
        return 0xFFFFFF;
    }
  }
  
  getAgentInitial(agentType: string): string {
    switch(agentType.toLowerCase()) {
      case 'professor':
        return 'P';
      case 'researcher':
        return 'R';
      case 'phd_student':
        return 'S';
      case 'doctor':
        return 'D';
      case 'ml_engineer':
        return 'E';
      case 'biomedical':
        return 'B';
      default:
        return 'A';
    }
  }
  
  // Toggle debug visuals
  toggleDebug(show: boolean): void {
    this.debugContainer.setVisible(show);
  }
}