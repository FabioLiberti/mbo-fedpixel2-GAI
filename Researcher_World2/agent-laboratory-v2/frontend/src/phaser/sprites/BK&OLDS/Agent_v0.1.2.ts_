/**
 * Base Agent class for all interactive entities in Agent Laboratory
 * Provides common functionality for all agent types
 */

import { Scene } from 'phaser';
import { Pathfinder } from '../utils/pathfinding';

/**
 * Agent states based on the design document
 */
export enum AgentState {
  WORKING = 'WORKING',
  MEETING = 'MEETING',
  RESTING = 'RESTING',
  MOVING = 'MOVING',
  DISCUSSING = 'DISCUSSING',
  PRESENTING = 'PRESENTING'
}

/**
 * Base properties for all agents
 */
export interface AgentConfig {
  scene: Scene;
  x: number;
  y: number;
  texture: string;
  frame?: string | number;
  name: string;
  speed?: number;
  pathfinder?: Pathfinder;
}

/**
 * Base Agent class that all specific agent types will extend
 */
export class Agent extends Phaser.GameObjects.Sprite {
  // Basic properties
  public name: string;
  public speed: number;
  protected state: AgentState;
  protected targetPosition: { x: number, y: number } | null;
  protected currentPath: { x: number, y: number }[] | null;
  protected pathfinder: Pathfinder | null;
  protected currentPathIndex: number;
  
  // Physics body for movement and collisions
  protected body: Phaser.Physics.Arcade.Body | null;

  /**
   * Create a new agent
   */
  constructor(config: AgentConfig) {
    super(config.scene, config.x, config.y, config.texture, config.frame);
    
    this.name = config.name;
    this.speed = config.speed || 60; // Default speed if not specified
    this.state = AgentState.RESTING; // Default initial state
    this.targetPosition = null;
    this.currentPath = null;
    this.currentPathIndex = 0;
    this.pathfinder = config.pathfinder || null;
    
    // Add to scene
    config.scene.add.existing(this);
    
    // Enable physics if the physics system is active
    if (config.scene.physics && config.scene.physics.world) {
      config.scene.physics.world.enable(this);
      this.body = this.body as Phaser.Physics.Arcade.Body;
      
      // Set up physics body properties
      if (this.body) {
        this.body.setCollideWorldBounds(true);
        this.body.setBounce(0);
        this.body.setFriction(0, 0);
      }
    } else {
      this.body = null;
    }
  }
  
  /**
   * Get the current state of the agent
   */
  public getState(): AgentState {
    return this.state;
  }
  
  /**
   * Set a new state for the agent
   */
  public setState(newState: AgentState): void {
    if (this.state !== newState) {
      const prevState = this.state;
      this.state = newState;
      this.onStateChange(prevState, newState);
    }
  }
  
  /**
   * Callback when agent state changes
   * Can be overridden by subclasses
   */
  protected onStateChange(prevState: AgentState, newState: AgentState): void {
    // Update animation based on new state
    this.updateAnimation();
  }
  
  /**
   * Update the agent's animation based on current state and direction
   * To be implemented by subclasses
   */
  protected updateAnimation(): void {
    // Base implementation - override in subclasses
  }
  
  /**
   * Move the agent to a specific position using pathfinding
   */
  public moveTo(x: number, y: number): boolean {
    if (!this.pathfinder) {
      console.warn(`Agent ${this.name} tried to move but has no pathfinder`);
      return false;
    }
    
    this.targetPosition = { x, y };
    this.setState(AgentState.MOVING);
    
    // Calculate path using pathfinder
    this.currentPath = this.pathfinder.findPathWorld(this.x, this.y, x, y);
    this.currentPathIndex = 0;
    
    if (!this.currentPath || this.currentPath.length === 0) {
      console.warn(`Agent ${this.name} couldn't find path to (${x}, ${y})`);
      this.setState(AgentState.RESTING);
      return false;
    }
    
    return true;
  }

  /**
   * Stop the agent's current movement
   */
  public stopMovement(): void {
    if (this.state === AgentState.MOVING) {
      this.setState(AgentState.RESTING);
    }
    
    this.targetPosition = null;
    this.currentPath = null;
    
    if (this.body) {
      this.body.setVelocity(0, 0);
    }
  }
  
  /**
   * Update method called on each frame
   */
  public update(time: number, delta: number): void {
    // Handle movement if agent is in MOVING state
    if (this.state === AgentState.MOVING) {
      this.updateMovement(delta);
    }
    
    // Other state-specific updates can be added here
  }
  
  /**
   * Update agent movement along current path
   */
  private updateMovement(delta: number): void {
    if (!this.currentPath || this.currentPathIndex >= this.currentPath.length) {
      this.stopMovement();
      return;
    }
    
    // Get current target point in path
    const targetPoint = this.currentPath[this.currentPathIndex];
    
    // Calculate distance to next point
    const dx = targetPoint.x - this.x;
    const dy = targetPoint.y - this.y;
    const distance = Math.sqrt(dx * dx + dy * dy);
    
    // Check if we've reached the current path point
    if (distance < 2) {
      // Move to next point in path
      this.currentPathIndex++;
      
      // If we've reached the end of the path
      if (this.currentPathIndex >= this.currentPath.length) {
        this.stopMovement();
        // Trigger arrival event
        this.onArrived();
        return;
      }
    }
    
    // Move towards the current target point
    if (this.body) {
      // Normalize direction vector
      const normalizedDx = dx / distance;
      const normalizedDy = dy / distance;
      
      // Set velocity based on speed
      this.body.setVelocity(
        normalizedDx * this.speed,
        normalizedDy * this.speed
      );
      
      // Update facing direction for animations
      this.updateFacingDirection(normalizedDx, normalizedDy);
    } else {
      // Fallback for when physics isn't enabled
      this.x += (dx / distance) * (this.speed * delta / 1000);
      this.y += (dy / distance) * (this.speed * delta / 1000);
    }
  }
  
  /**
   * Update the agent's facing direction based on movement
   */
  private updateFacingDirection(dx: number, dy: number): void {
    // Determine primary direction (left, right, up, down)
    if (Math.abs(dx) > Math.abs(dy)) {
      // Horizontal movement is dominant
      this.setFlipX(dx < 0);
    }
    
    // Update animation based on new direction
    this.updateAnimation();
  }
  
  /**
   * Callback when agent reaches its destination
   * Can be overridden by subclasses
   */
  protected onArrived(): void {
    // Default behavior is to enter RESTING state
    this.setState(AgentState.RESTING);
  }
  
  /**
   * Destroy agent and clean up resources
   */
  public destroy(): void {
    this.stopMovement();
    super.destroy();
  }
}