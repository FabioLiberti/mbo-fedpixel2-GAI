import Phaser from 'phaser';
import { ResearcherAgent } from './ResearcherAgent';
import { 
  MedicalResearcherState, 
  MedicalResearcherType, 
  MedicalSpecialization,
  ResearcherState 
} from '../../types/AgentTypes';

export class MedicalResearcher extends ResearcherAgent {
  // Stato corrente specifico per medici
  protected override state: MedicalResearcherState = 'idle';
  
  // Tipo specifico di ricercatore medico
  protected medicalType: MedicalResearcherType;
  
  // Competenze mediche (0-100)
  protected medicalSkills: Record<string, number> = {
    'diagnostics': 20,
    'patient-care': 20,
    'medical-analytics': 20,
    'ethics': 20
  };
  
  // Contatori specifici per il medico
  protected patientsAnalyzed: number = 0;
  protected diagnosticsRun: number = 0;
  
  /**
   * Costruttore per il ricercatore medico
   * @param scene La scena Phaser
   * @param x Posizione X iniziale
   * @param y Posizione Y iniziale
   * @param texture La texture/sprite da utilizzare
   * @param type Il tipo di ricercatore medico
   * @param specialization La specializzazione medica
   */
  constructor(
    scene: Phaser.Scene, 
    x: number, 
    y: number, 
    texture: string,
    type: MedicalResearcherType,
    specialization: MedicalSpecialization
  ) {
    // Inizializza come ResearcherAgent con tipo e specializzazione convertiti
    super(
      scene, 
      x, 
      y, 
      texture, 
      'data-engineer', // Tipo base, sarà sovrascritto
      'data-pipeline' // Specializzazione base, sarà sovrascritta
    );
    
    // Imposta il tipo medico specifico
    this.medicalType = type;
    
    // Inizializza le competenze mediche in base al tipo
    this.initializeMedicalSkills();
  }
  
  /**
   * Inizializza le competenze mediche in base al tipo
   */
  private initializeMedicalSkills(): void {
    // Base di competenze mediche
    const baseSkills = {
      'diagnostics': 20,
      'patient-care': 20,
      'medical-analytics': 20,
      'ethics': 20
    };
    
    // Regola le competenze in base al tipo
    switch (this.medicalType) {
      case 'medical-doctor':
        baseSkills['diagnostics'] += 30;
        baseSkills['patient-care'] += 40;
        this.gainKnowledge('clinical-data', 30);
        break;
      case 'biomedical-engineer':
        baseSkills['medical-analytics'] += 40;
        baseSkills['diagnostics'] += 20;
        this.gainKnowledge('medical-imaging', 30);
        break;
    }
    
    this.medicalSkills = baseSkills;
  }
  
  /**
   * Incrementa una competenza medica specifica
   * @param skill La competenza da incrementare
   * @param amount La quantità da aggiungere
   */
  protected gainMedicalSkill(skill: string, amount: number): void {
    if (this.medicalSkills[skill] !== undefined) {
      this.medicalSkills[skill] = Math.min(100, this.medicalSkills[skill] + amount);
    } else {
      this.medicalSkills[skill] = amount;
    }
    
    // Emetti un evento di competenza acquisita
    this.emit('skillGained', { skill, amount, newValue: this.medicalSkills[skill] });
  }
  
  /**
   * Ottieni il livello di una competenza medica
   * @param skill La competenza richiesta
   */
  public getMedicalSkillLevel(skill: string): number {
    return this.medicalSkills[skill] || 0;
  }
  
  /**
   * Avvia un'attività di diagnostica
   */
  public startDiagnostics(): void {
    // Imposta lo stato diagnostica
    this.setAgentState('diagnostics');
    
    // Mostra la barra di progresso
    this.showProgress('Diagnostics');
    this.setProgress(0);
  }
  
  /**
   * Avvia una revisione paziente
   */
  public startPatientReview(): void {
    // Imposta lo stato revisione paziente
    this.setAgentState('patient-review');
    
    // Mostra la barra di progresso
    this.showProgress('Patient Review');
    this.setProgress(0);
  }
  
  /**
   * Override del metodo di aggiornamento
   */
  override update(time: number, delta: number): void {
    super.update(time, delta);
    
    // Gestione stati specifici medici
    switch (this.state) {
      case 'diagnostics':
        this.updateDiagnostics(delta);
        break;
      case 'patient-review':
        this.updatePatientReview(delta);
        break;
      case 'medical-analysis':
        this.updateMedicalAnalysis(delta);
        break;
    }
  }
  
  /**
   * Aggiorna quando il medico sta eseguendo diagnostica
   */
  protected updateDiagnostics(delta: number): void {
    // Incrementa il progresso
    this.setProgress(this.progress + 0.06 * delta / 16);
    
    // Se la diagnostica è completata
    if (this.progress >= 100) {
      // Incrementa le statistiche
      this.diagnosticsRun++;
      
      // Guadagna competenza in diagnostica
      this.gainMedicalSkill('diagnostics', Phaser.Math.Between(1, 3));
      
      // Piccola probabilità di guadagnare conoscenza in privacy (per i dati sensibili)
      if (Phaser.Math.Between(0, 1000) < 5) { // 0.5% probabilità ogni secondo
        this.gainMedicalSkill('ethics', 0.1);
        this.gainKnowledge('privacy', 0.1);
      }
      
      // Ripristina lo stato e nasconde il progresso
      this.setAgentState('idle');
      this.hideProgress();
    }
  }
  
  /**
   * Aggiorna quando il medico sta rivedendo un caso paziente
   */
  protected updatePatientReview(delta: number): void {
    // Incrementa il progresso
    this.setProgress(this.progress + 0.04 * delta / 16);
    
    // Se la revisione è completata
    if (this.progress >= 100) {
      // Incrementa pazienti analizzati
      this.patientsAnalyzed++;
      
      // Guadagna competenza in patient-care
      this.gainMedicalSkill('patient-care', Phaser.Math.Between(1, 2));
      
      // Ripristina lo stato e nasconde il progresso
      this.setAgentState('idle');
      this.hideProgress();
    }
  }
  
  /**
   * Aggiorna quando il medico sta facendo analisi mediche
   */
  protected updateMedicalAnalysis(delta: number): void {
    // Incrementa il progresso
    this.setProgress(this.progress + 0.05 * delta / 16);
    
    // Se l'analisi è completata
    if (this.progress >= 100) {
      // Guadagna competenza in medical-analytics
      this.gainMedicalSkill('medical-analytics', Phaser.Math.Between(1, 3));
      
      // Possibilità di pubblicazione
      if (Phaser.Math.Between(0, 100) < 10) {
        this.addPublication();
      }
      
      // Ripristina lo stato e nasconde il progresso
      this.setAgentState('idle');
      this.hideProgress();
    }
  }
  
  /**
   * Override di chooseRandomState per includere stati specifici medici
   */
  protected override chooseRandomState(): void {
    const medicalStates: MedicalResearcherState[] = [
      'idle', 'moving', 'working', 'resting', 
      'researching', 'analyzing', 'writing',
      'diagnostics', 'patient-review', 'medical-analysis'
    ];
    
    const randomState = medicalStates[Phaser.Math.Between(0, medicalStates.length - 1)];
    
    // Se è scelto moving, trova una posizione casuale
    if (randomState === 'moving') {
      this.moveToRandomPosition();
    } 
    // Se è scelto researching, inizia una ricerca
    else if (randomState === 'researching') {
      this.startResearch();
    }
    // Se è diagnostics, avvia diagnostica
    else if (randomState === 'diagnostics') {
      this.startDiagnostics();
    }
    // Se è patient-review, avvia revisione paziente
    else if (randomState === 'patient-review') {
      this.startPatientReview();
    }
    // Altrimenti imposta lo stato direttamente
    else {
      this.setAgentState(randomState);
    }
    
    // Imposta un nuovo timer per cambiare stato
    this.setRandomStateTimer();
  }
  
  /**
   * Override per impostare lo stato del ricercatore medico
   * @param newState Il nuovo stato
   */
  setAgentState(newState: MedicalResearcherState): void {
    // Chiama il metodo della classe base
    super.setAgentState(newState as ResearcherState);
  }
  
  /**
   * Override per ottenere lo stato
   */
  getState(): MedicalResearcherState {
    return this.state as MedicalResearcherState;
  }
}