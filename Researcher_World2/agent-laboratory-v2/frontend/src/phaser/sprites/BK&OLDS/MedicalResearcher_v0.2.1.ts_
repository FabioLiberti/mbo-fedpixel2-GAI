import Phaser from 'phaser';
import { ResearcherAgent } from './ResearcherAgent';

/**
 * Versione minima del ricercatore medico
 * Implementazione ridotta al minimo per garantire compatibilità
 */
export class MedicalResearcher extends ResearcherAgent {
  // Indicatore visuale di base
  private infoText?: Phaser.GameObjects.Text;
  
  /**
   * Costruttore con parametri di tipo 'any' per evitare problemi di compatibilità
   */
  constructor(scene: Phaser.Scene, x: number, y: number, texture: string, type: any, specialization: any) {
    super(scene, x, y, texture, type, specialization);
  }
  
  /**
   * Override minimo dell'update
   */
  update(time: number, delta: number): void {
    super.update(time, delta);
    
    // Aggiorna posizione dell'eventuale testo informativo
    if (this.infoText) {
      this.infoText.setPosition(this.x, this.y - 35);
    }
  }
  
  /**
   * Metodo semplificato per mostrare informazioni quando il ricercatore viene cliccato
   */
  handleClick(): void {
    // Rimuovi vecchio testo se presente
    if (this.infoText) {
      this.infoText.destroy();
    }
    
    // Crea un popup informativo
    this.infoText = this.scene.add.text(this.x, this.y - 35, 
      "Medical Researcher",
      {
        fontSize: '10px',
        backgroundColor: '#333333',
        padding: { x: 5, y: 3 },
        color: '#ffffff'
      }
    );
    this.infoText.setOrigin(0.5);
    
    // Autodissolve dopo breve tempo
    this.scene.time.delayedCall(2000, () => {
      if (this.infoText) {
        this.scene.tweens.add({
          targets: this.infoText,
          alpha: 0,
          duration: 300,
          onComplete: () => {
            if (this.infoText) {
              this.infoText.destroy();
              this.infoText = undefined;
            }
          }
        });
      }
    });
  }
}