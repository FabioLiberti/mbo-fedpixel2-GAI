import Phaser from 'phaser';
import { Agent } from './Agent';
import { ResearcherState, ResearcherType, ResearcherSpecialization } from '../../types/AgentTypes';

export class ResearcherAgent extends Agent {
  // Stato corrente specifico per ricercatori
  protected state: ResearcherState = 'idle';
  
  // Livello di conoscenza (0-100) nelle diverse aree
  protected knowledge: Record<string, number> = {
    'federated-learning': 10,
    'privacy': 10,
    'optimization': 10,
    'data-science': 10,
    'communication': 10
  };
  
  // Contatori di attività
  protected publications: number = 0;
  protected collaborations: number = 0;
  
  // Tipo di ricercatore e specializzazione
  protected researcherType: ResearcherType;
  protected specialization: ResearcherSpecialization;
  
  // Area di ricerca corrente
  protected currentResearchArea: string | null = null;
  
  // Rete di collaboratori (ID o riferimenti)
  protected collaborators: Set<ResearcherAgent> = new Set();
  
  // Progress bar per la visualizzazione del lavoro
  protected progressBar: Phaser.GameObjects.Graphics | null = null;
  protected progressText: Phaser.GameObjects.Text | null = null;
  protected progress: number = 0;
  
  /**
   * Costruttore per il ricercatore
   * @param scene La scena Phaser
   * @param x Posizione X iniziale
   * @param y Posizione Y iniziale
   * @param texture La texture/sprite da utilizzare
   * @param type Il tipo di ricercatore
   * @param specialization La specializzazione del ricercatore
   */
  constructor(
    scene: Phaser.Scene, 
    x: number, 
    y: number, 
    texture: string, 
    type: ResearcherType,
    specialization: ResearcherSpecialization
  ) {
    super(scene, x, y, texture);
    
    this.researcherType = type;
    this.specialization = specialization;
    
    // Inizializza la conoscenza in base al tipo di ricercatore
    this.initializeKnowledge();
    
    // Crea la barra di progresso per visualizzare il lavoro
    this.createProgressBar();
  }
  
  /**
   * Inizializza la conoscenza in base al tipo di ricercatore
   */
  private initializeKnowledge(): void {
    // Base di conoscenza condivisa
    const baseKnowledge = {
      'federated-learning': 10,
      'privacy': 10,
      'optimization': 10,
      'data-science': 10,
      'communication': 10
    };
    
    // Aggiungi conoscenza specifica in base al tipo
    switch (this.researcherType) {
      case 'phd-student':
        baseKnowledge['data-science'] += 20;
        break;
      case 'postdoc':
        baseKnowledge['federated-learning'] += 30;
        baseKnowledge['optimization'] += 15;
        break;
      case 'professor':
        baseKnowledge['federated-learning'] += 40;
        baseKnowledge['privacy'] += 20;
        baseKnowledge['communication'] += 30;
        break;
      case 'ml-engineer':
        baseKnowledge['optimization'] += 30;
        baseKnowledge['data-science'] += 25;
        break;
      case 'data-engineer':
        baseKnowledge['data-science'] += 40;
        baseKnowledge['communication'] += 20;
        break;
      case 'privacy-specialist':
        baseKnowledge['privacy'] += 50;
        baseKnowledge['federated-learning'] += 15;
        break;
    }
    
    // Aggiungi conoscenza specifica in base alla specializzazione
    switch (this.specialization) {
      case 'data-science':
        baseKnowledge['data-science'] += 15;
        break;
      case 'privacy-engineering':
        baseKnowledge['privacy'] += 15;
        break;
      case 'optimization':
        baseKnowledge['optimization'] += 15;
        break;
      // Altre specializzazioni...
    }
    
    this.knowledge = baseKnowledge;
  }
  
  /**
   * Crea una barra di progresso sopra l'agente
   */
  private createProgressBar(): void {
    // Crea la grafica per la barra di progresso
    this.progressBar = this.scene.add.graphics();
    this.progressBar.setDepth(100);
    
    // Crea il testo per la barra di progresso
    this.progressText = this.scene.add.text(
      this.x, 
      this.y - 20,
      '',
      { fontSize: '8px', color: '#ffffff' }
    );
    this.progressText.setDepth(100);
    this.progressText.setOrigin(0.5);
    
    // Inizialmente la barra di progresso è nascosta
    this.hideProgress();
  }
  
  /**
   * Aggiorna la posizione della barra di progresso
   */
  private updateProgressPosition(): void {
    if (this.progressBar && this.progressText) {
      this.progressBar.clear();
      
      // Disegna la barra solo se ci troviamo in uno stato di lavoro
      if (this.isWorking()) {
        // Sfondo della barra
        this.progressBar.fillStyle(0x000000, 0.5);
        this.progressBar.fillRect(this.x - 15, this.y - 22, 30, 5);
        
        // Barra di progresso
        this.progressBar.fillStyle(0x00ff00, 1);
        this.progressBar.fillRect(this.x - 15, this.y - 22, 30 * (this.progress / 100), 5);
      }
      
      // Aggiorna la posizione del testo
      this.progressText.setPosition(this.x, this.y - 30);
    }
  }
  
  /**
   * Mostra la barra di progresso con un'etichetta
   * @param label L'etichetta da mostrare
   */
  protected showProgress(label: string): void {
    if (this.progressText) {
      this.progressText.setText(label);
      this.progressText.setVisible(true);
    }
    this.updateProgressPosition();
  }
  
  /**
   * Nascondi la barra di progresso
   */
  protected hideProgress(): void {
    if (this.progressBar) {
      this.progressBar.clear();
    }
    if (this.progressText) {
      this.progressText.setVisible(false);
    }
  }
  
  /**
   * Aggiorna il valore della barra di progresso
   * @param value Il nuovo valore (0-100)
   */
  protected setProgress(value: number): void {
    this.progress = Phaser.Math.Clamp(value, 0, 100);
    this.updateProgressPosition();
  }
  
  /**
   * Verifica se il ricercatore sta attualmente lavorando
   */
  protected isWorking(): boolean {
    return ['working', 'researching', 'analyzing', 'writing', 'collaborating'].includes(this.state);
  }
  
  /**
   * Incrementa la conoscenza in un'area specifica
   * @param area L'area di conoscenza da incrementare
   * @param amount La quantità da aggiungere
   */
  protected gainKnowledge(area: string, amount: number): void {
    if (this.knowledge[area] !== undefined) {
      this.knowledge[area] = Math.min(100, this.knowledge[area] + amount);
    } else {
      this.knowledge[area] = amount;
    }
    
    // Emetti un evento di conoscenza acquisita
    this.emit('knowledgeGained', { area, amount, newValue: this.knowledge[area] });
  }
  
  /**
   * Ottieni il livello di conoscenza in un'area specifica
   * @param area L'area di conoscenza
   */
  public getKnowledgeLevel(area: string): number {
    return this.knowledge[area] || 0;
  }
  
  /**
   * Aggiungi una pubblicazione al conteggio del ricercatore
   */
  protected addPublication(): void {
    this.publications++;
    // Emetti un evento di pubblicazione
    this.emit('publication', { total: this.publications });
  }
  
  /**
   * Aggiungi una collaborazione al conteggio
   * @param collaborator Il ricercatore con cui si collabora
   */
  public addCollaboration(collaborator: ResearcherAgent): boolean {
    if (collaborator === this) return false;
    
    // Aggiungi alla rete di collaboratori
    if (!this.collaborators.has(collaborator)) {
      this.collaborators.add(collaborator);
      this.collaborations++;
      
      // Emetti un evento di collaborazione
      this.emit('collaboration', { 
        with: collaborator, 
        total: this.collaborations 
      });
      
      return true;
    }
    
    return false;
  }
  
  /**
   * Sceglie un'area di ricerca in base alle proprie competenze
   */
  protected chooseResearchArea(): string {
    // Lista di possibili aree di ricerca
    const potentialAreas = Object.keys(this.knowledge);
    
    // Sceglie un'area in base alle competenze (privilegiando quelle più alte)
    const sortedAreas = potentialAreas.sort(
      (a, b) => this.knowledge[b] - this.knowledge[a]
    );
    
    // Con una piccola probabilità, scegli un'area casuale per esplorare
    if (Phaser.Math.Between(0, 100) < 20) {
      return Phaser.Utils.Array.GetRandom(potentialAreas);
    }
    
    // Altrimenti scegli una delle aree migliori
    return sortedAreas[Phaser.Math.Between(0, Math.min(2, sortedAreas.length - 1))];
  }
  
  /**
   * Avvia un'attività di ricerca
   */
  public startResearch(): void {
    // Scegli un'area su cui fare ricerca
    this.currentResearchArea = this.chooseResearchArea();
    
    // Imposta lo stato di ricerca
    this.setAgentState('researching');
    
    // Mostra la barra di progresso con l'area di ricerca
    this.showProgress(`Researching: ${this.currentResearchArea}`);
    this.setProgress(0);
  }
  
  /**
   * Override del metodo di aggiornamento
   */
  override update(time: number, delta: number): void {
    super.update(time, delta);
    
    // Aggiorna la posizione della barra di progresso
    this.updateProgressPosition();
    
    // Gestione stati specifici dei ricercatori
    switch (this.state) {
      case 'researching':
        this.updateResearching(delta);
        break;
      case 'analyzing':
        this.updateAnalyzing(delta);
        break;
      case 'writing':
        this.updateWriting(delta);
        break;
      case 'collaborating':
        this.updateCollaborating(delta);
        break;
    }
  }
  
  /**
   * Aggiorna quando il ricercatore sta facendo ricerca
   */
  protected updateResearching(delta: number): void {
    if (!this.currentResearchArea) {
      this.setAgentState('idle');
      return;
    }
    
    // Incrementa il progresso
    this.setProgress(this.progress + 0.05 * delta / 16);
    
    // Se la ricerca è completata
    if (this.progress >= 100) {
      // Guadagna conoscenza nell'area di ricerca
      this.gainKnowledge(this.currentResearchArea, Phaser.Math.Between(2, 5));
      
      // Piccola probabilità di guadagnare conoscenza in aree correlate
      if (Phaser.Math.Between(0, 100) < 30) {
        const relatedArea = this.chooseResearchArea();
        if (relatedArea !== this.currentResearchArea) {
          this.gainKnowledge(relatedArea, Phaser.Math.Between(1, 2));
        }
      }
      
      // Piccola probabilità di pubblicare
      if (Phaser.Math.Between(0, 100) < 5) {
        this.addPublication();
      }
      
      // Cambia stato - può scrivere, analizzare o tornare a idle
      const nextActions = ['writing', 'analyzing', 'idle'];
      const nextAction = Phaser.Utils.Array.GetRandom(nextActions);
      this.setAgentState(nextAction as ResearcherState);
      
      // Reimposta progresso e area di ricerca
      this.currentResearchArea = null;
      this.hideProgress();
    }
  }
  
  /**
   * Aggiorna quando il ricercatore sta analizzando dati
   */
  protected updateAnalyzing(delta: number): void {
    // Comportamento base per l'analisi
    this.setProgress(this.progress + 0.03 * delta / 16);
    
    // Se l'analisi è completata
    if (this.progress >= 100) {
      // Ripristina lo stato e nasconde il progresso
      this.setAgentState('idle');
      this.hideProgress();
    }
  }
  
  /**
   * Aggiorna quando il ricercatore sta scrivendo
   */
  protected updateWriting(delta: number): void {
    // Comportamento base per la scrittura
    this.setProgress(this.progress + 0.02 * delta / 16);
    
    // Se la scrittura è completata
    if (this.progress >= 100) {
      // Alta probabilità di pubblicare
      if (Phaser.Math.Between(0, 100) < 70) {
        this.addPublication();
      }
      
      // Ripristina lo stato e nasconde il progresso
      this.setAgentState('idle');
      this.hideProgress();
    }
  }
  
  /**
   * Aggiorna quando il ricercatore sta collaborando
   */
  protected updateCollaborating(delta: number): void {
    // Comportamento base per la collaborazione
    this.setProgress(this.progress + 0.04 * delta / 16);
    
    // Se la collaborazione è completata
    if (this.progress >= 100) {
      // Ripristina lo stato e nasconde il progresso
      this.setAgentState('idle');
      this.hideProgress();
    }
  }
  
  /**
   * Override di chooseRandomState per includere stati specifici dei ricercatori
   */
  protected override chooseRandomState(): void {
    const researcherStates: ResearcherState[] = [
      'idle', 'moving', 'working', 'resting', 
      'researching', 'analyzing', 'writing', 'collaborating'
    ];
    
    const randomState = researcherStates[Phaser.Math.Between(0, researcherStates.length - 1)];
    
    // Se è scelto moving, trova una posizione casuale
    if (randomState === 'moving') {
      this.moveToRandomPosition();
    } 
    // Se è scelto researching, inizia una ricerca
    else if (randomState === 'researching') {
      this.startResearch();
    }
    // Altrimenti imposta lo stato direttamente
    else {
      this.setAgentState(randomState as ResearcherState);
    }
    
    // Imposta un nuovo timer per cambiare stato
    this.setRandomStateTimer();
  }
  
  /**
   * Override per impostare lo stato del ricercatore
   * @param newState Il nuovo stato
   */
  public setAgentState(newState: ResearcherState): void {
    // Se lo stato non cambia, esci
    if (this.state === newState) return;
    
    // Imposta il nuovo stato
    super.setAgentState(newState as AgentState);
  }
}