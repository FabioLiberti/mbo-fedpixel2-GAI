import Phaser from 'phaser';

// Possibili stati per un agente
export type AgentState = 
  'idle' | 'moving' | 'working' | 'resting' | 'collaborating' | 
  'analyzing' | 'meeting' | 'discussing' | 'presenting';

/**
 * Classe base per tutti gli agenti nel simulatore.
 * Gestisce il movimento, le animazioni e gli stati di base.
 */
export class Agent extends Phaser.Physics.Arcade.Sprite {
  // Stato corrente dell'agente
  protected state: AgentState = 'idle';
  
  // Destinazione del movimento
  protected targetX: number | null = null;
  protected targetY: number | null = null;
  
  // Velocità di movimento
  protected moveSpeed: number = 50;
  
  // Contatori per cambi di stato automatici
  protected stateTimer: number = 0;
  protected stateDuration: number = 0;
  
  // Bolla di dialogo/stato
  protected statusBubble: Phaser.GameObjects.Container | null = null;
  
  /**
   * Costruttore dell'agente
   * @param scene La scena a cui appartiene l'agente
   * @param x Posizione X iniziale
   * @param y Posizione Y iniziale
   * @param texture Chiave della texture da utilizzare
   * @param frame Frame iniziale dello spritesheet
   */
  constructor(
    scene: Phaser.Scene,
    x: number,
    y: number,
    texture: string,
    frame?: string | number
  ) {
    super(scene, x, y, texture, frame);
    
    // Aggiungi l'agente alla scena
    scene.add.existing(this);
    scene.physics.add.existing(this);
    
    // Imposta una collisione leggera per evitare che gli agenti si sovrappongano
    this.body.setSize(12, 12); // Dimensione del body minore dell'agente
    this.body.setOffset(2, 12); // Offset per posizionare il body correttamente
    
    // Configura la fisica
    this.body.setBounce(0.1, 0.1);
    this.body.setDamping(true);
    this.body.setDrag(0.9, 0.9);
    
    // Crea le animazioni
    this.createAnimations();
    
    // Imposta timer per cambio di stato casuale
    this.setRandomStateDuration();
  }
  
  /**
   * Aggiorna lo stato e il movimento dell'agente
   * @param time Tempo corrente
   * @param delta Delta time tra i frame
   */
  update(time: number, delta: number): void {
    // Aggiorna il timer di stato
    this.stateTimer += delta;
    
    // Controlla se è il momento di cambiare stato
    if (this.stateTimer >= this.stateDuration) {
      this.pickRandomState();
      this.setRandomStateDuration();
    }
    
    // Gestisci il movimento se c'è una destinazione
    if (this.targetX !== null && this.targetY !== null) {
      this.moveToTarget();
    } else if (this.state === 'moving') {
      // Se è in stato di movimento ma non ha una destinazione, trova una nuova destinazione
      this.findRandomDestination();
    }
    
    // Aggiorna la bolla di stato
    this.updateStatusBubble();
  }
  
  /**
   * Imposta lo stato dell'agente
   * @param newState Il nuovo stato
   */
  setState(newState: AgentState): void {
    // Se lo stato non cambia, esci
    if (this.state === newState) return;
    
    // Aggiorna lo stato
    this.state = newState;
    
    // Reset del timer di stato
    this.stateTimer = 0;
    this.setRandomStateDuration();
    
    // Aggiorna l'animazione in base allo stato
    this.playStateAnimation();
    
    // Se non è in movimento, ferma il movimento
    if (newState !== 'moving') {
      this.stopMoving();
    }
    
    // Crea o aggiorna la bolla di stato
    this.createOrUpdateStatusBubble();
  }
  
  /**
   * Ottieni lo stato corrente dell'agente
   */
  getState(): AgentState {
    return this.state;
  }
  
  /**
   * Crea le animazioni per l'agente
   * Da sovrascrivere nelle sottoclassi per animazioni specifiche
   */
  protected createAnimations(): void {
    // Esempi di animazioni base, le sottoclassi dovrebbero sovrascrivere
    
    // Animazione idle
    if (!this.scene.anims.exists(`${this.texture.key}-idle`)) {
      this.scene.anims.create({
        key: `${this.texture.key}-idle`,
        frames: this.scene.anims.generateFrameNumbers(this.texture.key, { start: 0, end: 3 }),
        frameRate: 5,
        repeat: -1
      });
    }
    
    // Animazione di movimento
    if (!this.scene.anims.exists(`${this.texture.key}-walk`)) {
      this.scene.anims.create({
        key: `${this.texture.key}-walk`,
        frames: this.scene.anims.generateFrameNumbers(this.texture.key, { start: 4, end: 7 }),
        frameRate: 10,
        repeat: -1
      });
    }
    
    // Animazione di lavoro
    if (!this.scene.anims.exists(`${this.texture.key}-work`)) {
      this.scene.anims.create({
        key: `${this.texture.key}-work`,
        frames: this.scene.anims.generateFrameNumbers(this.texture.key, { start: 8, end: 11 }),
        frameRate: 8,
        repeat: -1
      });
    }
  }
  
  /**
   * Riproduce l'animazione appropriata in base allo stato
   */
  protected playStateAnimation(): void {
    switch (this.state) {
      case 'idle':
        this.anims.play(`${this.texture.key}-idle`, true);
        break;
      case 'moving':
        this.anims.play(`${this.texture.key}-walk`, true);
        break;
      case 'working':
      case 'analyzing':
        this.anims.play(`${this.texture.key}-work`, true);
        break;
      // Altre animazioni per altri stati possono essere aggiunte qui
      default:
        // Fallback all'animazione idle
        this.anims.play(`${this.texture.key}-idle`, true);
    }
  }
  
  /**
   * Trova una destinazione casuale sulla mappa
   */
  protected findRandomDestination(): void {
    // Trova una posizione casuale valida nella scena
    const width = this.scene.physics.world.bounds.width;
    const height = this.scene.physics.world.bounds.height;
    
    // Generiamo una posizione all'interno dei confini
    let x = Phaser.Math.Between(50, width - 50);
    let y = Phaser.Math.Between(50, height - 50);
    
    // Imposta la destinazione
    this.setTarget(x, y);
  }
  
  /**
   * Imposta la destinazione dell'agente
   * @param x Coordinata X
   * @param y Coordinata Y
   */
  setTarget(x: number, y: number): void {
    this.targetX = x;
    this.targetY = y;
    
    // Se non è già in movimento, imposta lo stato
    if (this.state !== 'moving') {
      this.setState('moving');
    }
  }
  
  /**
   * Muove l'agente verso la destinazione corrente
   */
  protected moveToTarget(): void {
    if (this.targetX === null || this.targetY === null) return;
    
    // Calcola la direzione verso la destinazione
    const dx = this.targetX - this.x;
    const dy = this.targetY - this.y;
    const distance = Math.sqrt(dx * dx + dy * dy);
    
    // Se è abbastanza vicino alla destinazione, ferma il movimento
    if (distance < 5) {
      this.stopMoving();
      return;
    }
    
    // Normalizza la direzione
    const dirX = dx / distance;
    const dirY = dy / distance;
    
    // Imposta la velocità
    this.body.setVelocity(dirX * this.moveSpeed, dirY * this.moveSpeed);
    
    // Aggiorna il flip in base alla direzione
    if (dirX < 0) {
      this.setFlipX(true);
    } else if (dirX > 0) {
      this.setFlipX(false);
    }
  }
  
  /**
   * Ferma il movimento dell'agente
   */
  protected stopMoving(): void {
    // Azzera la velocità
    this.body.setVelocity(0, 0);
    
    // Reimposta la destinazione
    this.targetX = null;
    this.targetY = null;
    
    // Se lo stato è in movimento, cambia a idle
    if (this.state === 'moving') {
      this.setState('idle');
    }
  }
  
  /**
   * Sceglie uno stato casuale appropriato
   */
  protected pickRandomState(): void {
    // Stati possibili per un cambio casuale
    const possibleStates: AgentState[] = ['idle', 'moving', 'working', 'resting'];
    
    // Evita di selezionare lo stesso stato attuale
    let filteredStates = possibleStates.filter(s => s !== this.state);
    
    // Se non ci sono stati disponibili, usa tutti
    if (filteredStates.length === 0) {
      filteredStates = possibleStates;
    }
    
    // Seleziona uno stato casuale
    const newState = Phaser.Utils.Array.GetRandom(filteredStates);
    
    // Imposta il nuovo stato
    this.setState(newState);
  }
  
  /**
   * Imposta una durata casuale per lo stato corrente
   */
  protected setRandomStateDuration(): void {
    // Durata base in base allo stato
    let baseDuration = 0;
    switch (this.state) {
      case 'idle':
        baseDuration = 3000; // 3 secondi
        break;
      case 'moving':
        baseDuration = 5000; // 5 secondi
        break;
      case 'working':
      case 'analyzing':
        baseDuration = 8000; // 8 secondi
        break;
      case 'resting':
        baseDuration = 6000; // 6 secondi
        break;
      default:
        baseDuration = 4000; // 4 secondi
    }
    
    // Aggiungi una variazione casuale del ±30%
    const variation = Phaser.Math.FloatBetween(0.7, 1.3);
    this.stateDuration = baseDuration * variation;
  }
  
  /**
   * Crea o aggiorna la bolla di stato dell'agente
   */
  protected createOrUpdateStatusBubble(): void {
    // Se esiste già una bolla, rimuovila
    if (this.statusBubble) {
      this.statusBubble.destroy();
    }
    
    // Crea un nuovo container per la bolla
    this.statusBubble = this.scene.add.container(this.x, this.y - 30);
    
    // Sfondo della bolla
    const background = this.scene.add.graphics();
    background.fillStyle(0xffffff, 0.7);
    background.fillRoundedRect(-20, -10, 40, 20, 5);
    background.lineStyle(1, 0x000000, 0.3);
    background.strokeRoundedRect(-20, -10, 40, 20, 5);
    
    // Icona o testo in base allo stato
    let icon;
    switch (this.state) {
      case 'idle':
        icon = this.scene.add.text(0, 0, '💤', { fontSize: '12px' });
        break;
      case 'moving':
        icon = this.scene.add.text(0, 0, '🚶', { fontSize: '12px' });
        break;
      case 'working':
        icon = this.scene.add.text(0, 0, '💻', { fontSize: '12px' });
        break;
      case 'resting':
        icon = this.scene.add.text(0, 0, '☕', { fontSize: '12px' });
        break;
      case 'collaborating':
        icon = this.scene.add.text(0, 0, '👥', { fontSize: '12px' });
        break;
      case 'analyzing':
        icon = this.scene.add.text(0, 0, '📊', { fontSize: '12px' });
        break;
      case 'meeting':
        icon = this.scene.add.text(0, 0, '🗣️', { fontSize: '12px' });
        break;
      case 'discussing':
        icon = this.scene.add.text(0, 0, '💬', { fontSize: '12px' });
        break;
      case 'presenting':
        icon = this.scene.add.text(0, 0, '📝', { fontSize: '12px' });
        break;
      default:
        icon = this.scene.add.text(0, 0, '❓', { fontSize: '12px' });
    }
    
    // Centra l'icona
    icon.setOrigin(0.5, 0.5);
    
    // Aggiungi gli elementi al container
    this.statusBubble.add([background, icon]);
  }
  
  /**
   * Aggiorna la posizione della bolla di stato
   */
  protected updateStatusBubble(): void {
    if (this.statusBubble) {
      this.statusBubble.setPosition(this.x, this.y - 30);
    }
  }
}