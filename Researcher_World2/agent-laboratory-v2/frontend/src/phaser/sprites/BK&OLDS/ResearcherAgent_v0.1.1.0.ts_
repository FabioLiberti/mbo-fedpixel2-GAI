import { Agent, AgentState } from './Agent';

// Tipi di ricercatori
export type ResearcherType = 'phd-student' | 'researcher' | 'professor' | 'ml-engineer' | 'data-engineer' | 'privacy-specialist';

// Specializzazioni possibili
export type Specialization = 
  'data-science' | 
  'privacy-engineering' | 
  'optimization-theory' | 
  'secure-aggregation' | 
  'non-iid-data' | 
  'communication-efficiency' | 
  'fl-architecture' | 
  'theoretical-guarantees' | 
  'privacy-economics' | 
  'model-optimization' | 
  'systems-integration' | 
  'empirical-evaluation' | 
  'data-pipeline' | 
  'heterogeneous-data' | 
  'quality-assurance' | 
  'differential-privacy' | 
  'attack-simulation' | 
  'compliance-verification';

export class ResearcherAgent extends Agent {
  private researcherType: ResearcherType;
  protected researcherSpecialization: Specialization;
  private researchProgress: number = 0;
  private collaborationStrength: number = 0;
  private stateTimer: number = 0;
  
  constructor(
    scene: Phaser.Scene,
    x: number,
    y: number,
    texture: string,
    type: ResearcherType,
    specialization: Specialization
  ) {
    super(scene, x, y, texture, type, specialization);
    
    this.researcherType = type;
    this.researcherSpecialization = specialization;
    
    // Configura proprietà specifiche in base al tipo
    this.configureByType();
    
    // Inizializza timer per cambi di stato
    this.stateTimer = Date.now() + Phaser.Math.Between(3000, 6000);
  }
  
  update(time: number, delta: number): void {
    super.update(time, delta);
    
    // Logica di comportamento autonomo
    this.updateBehavior(time);
    
    // Aggiorna la progresso della ricerca quando lavora
    if (this.currentState === 'working' || this.currentState === 'analyzing') {
      this.researchProgress += (delta / 1000) * 0.1;
      
      // Visualizza qualche effetto quando fa progressi significativi
      if (Math.floor(this.researchProgress) % 5 === 0 && 
          Math.floor(this.researchProgress) > 0 &&
          Math.random() < 0.02) {
        this.showResearchProgress();
      }
    }
  }
  
  // Configura proprietà specifiche in base al tipo di ricercatore
  private configureByType(): void {
    switch (this.researcherType) {
      case 'phd-student':
        this.moveSpeed = 70; // Più veloce
        // Cambia colore nameTag
        if (this.nameTag) {
          this.nameTag.setBackgroundColor('#e1f5fe');
        }
        break;
        
      case 'researcher':
        this.moveSpeed = 50; // Velocità normale
        // Cambia colore nameTag
        if (this.nameTag) {
          this.nameTag.setBackgroundColor('#e8f5e9');
        }
        break;
        
      case 'professor':
        this.moveSpeed = 40; // Più lento
        // Cambia colore nameTag
        if (this.nameTag) {
          this.nameTag.setBackgroundColor('#fff3e0');
        }
        break;
        
      case 'ml-engineer':
      case 'data-engineer':
      case 'privacy-specialist':
        this.moveSpeed = 60;
        // Cambia colore nameTag
        if (this.nameTag) {
          this.nameTag.setBackgroundColor('#f3e5f5');
        }
        break;
    }
    
    // Imposta il testo del tag con nome
    if (this.nameTag) {
      this.nameTag.setText(this.formatTitle());
    }
  }
  
  // Formatta il titolo/ruolo per il tag nome
  private formatTitle(): string {
    let title = '';
    
    switch (this.researcherType) {
      case 'phd-student':
        title = 'PhD Student';
        break;
      case 'researcher':
        title = 'Researcher';
        break;
      case 'professor':
        title = 'Professor';
        break;
      case 'ml-engineer':
        title = 'ML Engineer';
        break;
      case 'data-engineer':
        title = 'Data Engineer';
        break;
      case 'privacy-specialist':
        title = 'Privacy Spec.';
        break;
    }
    
    return title;
  }
  
  // Aggiorna il comportamento autonomo
  private updateBehavior(time: number): void {
    // Cambia stato casualmente dopo un certo intervallo
    if (time > this.stateTimer) {
      // Imposta un nuovo timer
      this.stateTimer = time + Phaser.Math.Between(5000, 15000);
      
      // Non cambiare stato se già in movimento
      if (this.currentState === 'moving') return;
      
      // Seleziona casualmente un nuovo stato
      const states: AgentState[] = ['idle', 'working', 'moving', 'discussing', 'resting'];
      let newState = Phaser.Utils.Array.GetRandom(states);
      
      // Se il nuovo stato è 'moving', trova una nuova destinazione
      if (newState === 'moving') {
        const width = this.scene.cameras.main.width;
        const height = this.scene.cameras.main.height;
        
        // Trova una posizione casuale nella scena
        this.targetX = Phaser.Math.Between(50, width - 50);
        this.targetY = Phaser.Math.Between(50, height - 50);
      }
      
      // Imposta il nuovo stato
      this.setState(newState);
    }
  }
  
  // Mostra una piccola animazione per il progresso della ricerca
  private showResearchProgress(): void {
    const idea = this.scene.add.text(this.x, this.y - 30, '💡', {
      fontSize: '20px'
    });
    
    this.scene.tweens.add({
      targets: idea,
      y: idea.y - 30,
      alpha: { from: 1, to: 0 },
      duration: 1000,
      onComplete: () => {
        idea.destroy();
      }
    });
  }
  
  // Override per l'aggiornamento dell'animazione
  protected updateAnimation(dx: number, dy: number): void {
    if (Math.abs(dx) > Math.abs(dy)) {
      // Movimento orizzontale
      if (dx > 0) {
        this.anims.play('walk-right', true);
        this.setFlipX(false);
      } else {
        this.anims.play('walk-left', true);
        this.setFlipX(true);
      }
    } else {
      // Movimento verticale
      if (dy > 0) {
        this.anims.play('walk-down', true);
      } else {
        this.anims.play('walk-up', true);
      }
    }
  }
  
  // Getter per il tipo specifico del ricercatore
  getResearcherType(): ResearcherType {
    return this.researcherType;
  }
  
  // Getter per la specializzazione specifica
  getResearcherSpecialization(): Specialization {
    return this.researcherSpecialization;
  }
  
  // Getter per il progresso della ricerca
  getResearchProgress(): number {
    return this.researchProgress;
  }
}