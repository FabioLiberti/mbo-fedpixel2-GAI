import Phaser from 'phaser';
import { ResearcherAgent } from './ResearcherAgent';
import { 
  MedicalResearcherState, 
  ResearcherType, 
  Specialization,
  ResearcherState,
  MedicalSkills
} from '../types/AgentTypes';

export class MedicalResearcher extends ResearcherAgent {
  // Stato corrente specifico per medici
  protected state: MedicalResearcherState = 'idle';
  
  // Competenze mediche specifiche
  protected medicalSkills: MedicalSkills = {
    diagnostics: 0,
    'patient-care': 0,
    'medical-analytics': 0,
    research: 0,
    ethics: 0,
    collaboration: 0
  };
  
  // Statistiche di attività medica
  protected diagnosticsRun: number = 0;
  protected patientsAnalyzed: number = 0;
  protected publicationsCount: number = 0;
  
  // Indicatore di progresso visivo
  protected progressBar?: Phaser.GameObjects.Graphics;
  protected progressLabel?: Phaser.GameObjects.Text;
  protected progress: number = 0;
  
  constructor(
    scene: Phaser.Scene, 
    x: number, 
    y: number, 
    texture: string,
    type: ResearcherType,
    specialization: Specialization
  ) {
    super(scene, x, y, texture, type, specialization);
    
    // Inizializza competenze mediche in base al tipo
    this.initializeMedicalSkills();
    
    // Crea indicatori di progresso
    this.createProgressIndicators();
  }
  
  /**
   * Inizializza le competenze mediche in base al tipo di ricercatore
   */
  protected initializeMedicalSkills(): void {
    // Valori base
    const baseSkills: Partial<MedicalSkills> = {
      diagnostics: 10,
      'patient-care': 10,
      'medical-analytics': 10,
      research: 10,
      ethics: 10,
      collaboration: 10
    };
    
    // Specializzazioni in base al tipo
    switch (this.type) {
      case 'medical-doctor':
        baseSkills['diagnostics'] += 30;
        baseSkills['patient-care'] += 40;
        this.gainKnowledge('clinical-data', 30);
        break;
      case 'biomedical-engineer':
        baseSkills['medical-analytics'] += 40;
        baseSkills['diagnostics'] += 20;
        this.gainKnowledge('medical-imaging', 30);
        break;
    }
    
    // Applica i valori
    Object.assign(this.medicalSkills, baseSkills);
  }
  
  /**
   * Crea gli indicatori di progresso
   */
  private createProgressIndicators(): void {
    // Crea una barra di progresso sopra l'agente
    this.progressBar = this.scene.add.graphics();
    this.progressLabel = this.scene.add.text(this.x, this.y - 35, '', {
      fontSize: '8px',
      color: '#ffffff',
      align: 'center'
    });
    this.progressLabel.setOrigin(0.5);
    
    // Nascondi inizialmente
    this.hideProgress();
  }
  
  /**
   * Avvia una diagnostica medica
   */
  public startDiagnostics(): void {
    // Imposta lo stato
    this.setAgentState('diagnostics');
    
    // Mostra la barra di progresso
    this.showProgress('Diagnostics');
    this.setProgress(0);
  }
  
  /**
   * Avvia una revisione paziente
   */
  public startPatientReview(): void {
    // Imposta lo stato
    this.setAgentState('patient-review');
    
    // Mostra la barra di progresso
    this.showProgress('Patient Review');
    this.setProgress(0);
  }
  
  /**
   * Avvia un'analisi medica
   */
  public startMedicalAnalysis(): void {
    // Imposta lo stato
    this.setAgentState('medical-analysis');
    
    // Mostra la barra di progresso
    this.showProgress('Medical Analysis');
    this.setProgress(0);
  }
  
  /**
   * Aggiorna lo stato di diagnostica
   */
  protected updateDiagnostics(delta: number): void {
    // Incrementa il progresso
    this.setProgress(this.progress + 0.06 * delta / 16);
    
    // Se la diagnostica è completata
    if (this.progress >= 100) {
      // Incrementa le statistiche
      this.diagnosticsRun++;
      
      // Migliora le competenze mediche
      this.gainMedicalSkill('diagnostics', Phaser.Math.Between(1, 2));
      
      // Possibilità di guadagnare anche in patient-care
      if (Phaser.Math.Between(0, 10) < 3) {
        this.gainMedicalSkill('patient-care', 0.5);
      }
      
      // Rare possibilità di guadagnare in etica e privacy
      if (Phaser.Math.Between(0, 1000) < 5) { // 0.5% probabilità ogni secondo
        this.gainMedicalSkill('ethics', 0.1);
        this.gainKnowledge('privacy', 0.1);
      }
      
      // Ripristina lo stato e nasconde il progresso
      this.setAgentState('idle');
      this.hideProgress();
    }
  }
  
  /**
   * Aggiorna lo stato di revisione paziente
   */
  protected updatePatientReview(delta: number): void {
    // Incrementa il progresso
    this.setProgress(this.progress + 0.04 * delta / 16);
    
    // Se la revisione è completata
    if (this.progress >= 100) {
      // Incrementa pazienti analizzati
      this.patientsAnalyzed++;
      
      // Migliora le competenze mediche
      this.gainMedicalSkill('patient-care', Phaser.Math.Between(1, 3));
      
      // Ripristina lo stato e nasconde il progresso
      this.setAgentState('idle');
      this.hideProgress();
    }
  }
  
  /**
   * Aggiorna lo stato di analisi medica
   */
  protected updateMedicalAnalysis(delta: number): void {
    // Incrementa il progresso
    this.setProgress(this.progress + 0.05 * delta / 16);
    
    // Se l'analisi è completata
    if (this.progress >= 100) {
      // Guadagna competenza in medical-analytics
      this.gainMedicalSkill('medical-analytics', Phaser.Math.Between(1, 3));
      
      // Possibilità di pubblicazione
      if (Phaser.Math.Between(0, 100) < 10) {
        this.addPublication();
      }
      
      // Ripristina lo stato e nasconde il progresso
      this.setAgentState('idle');
      this.hideProgress();
    }
  }
  
  /**
   * Sceglie uno stato casuale specifico per medici
   */
  protected chooseRandomState(): void {
    const medicalStates: MedicalResearcherState[] = [
      'idle', 'moving', 'working', 'resting', 
      'researching', 'analyzing', 'writing',
      'diagnostics', 'patient-review', 'medical-analysis'
    ];
    
    // Probabilità pesate (alcuni stati sono più probabili di altri)
    const weights: Record<MedicalResearcherState, number> = {
      'idle': 1,
      'moving': 3,
      'working': 2,
      'resting': this.energy < 30 ? 5 : 1,
      'researching': 2,
      'analyzing': 2,
      'writing': 1,
      'diagnostics': 3,
      'patient-review': 2,
      'medical-analysis': 2
    };
    
    // Seleziona stato casuale in base ai pesi
    const randomState = this.getWeightedRandomState(medicalStates, weights);
    
    // Se è scelto moving, trova una posizione casuale
    if (randomState === 'moving') {
      this.moveToRandomLocation();
    } 
    // Se è scelto researching, inizia una ricerca
    else if (randomState === 'researching') {
      this.startResearch();
    }
    // Se è diagnostics, avvia diagnostica
    else if (randomState === 'diagnostics') {
      this.startDiagnostics();
    }
    // Se è patient-review, avvia revisione paziente
    else if (randomState === 'patient-review') {
      this.startPatientReview();
    }
    // Se è medical-analysis, avvia analisi medica
    else if (randomState === 'medical-analysis') {
      this.startMedicalAnalysis();
    }
    else {
      // Imposta lo stato direttamente
      this.setAgentState(randomState);
    }
    
    // Imposta un nuovo timer per cambiare stato
    this.setStateChangeTimer();
  }
  
  /**
   * Imposta lo stato dell'agente medico
   */
  setAgentState(newState: MedicalResearcherState): void {
    // Imposta lo stato e aggiorna indicatore
    this.state = newState;
    this.updateStateIndicator();
  }
  
  /**
   * Sposta l'agente in una posizione casuale
   */
  protected moveToRandomLocation(): void {
    const x = Phaser.Math.Between(50, this.scene.cameras.main.width - 50);
    const y = Phaser.Math.Between(50, this.scene.cameras.main.height - 50);
    this.moveTo(x, y);
  }
  
  /**
   * Inizia una ricerca
   */
  public startResearch(): void {
    this.setAgentState('researching');
    this.showProgress('Research');
    this.setProgress(0);
  }
  
  /**
   * Imposta un timer per il prossimo cambio di stato
   */
  protected setStateChangeTimer(): void {
    // Cancella timer esistenti
    if (this.stateTimer) {
      this.stateTimer.destroy();
    }
    
    // Imposta un nuovo timer casuale (da 3 a 10 secondi)
    const delay = Phaser.Math.Between(3000, 10000);
    this.stateTimer = this.scene.time.addEvent({
      delay: delay,
      callback: this.chooseRandomState,
      callbackScope: this
    });
  }
  
  /**
   * Migliora una competenza medica
   */
  protected gainMedicalSkill(skill: keyof MedicalSkills, amount: number): void {
    if (this.medicalSkills[skill] !== undefined) {
      this.medicalSkills[skill] = Math.min(100, this.medicalSkills[skill] + amount);
    }
  }
  
  /**
   * Aggiunge una pubblicazione al ricercatore
   */
  protected addPublication(): void {
    this.publicationsCount++;
    
    // Crea un effetto visivo temporaneo
    const text = this.scene.add.text(this.x, this.y - 30, 'Publication! 📝', {
      fontSize: '10px',
      color: '#ffff00',
      stroke: '#000000',
      strokeThickness: 2
    });
    text.setOrigin(0.5);
    
    // Anima il testo
    this.scene.tweens.add({
      targets: text,
      y: this.y - 60,
      alpha: 0,
      duration: 1500,
      onComplete: () => {
        text.destroy();
      }
    });
  }
  
  /**
   * Ottiene uno stato casuale in base ai pesi
   */
  private getWeightedRandomState<T>(states: T[], weights: Record<string, number>): T {
    const totalWeight = states.reduce((sum, state) => sum + (weights[String(state)] || 1), 0);
    let random = Phaser.Math.Between(0, totalWeight);
    
    for (const state of states) {
      const weight = weights[String(state)] || 1;
      random -= weight;
      if (random <= 0) {
        return state;
      }
    }
    
    return states[0];
  }
  
  /**
   * Mostra la barra di progresso
   */
  protected showProgress(label: string): void {
    if (this.progressLabel) {
      this.progressLabel.setText(label);
      this.progressLabel.setVisible(true);
    }
    if (this.progressBar) {
      this.progressBar.setVisible(true);
    }
  }
  
  /**
   * Nasconde la barra di progresso
   */
  protected hideProgress(): void {
    if (this.progressLabel) {
      this.progressLabel.setVisible(false);
    }
    if (this.progressBar) {
      this.progressBar.setVisible(false);
    }
  }
  
  /**
   * Imposta il valore della barra di progresso
   */
  protected setProgress(value: number): void {
    this.progress = Phaser.Math.Clamp(value, 0, 100);
    
    // Aggiorna la barra grafica
    if (this.progressBar) {
      this.progressBar.clear();
      
      // Sfondo della barra
      this.progressBar.fillStyle(0x000000, 0.5);
      this.progressBar.fillRect(this.x - 15, this.y - 25, 30, 5);
      
      // Barra di progresso
      this.progressBar.fillStyle(0x00ff00, 0.8);
      this.progressBar.fillRect(this.x - 15, this.y - 25, 30 * (this.progress / 100), 5);
    }
  }
  
  // Override dell'update per gestire stati specifici dei medici
  update(time: number, delta: number): void {
    super.update(time, delta);
    
    // Aggiorna la posizione degli indicatori di progresso
    if (this.progressBar && this.progressLabel) {
      this.setProgress(this.progress);
      this.progressLabel.setPosition(this.x, this.y - 35);
    }
    
    // Gestisci comportamenti specifici per stati medici
    switch (this.state) {
      case 'diagnostics':
        this.updateDiagnostics(delta);
        break;
      case 'patient-review':
        this.updatePatientReview(delta);
        break;
      case 'medical-analysis':
        this.updateMedicalAnalysis(delta);
        break;
    }
  }
  
  // Override di handleClick per mostrare informazioni mediche
  protected handleClick(): void {
    console.log('Medical Researcher clicked:', {
      type: this.type,
      specialization: this.specialization,
      medicalSkills: this.medicalSkills,
      diagnosticsRun: this.diagnosticsRun,
      patientsAnalyzed: this.patientsAnalyzed,
      publications: this.publicationsCount
    });
    
    // Crea un popup informativo
    const info = this.scene.add.text(this.x, this.y - 50, 
      `${this.type} - ${this.specialization}\n` +
      `Diagnostics: ${this.diagnosticsRun} | Patients: ${this.patientsAnalyzed}\n` +
      `Publications: ${this.publicationsCount}`,
      {
        fontSize: '10px',
        backgroundColor: '#333333',
        padding: { x: 5, y: 5 },
        color: '#ffffff'
      }
    );
    info.setOrigin(0.5);
    
    // Autodissolve dopo 3 secondi
    this.scene.time.delayedCall(3000, () => {
      this.scene.tweens.add({
        targets: info,
        alpha: 0,
        duration: 500,
        onComplete: () => {
          info.destroy();
        }
      });
    });
  }
}