import Phaser from 'phaser';

// Stati possibili per un agente
export type AgentState = 'idle' | 'working' | 'moving' | 'discussing' | 'resting' | 'analyzing' | 'collaborating';

// Classe base per tutti gli agenti
export class Agent extends Phaser.Physics.Arcade.Sprite {
  // Proprietà base dell'agente
  protected agentId: string;
  protected agentType: string;
  protected agentSpecialization: string;
  protected currentState: AgentState;
  protected targetX: number;
  protected targetY: number;
  protected moveSpeed: number;
  
  // Elementi visuali aggiuntivi
  protected statusEmoji?: Phaser.GameObjects.Text;
  protected nameTag?: Phaser.GameObjects.Text;
  
  constructor(
    scene: Phaser.Scene,
    x: number,
    y: number,
    texture: string,
    type: string,
    specialization: string
  ) {
    super(scene, x, y, texture);
    
    // Aggiungi lo sprite alla scena e al engine di fisica
    scene.add.existing(this);
    scene.physics.add.existing(this);
    
    // Inizializza proprietà
    this.agentId = `agent-${Date.now()}-${Math.floor(Math.random() * 1000)}`;
    this.agentType = type;
    this.agentSpecialization = specialization;
    this.currentState = 'idle';
    this.targetX = x;
    this.targetY = y;
    this.moveSpeed = 50;
    
    // Configura fisica
    this.setCollideWorldBounds(true);
    this.setBounce(0.1);
    
    // Crea elementi visuali
    this.createVisualElements();
    
    // Imposta la profondità in base alla posizione Y per effetto di sovrapposizione
    this.setDepth(y);
  }
  
  // Metodo di aggiornamento che verrà chiamato ad ogni frame
  update(time: number, delta: number): void {
    // Aggiorna posizione
    this.updateMovement();
    
    // Aggiorna elementi visivi
    this.updateVisualElements();
    
    // Aggiorna profondità in base alla posizione Y
    this.setDepth(this.y);
  }
  
  // Imposta un nuovo stato per l'agente
  setState(newState: AgentState): this {
    this.currentState = newState;
    this.updateStatusEmoji();
    return this;
  }
  
  // Ottieni lo stato corrente
  getState(): AgentState {
    return this.currentState;
  }
  
  // Imposta una nuova destinazione
  setTarget(x: number, y: number): this {
    this.targetX = x;
    this.targetY = y;
    this.currentState = 'moving';
    this.updateStatusEmoji();
    return this;
  }
  
  // Crea elementi visuali associati all'agente
  protected createVisualElements(): void {
    // Emoji di stato sopra l'agente
    this.statusEmoji = this.scene.add.text(this.x, this.y - 15, '💭', {
      fontSize: '16px'
    });
    
    // Tag con nome sotto l'agente
    this.nameTag = this.scene.add.text(this.x, this.y + 15, this.agentType, {
      fontSize: '8px',
      backgroundColor: '#ffffff',
      padding: { x: 2, y: 1 },
      color: '#000000'
    });
    this.nameTag.setOrigin(0.5);
  }
  
  // Aggiorna elementi visuali
  protected updateVisualElements(): void {
    if (this.statusEmoji) {
      this.statusEmoji.setPosition(this.x, this.y - 15);
    }
    
    if (this.nameTag) {
      this.nameTag.setPosition(this.x, this.y + 15);
    }
  }
  
  // Aggiorna movimento verso la destinazione
  protected updateMovement(): void {
    if (this.currentState === 'moving') {
      const dx = this.targetX - this.x;
      const dy = this.targetY - this.y;
      const distance = Math.sqrt(dx * dx + dy * dy);
      
      if (distance > 5) {
        // Calcola velocità
        const velocityX = (dx / distance) * this.moveSpeed;
        const velocityY = (dy / distance) * this.moveSpeed;
        
        // Imposta velocità
        this.setVelocity(velocityX, velocityY);
        
        // Aggiorna animazione in base alla direzione
        this.updateAnimation(dx, dy);
      } else {
        // Raggiunta la destinazione
        this.setVelocity(0, 0);
        this.currentState = 'idle';
        this.updateStatusEmoji();
      }
    }
  }
  
  // Aggiorna animazione in base alla direzione di movimento
  protected updateAnimation(dx: number, dy: number): void {
    // Da implementare nelle sottoclassi
  }
  
  // Aggiorna l'emoji di stato in base allo stato corrente
  protected updateStatusEmoji(): void {
    if (!this.statusEmoji) return;
    
    switch (this.currentState) {
      case 'idle':
        this.statusEmoji.setText('💭');
        break;
      case 'working':
        this.statusEmoji.setText('💻');
        break;
      case 'moving':
        this.statusEmoji.setText('🚶');
        break;
      case 'discussing':
        this.statusEmoji.setText('💬');
        break;
      case 'resting':
        this.statusEmoji.setText('😴');
        break;
      case 'analyzing':
        this.statusEmoji.setText('📊');
        break;
      case 'collaborating':
        this.statusEmoji.setText('👥');
        break;
    }
  }
  
  // Ottieni l'ID dell'agente
  getId(): string {
    return this.agentId;
  }
  
  // Ottieni il tipo dell'agente
  getType(): string {
    return this.agentType;
  }
  
  // Ottieni la specializzazione dell'agente
  getSpecialization(): string {
    return this.agentSpecialization;
  }
}